ass=\"multiselect-content\"><ul><li data-ng-repeat=\"data in options | filter:selectmodel \" ><label class=\"reg bigchecklabel\"><input type=\"checkbox\" ng-checked=\"selectedItemList.indexOf(data) > -1\" class=\"bigcheckbox\" id=\"{{data.c}}\" data-ng-click=\"multiSelectVals(data)\" value={{data.c}}/> {{data.n}}</label></li></ul></div></div></dd></dl>                    <br><br>     <div class=\"row pad-t-20\"><span class=\"stateselected\" data-ng-repeat=\"data in selectedItemList\">{{data.n}} <span class=\"statecancel\" data-ng-click=\"removeMultiSelRem(data)\">X</span></span></div></div>' +\n\n\t\t\t'<div data-ng-if=\"multiSelRemoteFlag\"><dl class=\"multiselect\"><dt><a href=\"#\" class=\"statelisterr\"><input data-ng-model=\"selectmodel\" class=\"form-control pad-r-0 hida \" type=\"text\" data-ng-click=\"sliding()\" placeholder=\"Select\" data-ng-change=\"typeSelectFilter()\" /><button type=\"button\" id=\"caret\" data-ng-click = \"sliding()\"> &#9660;</button><p class=\"multiSel\"></p></a></dt><dd><div class=\"mutliSelect\" id=\"multiSel\" ng-show=\"showList\"><div class=\"multiselect-content\"><ul><li id=\"selListDir\" data-ng-repeat=\"data in optionsRemMulti | filter:selectmodel\" ><label class=\"reg bigchecklabel\"><input type=\"checkbox\" ng-checked=\"selectedItemList.indexOf(data) > -1\"  class=\"bigcheckbox\" id=\"{{data.c}}\" data-ng-click=\"multiSelectVals(data)\" value={{data.c}}/> {{data.n}}</label></li></ul></div></div></dd></dl>                   <br><br>      <div class=\"row pad-t-20\"><span class=\"stateselected\" data-ng-repeat=\"data in selectedItemList\">{{data.n}} <span class=\"statecancel\" data-ng-click=\"removeMultiSelRem(data)\">X</span></span></div></div>',\n\n\n\t\tlink: function (scope, element, attrs) {\n\n\t\t\t$(document).bind('click', function (e) {\n\t\t\t\tvar $clicked = $(e.target);\n\t\t\t\tif (!$clicked.parents().hasClass(\"multiselect\")) {\n\t\t\t\t\tconsole.log(\"in\");\n\t\t\t\t\t$(\".multiselect dd ul\").hide();\n\t\t\t\t\tscope.showList = false;\n\t\t\t\t} else {\n\t\t\t\t\t$(\".multiselect dd ul\").show();\n\t\t\t\t\t//                    scope.showList = true;\n\t\t\t\t}\n\t\t\t});\n\n\t\t\tscope.selectedItemList = [];\n\t\t\tscope.multiSelLocalFlag = false;\n\t\t\tscope.multiSelRemoteFlag = false;\n\t\t\tscope.singleRemoteSel = false;\n\t\t\tscope.singleLocalSel = false;\n\t\t\tscope.showList = false;\n\t\t\t//to toggle display of list in multi select\n\t\t\tscope.sliding = function () {\n\t\t\t\tscope.showList = !scope.showList;\n\t\t\t};\n\t\t\t// to show list when user is typing\n\t\t\tscope.typeSelectFilter = function () {\n\t\t\t\tscope.showList = true;\n\t\t\t};\n\t\t\tscope.sendData = function (object) {\n\t\t\t\tfor (var i = 0; i < scope.selectedItemList.length; i++) {\n\t\t\t\t\tif (scope.selectedItemList[i].c === object) {\n\t\t\t\t\t\tscope.callback({\n\t\t\t\t\t\t\tobjectList: scope.selectedItemList[i]\n\t\t\t\t\t\t});\n\t\t\t\t\t\tbreak;\n\t\t\t\t\t}\n\t\t\t\t}\n\t\t\t};\n\t\t\t// remove values when clicked on span and uncheck checkbox value in list \n\t\t\tscope.removeMultiSelRem = function (object) {\n\t\t\t\tangular.forEach(scope.selectedItemList, function (item, key) {\n\t\t\t\t\tif (item.c == object.c) {\n\t\t\t\t\t\t$(\"#\" + item.c).prop(\"checked\", false);\n\t\t\t\t\t}\n\t\t\t\t});\n\t\t\t\tvar index = scope.selectedItemList.indexOf(object);\n\t\t\t\tscope.selectedItemList.splice(index, 1);\n\t\t\t\tscope.callback({\n\t\t\t\t\tobjectList: scope.selectedItemList\n\t\t\t\t});\n\t\t\t};\n\n\t\t\t// store checked values function\n\t\t\tscope.multiSelectVals = function (object) {\n\t\t\t\tvar index = scope.selectedItemList.indexOf(object);\n\t\t\t\tif (index !== -1) {\n\t\t\t\t\tscope.selectedItemList.splice(index, 1);\n\t\t\t\t} else {\n\t\t\t\t\tscope.selectedItemList.push(object);\n\t\t\t\t}\n\t\t\t\tscope.callback({\n\t\t\t\t\tobjectList: scope.selectedItemList\n\t\t\t\t});\n\t\t\t};\n\n\n\t\t\tif (attrs.dptype == \"single\") {\n\t\t\t\tif (attrs.optntype == \"local\") {\n\t\t\t\t\tscope.selectedItemList = scope.options;\n\t\t\t\t\tscope.singleLocalSel = true;\n\t\t\t\t} else if (attrs.optntype == \"remote\") {\n\t\t\t\t\tajax.get(attrs.optRemoteUrl).then(function (response) {\n\t\t\t\t\t\tscope.selectedItemList = response.data;\n\t\t\t\t\t\tscope.singleRemoteSel = true;\n\t\t\t\t\t}, function (err) {\n\t\t\t\t\t\tconsole.log(err);\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t} else if (attrs.dptype == \"multiselect\") {\n\t\t\t\tif (attrs.optntype == \"local\") {\n\t\t\t\t\tscope.multiSelLocalFlag = true;\n\t\t\t\t} else if (attrs.optntype == \"remote\") {\n\t\t\t\t\tajax.get(attrs.optRemoteUrl).then(function (response) {\n\t\t\t\t\t\tscope.optionsRemMulti = response.data;\n\t\t\t\t\t\tscope.multiSelRemoteFlag = true;\n\t\t\t\t\t}, function (err) {\n\t\t\t\t\t\tconsole.log(err);\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t};\n\n}]);\nmyApp.directive('customSelectMfy', ['ajax', '$http', '$compile', 'shareData', function(ajax, $http, $compile, shareData) {\n\n    return {\n        restrict: \"E\",\n        scope: {\n            id: \"@\",\n            selectmodel: \"=\",\n            name: \"@\",\n            dptype: \"@\",\n            placeholder: \"@\",\n            options: \"=\",\n            optntype: \"@\",\n            optRemoteUrl: \"@\",\n            callback: \"&\",\n        },\n        template: '<select data-ng-model=\"selectmodel\" class=\"form-control\" id={{id}} name={{name}} data-ng-options=\"data for data in selectedItemList\" data-ng-change=\"sendData(this.selectmodel)\" data-ng-if=\"singleLocalSel\" ><option style=\"display:none\" value=\"\">Select</option></select>' +\n\n            '<select data-ng-model=\"selectmodel\" class=\"form-control\" id={{id}} name={{name}} data-ng-options=\"data for data in selectedItemList\" data-ng-change=\"sendData(this.selectmodel)\" data-ng-if=\"singleRemoteSel\">data-ng-show=\"singleLocalSel\" ><option style=\"display:none\" value=\"\">Select</option></select>' +\n\n            '<div data-ng-if=\"multiSelLocalFlag\"><dl class=\"multiselect\"><dt><a href=\"#\" class=\"statelisterr\"><input data-ng-model=\"selectmodel\" class=\"form-control pad-r-0 hida \" type=\"text\" data-ng-click=\"sliding()\" data-ng-change=\"typeSelectFilter()\" placeholder=\"Select\"/><button type=\"button\" id=\"caret\" data-ng-click = \"sliding()\"> &#9660;</button><p class=\"multiSel\"></p></a></dt><dd><div class=\"mutliSelect\" id=\"multiSel\" ng-show=\"showList\"><div class=\"multiselect-content\"><ul><li data-ng-repeat=\"data in options\" ><label class=\"reg bigchecklabel\"><input type=\"checkbox\" ng-checked=\"selectedItemList.indexOf(data) > -1\" class=\"bigcheckbox\" id=\"{{data}}\" data-ng-click=\"multiSelectVals(data)\" ng-disabled =\"data.f\" value={{data}}/> {{data}}</label></li></ul></div></div></dd></dl>                    <br><br>     <div class=\"row pad-t-20\" style=\"margin-left:0px\"><p ng-show=\"selectedItemList.length > 0\"><em><b>Selected Items:</b></em></p><span class=\"stateselected\" data-ng-repeat=\"data in selectedItemList\">{{data}} <span class=\"statecancel\" data-ng-click=\"removeMultiSelRem(data)\">X</span></span></div></div>' +\n\n            '<div data-ng-if=\"multiSelRemoteFlag\"><dl class=\"multiselect\"><dt><a href=\"#\" class=\"statelisterr\"><input data-ng-model=\"selectmodel\" class=\"form-control pad-r-0 hida \" type=\"text\" data-ng-click=\"sliding()\" placeholder=\"Select\" data-ng-change=\"typeSelectFilter()\" /><button type=\"button\" id=\"caret\" data-ng-click = \"sliding()\"> &#9660;</button><p class=\"multiSel\"></p></a></dt><dd><div class=\"mutliSelect\" id=\"multiSel\" ng-show=\"showList\"><div class=\"multiselect-content\"><ul><li id=\"selListDir\" data-ng-repeat=\"data in optionsRemMulti | filter:selectmodel\" ><label class=\"reg bigchecklabel\"><input type=\"checkbox\" ng-checked=\"selectedItemList.indexOf(data) > -1\"  class=\"bigcheckbox\" id=\"{{data.c}}\" data-ng-click=\"multiSelectVals(data)\" value={{data.c}}/> {{data.n}}</label></li></ul></div></div></dd></dl>                   <br><br>      <div class=\"row pad-t-20\" style=\"margin-left:0px\"><p ng-show=\"selectedItemList.length > 0\"><em><b>Selected Items:</b></em></p><span class=\"stateselected\" data-ng-repeat=\"data in selectedItemList\">{{data.n}} <span class=\"statecancel\" data-ng-click=\"removeMultiSelRem(data)\">X</span></span></div></div>',\n\n\n        link: function(scope, element, attrs) {\n            $(document).bind('click', function(e) {\n                var $clicked = $(e.target);\n                if (!$clicked.parents().hasClass(\"multiselect\")) {\n                    $(\".multiselect dd ul\").hide();\n                    scope.showList = false;\n                } else {\n                    $(\".multiselect dd ul\").show();\n                    //\t\t\t\t\tscope.showList=true;\n                }\n            });\n            scope.selectedItemList = [];\n            if (shareData.sec != undefined) {\n                scope.selectedItemList = shareData.sec;\n            }\n            scope.multiSelLocalFlag = false;\n            scope.multiSelRemoteFlag = false;\n            scope.singleRemoteSel = false;\n            scope.singleLocalSel = false;\n            scope.showList = false;\n            //to toggle display of list in multi select\n            scope.sliding = function() {\n                scope.showList = !scope.showList;\n            };\n            // to show list when user is typing\n            scope.typeSelectFilter = function() {\n                scope.showList = true;\n            };\n            scope.sendData = function(object) {\n                for (var i = 0; i < scope.selectedItemList.length; i++) {\n                    if (scope.selectedItemList[i].c === object) {\n                        scope.callback({ objectList: scope.selectedItemList[i] });\n                        break;\n                    }\n                }\n            };\n            // remove values when clicked on span and uncheck checkbox value in list \n            scope.removeMultiSelRem = function(object) {\n                angular.forEach(scope.selectedItemList, function(item, key) {\n                    if (item.c == object.c) {\n                        $(\"#\" + item.c).prop(\"checked\", false);\n                    }\n                });\n                var index = scope.selectedItemList.indexOf(object);\n                scope.selectedItemList.splice(index, 1);\n                scope.callback({ objectList: scope.selectedItemList });\n            };\n\n            shareData.resetAll = function() {\n                scope.selectedItemList = [];\n                scope.selectmodel = [];\n                scope.callback({ objectList: scope.selectedItemList });\n            };\n\n            // store checked values function\n            scope.multiSelectVals = function(object) {\n                var index = scope.selectedItemList.indexOf(object);\n                if (index !== -1) {\n                    scope.selectedItemList.splice(index, 1);\n                } else {\n                    scope.selectedItemList.push(object);\n                }\n                scope.callback({ objectList: scope.selectedItemList });\n            };\n\n\n            if (attrs.dptype == \"single\") {\n                if (attrs.optntype == \"local\") {\n                    scope.selectedItemList = scope.options;\n                    scope.singleLocalSel = true;\n                } else if (attrs.optntype == \"remote\") {\n                    ajax.get(attrs.optRemoteUrl).then(function(response) {\n                        scope.selectedItemList = response.data;\n                        scope.singleRemoteSel = true;\n                    }, function(err) {\n                        console.log(err);\n                    });\n                }\n            } else if (attrs.dptype == \"multiselect\") {\n                if (attrs.optntype == \"local\") {\n                    scope.multiSelLocalFlag = true;\n                } else if (attrs.optntype == \"remote\") {\n\t\t\t\t\tajax.get(attrs.optRemoteUrl).then(function (response) {\n\t\t\t\t\t\tscope.optionsRemMulti = response.data;\n\t\t\t\t\t\tscope.multiSelRemoteFlag = true;\n\t\t\t\t\t}, function (err) {\n\t\t\t\t\t\tconsole.log(err);\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t}\n\t\t}\n\t};\n\n}]);\n//CR-18078 Rectification directives\nmyApp.directive('customSelectTable', function () {\n\treturn {\n\t\trestrict: \"E\",\n\t\tscope: {\n\t\t\tid: \"@\",\n\t\t\tselectmodel: \"=\",\n\t\t\tname: \"@\",\n\t\t\tplaceholder: \"@\",\n\t\t\toptions: \"=\",\n\t\t\tcallback: \"&\",\n\t\t},\n\t\ttemplate: '<div><dl class=\"multiselect\"><dt><a class=\"statelisterr\"><input data-ng-model=\"selectmodel\" class=\"form-control pad-r-0 hida \" type=\"text\" data-ng-click=\"sliding()\" data-ng-change=\"typeSelectFilter()\" placeholder=\"Select\"/><button type=\"button\" id=\"caret\" data-ng-click = \"sliding()\"> &#9660;</button><p class=\"multiSel\"></p></a></dt><dd><div class=\"mutliSelect\" id=\"multiSel\" ng-show=\"showList\"><div class=\"multiselect-content\"><ul style=\"height: auto;min-height: 130px;\"><li data-ng-repeat=\"data in options | filter:selectmodel \" ><label class=\"reg bigchecklabel\"><input type=\"checkbox\" ng-checked=\"selectedItemList.indexOf(data) > -1\" class=\"bigcheckbox\" id=\"{{data.c}}\" data-ng-click=\"multiSelectVals(data)\" value={{data.c}}/> {{data.n}}</label></li></ul></div></div></dd></dl><br><br></div>',\n\t\tlink: function (scope, element, attrs) {\n\t\t\t$(document).bind('click', function (e) {\n\t\t\t\tvar $clicked = $(e.target);\n\t\t\t\tif (!$clicked.parents().hasClass(\"multiselect\")) {\n\t\t\t\t\t$(\".multiselect dd ul\").hide();\n\t\t\t\t\tscope.showList = false;\n\t\t\t\t} else {\n\t\t\t\t\t$(\".multiselect dd ul\").show();\n\t\t\t\t}\n\t\t\t});\n\t\t\tscope.selectedItemList = [];\n\t\t\tscope.showList = false;\n\t\t\t//to toggle display of list in multi select\n\t\t\tscope.sliding = 