me":"content-type","value":"text/html"},{"name":"date","value":"Fri, 22 May 2026 16:51:12 GMT"},{"name":"etag","value":"W/\"69fafd6c-1f65\""},{"name":"expires","value":"Fri, 22 May 2026 22:51:12 GMT"},{"name":"last-modified","value":"Wed, 06 May 2026 08:35:56 GMT"},{"name":"pragma","value":"public"},{"name":"strict-transport-security","value":"max-age=31536000; includeSubDomains"},{"name":"vary","value":"Accept-Encoding"},{"name":"x-content-type-options","value":"nosniff"},{"name":"x-frame-options","value":"SAMEORIGIN"},{"name":"x-xss-protection","value":"1; mode=block"}],"content":{"size":8037,"mimeType":"text/html","compression":6225,"text":"<style>\r\n    @media(max-width:1000px) {\r\n        .namechange {\r\n            width: 50%;\r\n            font-size: 12px;\r\n            white-space: nowrap;\r\n        }\r\n    }\r\n    \r\n    @media(max-width:475px) {\r\n        .namechange {\r\n            width: 50%;\r\n            font-size: 12px;\r\n            white-space: nowrap;\r\n        }\r\n    }\r\n</style>\r\n<div class=\"row\">\r\n    <div class=\"col-sm-offset-2 col-md-offset-3 col-md-6 col-sm-8 col-xs-12\">\r\n        <div class=\"row\">\r\n            <div class=\"col-xs-12\">\r\n                <div class=\"row\">\r\n\t\t\t\t\t<div class=\"col-xs-12 err\" data-ng-show=\"errors.login_error\">\r\n\t\t\t\t\t\t<div  class=\"alert  alert-danger\" data-ng-if=\"errors.login_error_desc === 'ERR_SWEB_9036'\">\r\n\t\t\t\t\t\t\t<p> The last date for filing Form GST REG-26 for enrolment/ migration of existing taxpayers is over. Since you did not complete the migration process within the allowed period, the Provisional ID has been cancelled. However, you may apply as a new taxpayer at GST portal by \r\n\t\t\t\t\t\t\t<a ng-click=\"newregclick()\"> Clicking Here</a></p>\t\t\t\t\t\t\t \r\n\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t<div data-ng-if=\"errors.login_error_desc != 'ERR_SWEB_9036'\" class=\"err\" name=\"errContainer\"></div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n<!--\r\n                <div class=\"row\">\r\n\t\t\t\t\t<div class=\"col-xs-12 \" data-ng-show=\"success.login_success\">\r\n\t\t\t\t\t\t<div  name=\"successContainer\"></div>\r\n\t\t\t\t\t</div>\r\n\t\t\t\t</div>\r\n-->\r\n                <p class=\"alert  alert-success \" id=\"alertMsg\" data-ng-hide=\"alertMsgSuccess\"><span data-ng-bind=\"successMsg\"></span></p>\r\n                <h4 class=\"mar-t-0\" data-ng-bind=\"trans.HEAD_LOGIN\"></h4>\r\n\t\t\t\t\t\t\t\t\r\n                <hr>\r\n\t\t\t\t\r\n                <p class=\"mand-text\" data-ng-bind=\"trans.HLP_MAND_FIELD\"></p>\r\n\t\t\t\t\r\n                <form class=\"\" role=\"form\" name=\"loginform\" data-accessible-form=\"\" data-ng-submit=\"saveUserLogin();\">\r\n                    <div class=\"row\">\r\n                        <div class=\"col-xs-12\">\r\n                            <label for=\"username\" class=\"m-cir reg\" data-ng-bind=\"trans.LBL_USRNAME\"></label>\r\n                            <div class=\"has-feedback\" data-ng-class=\"{'has-error': loginform.$submitted && loginform.user_name.$invalid, 'has-success': loginform.$submitted && loginform.user_name.$valid}\">\r\n                                <input id=\"username\" class=\"form-control pad-r-0\" type=\"text\" placeholder=\"{{trans.HLP_USERNAME}}\" name=\"user_name\" data-ng-model=\"lform.username\" maxlength=\"15\" data-ng-pattern=\"/^[a-zA-Z][a-zA-Z0-9_.-]*$/\" required=\"true\" data-ng-change=\"validName();\" autofocus autocomplete=\"off\">\r\n                                <span class=\"glyphicon glyphicon-ok form-control-feedback\" data-ng-show=\"loginform.$submitted && loginform.user_name.$valid\"></span>\r\n                            </div>\r\n                            <span data-ng-if=\"loginform.$submitted && loginform.user_name.$error.required\" class=\"err\" data-ng-bind=\"trans.ERR_MAND\"></span>\r\n                            <span data-ng-if=\"loginform.$submitted && loginform.user_name.$error.pattern\" class=\"err\">Enter valid username</span>\r\n                        </div>\r\n                    </div>\r\n\t\t\t\t\t<div class=\"hidden\">\r\n                        <input type=\"password\" name=\"user_pass\" />\r\n                    </div>\r\n                    <div class=\"row\">\r\n                        <div class=\"col-xs-12\">\r\n                            <label for=\"user_pass\" class=\"m-cir reg\" data-ng-bind=\"trans.LBL_PWD\"></label>\r\n                            <div class=\"has-feedback\" data-ng-class=\"{'has-error': loginform.$submitted && loginform.user_pass.$invalid && !loginform.captcha.$error.invalid_captcha, \r\n\t\t\t\t\t\t\t'has-success': loginform.$submitted && loginform.user_pass.$valid}\">\r\n\r\n                                <input id=\"user_pass\" class=\"form-control\" type=\"password\" name=\"user_pass\" data-ng-model=\"lform.password\" maxlength=\"15\" data-ng-paste=\"$event.preventDefault();\" required=\"true\" placeholder=\"{{trans.HLP_PWD}}\" autocomplete=\"off\" />\r\n                                <span class=\"glyphicon glyphicon-ok form-control-feedback\" data-ng-show=\"loginform.$submitted && loginform.user_pass.$valid\"></span>\r\n                            </div>\r\n                            <span data-ng-if=\"loginform.$submitted && loginform.user_pass.$error.required\" class=\"err\" data-ng-bind=\"trans.ERR_MAND\"></span>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"row\" data-ng-if=\"loginform.user_name.$dirty ||  loginform.user_pass.$dirty\"  >\r\n                        <div class=\"col-xs-12\">\r\n                            <label for=\"captcha\" class=\"m-cir reg\" data-ng-bind=\"trans.LBL_CAPTCHA\"> </label>\r\n\t\t\t\t\t\t\t<div class=\"has-feedback\" data-ng-class=\"{'has-error': loginform.$submitted && loginform.captcha.$invalid, 'has-success': loginform.$submitted && loginform.captcha.$valid}\">\r\n\t\t\t\t\t\t\t\t<input id=\"captcha\" class=\"form-control number\" name=\"captcha\" placeholder=\"{{trans.HLP_CAPTCHA}}\" data-ng-model=\"lform.captcha\" data-ng-paste=\"$event.preventDefault();\" required=\"true\" data-ng-pattern=\"validations.formats.number\"   \r\n\t\t\t\t\t\t\t\t data-ng-keydown=\"setPristine('loginform', 'captcha', 'invalid_captcha')\" autocomplete=\"off\" >\r\n\t\t\t\t\t\t\t</div>\r\n\t\t\t\t\t\t\t<span data-ng-if=\"loginform.$submitted && loginform.captcha.$error.required && !loginform.captcha.$error.invalid_captcha\" class=\"err\" data-ng-bind=\"trans.ERR_MAND\"></span>\r\n\t\t\t\t\t\t\t <span data-ng-if=\"loginform.$submitted && ((loginform.captcha.$error.minlength) || (loginform.captcha.$error.pattern))\" class=\"err\" data-ng-bind=\"trans.ERR_CAPTCHA\"></span>\r\n\t\t\t\t\t\t\t<span data-ng-if=\"loginform.captcha.$error.invalid_captcha\" class=\"err\" data-ng-bind=\"trans.ERR_SWEB_9000\"></span>\r\n\t\t\t\t\t\t\t\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"row\" >\r\n                        <div class=\"col-xs-12\">\r\n                             <div data-ng-if=\"loginform.user_name.$dirty ||  loginform.cred.$dirty\"  >\r\n                              \r\n                               <div data-captcha=\"\" data-captcha-object=\"captchaObj\"></div> <span class=\"err\" data-ng-if=\"errors.captcha\" data-ng-bind=\"errors.captcha\"></span>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"row\">\r\n                        <div class=\"col-lg-6 col-md-6 col-sm-6 col-xs-6\">\r\n                            <button type=\"submit\" class=\"btn  btn-primary\" data-ng-bind=\"trans.HEAD_LOGIN\"></button>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"row\">\r\n                        <div class=\"col-lg-6 col-md-6 col-sm-6 col-xs-6 namechange\">\r\n                            <a class=\"link\" href=\"/services/forgotusername\" data-ng-bind=\"trans.HEAD_FORGT_USERNAME\"></a>\r\n                        </div>\r\n                        <div data-ng-if=\"!hidemenu\" class=\"col-lg-6 col-md-6 col-sm-6 col-xs-6 namechange\">\r\n                            <div class=\"pull-right\">\r\n                                <a class=\"link\" href=\"/services/forgotpassword\" data-ng-bind=\"trans.HEAD_FORGT_PWD\"></a>\r\n                            </div>\r\n                        </div>\r\n                        <div data-ng-if=\"hidemenu\" class=\"col-lg-6 col-md-6 col-sm-6 col-xs-6\">\r\n                            <div class=\"pull-right\">\r\n                                <a class=\"link\" href=\"/services/forgotpassword?flag=einvoice\" data-ng-bind=\"trans.HEAD_FORGT_PWD\"></a>\r\n                            </div>\r\n                        </div>\r\n                    </div>\r\n                    <div class=\"row\">\r\n                        <div class=\"col-sm-12\">\r\n                            <p class=\"help-block\"><i class=\"fa fa-info-circle\"></i><strong> First time login:</strong> If you are logging in for the first time, click <a href=\"/services/newlogin\"><u>here</u></a> to log in.</p>\r\n                        </div>\r\n                    </div>\r\n                </form>\r\n            </div>\r\n        </div>\r\n    </div>\r\n</div>"},"headersSize":1184,"bodySize":1812,"redirectURL":"","_transferSize":2996},"cache":{},"timings":{"dns":0.003,"connect":83.565,"ssl":44.292,"send":0,"wait":48.306,"receive":1.521},"serverIPAddress":"103.83.77.48","_serverPort":443,"_securityDetails":{"protocol":"TLS 1.2","subjectName":"services.gst.gov.in","issuer":"GlobalSign Extended Validation CA - SHA256 - G3","validFrom":1747043474,"validTo":1781344273}},{"pageref":"page@208d3e1db68ef3d6564c6188af16a787","startedDateTime":"2026-05-22T16:51:11.414Z","time":87.832,"request":{"method":"GET","url":"https://static.gst.gov.in/uiassets/css/fonts/minified/FontAwesome.wof