L}}/registration/auth/geocode\">\r\n                                        Geocoding Business Addresses</a>\r\n                                </li>\r\n                                <!-----cr 24843 ends-------->\r\n                                <li\r\n                                    data-ng-hide=\"udata && (udata.utype=='NR' || udata.utype=='TD' || udata.utype=='TS' || udata.utype=='O' || udata.utype=='UN')\">\r\n                                    <a\r\n                                        data-ng-href=\"{{servers.GST_REGISTRATION_R1_URL}}/registration/auth/amend/noncore/business\">Amendment\r\n                                        of Registration Non - Core Fields</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-show=\"udata && udata.role == 'login' && (udata.utype=='NR' || udata.utype=='TD' || udata.utype=='TS' || udata.utype=='O')\">\r\n                                    <a\r\n                                        data-ng-href=\"{{servers.GST_REGISTRATION_R1_URL}}/registration/auth/comnamend/noncore/basicdtls\">Amendment\r\n                                        of Registration Non - Core Fields</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && udata.role == 'login' && udata.utype=='UN'\">\r\n                                    <a\r\n                                        data-ng-href=\"{{servers.GST_REGISTRATION_R1_URL}}/registration/auth/amend/uin/noncore/authsign\">Amendment\r\n                                        of Registration Non - Core Fields</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && udata.role == 'login'\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/appstatus\">Track\r\n                                        Application Status</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' ) && udata.IS_MIGRATED == 'Y' && udata.sumotoCanStatus == 'SC' && udata.jkmig != 'Y' && udata.utype!='TR' && udata.utype!='UN' && udata.utype!='TC'\">\r\n                                    <a data-ng-href=\"{{servers.GST_REGISTRATION_R1_URL}}/registration/auth/revoke\">Application\r\n                                        for Revocation of Cancelled Registration</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-show=\"udata && (udata.role == 'login'  || udata.role == 'panLogin') && udata.IS_MIGRATED == 'N' && udata.utype!='TR' && udata.sumotoCanStatus == 'SC' && udata.jkmig != 'Y' && udata.utype!='UN' && udata.utype!='TC'\">\r\n                                    <a data-ng-href=\"{{servers.GST_REGISTRATION_R1_URL}}/registration/auth/revoke\">Application\r\n                                        for Revocation of Cancelled Registration</a>\r\n                                </li>\r\n                                <!--CR 29179A Changes Start-->\r\n                                <li data-ng-show=\"udata && udata.role == 'panLogin' && validSP\">\r\n                                    <a\r\n                                        data-ng-href=\"{{servers.GST_REGISTRATION_R1_URL}}/registration/auth/specifiedpremises\">Declaration\r\n                                        for Specified Premises</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-show=\"udata && udata.role == 'login' && (udata.utype =='TP' || udata.utype =='NT') && (!udata.regType || udata.regType == 'TP' || udata.regType == 'NT') && !udata.sezFlag\">\r\n                                    <a\r\n                                        data-ng-href=\"{{servers.GST_REGISTRATION_R1_URL}}/registration/auth/specifiedpremises\">Declaration\r\n                                        for Specified Premises</a>\r\n                                </li>\r\n                                <!--CR 29179A Changes End-->\r\n                            </ul>\r\n                        </li>\r\n                        <li class=\"has-sub\" data-ng-show=\"udata && udata.role == 'login'\">\r\n                            <a\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/quicklinks/ledgers\">Ledgers</a>\r\n                            <ul\r\n                                data-ng-class=\"{'isubmenu leg post': udata && udata.utype!='O' ,'isubmenu leg oidr': udata && udata.utype=='O'}\">\r\n                                <li>\r\n                                    <a data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/ledger/cashledger\">Electronic\r\n                                        Cash Ledger</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-if=\"udata && (udata.utype== 'NRCN'|| udata.regType== 'TP' || udata.utype== 'NR' || udata.regType== 'CO' || udata.regType== 'NT' || udata.regType== 'TPCO' || udata.regType== 'TPCOCN' || udata.regType== 'TPNTCN')\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/ledger/itcledger\">Electronic\r\n                                        Credit Ledger</a>\r\n                                </li>\r\n                                <li>\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/ledger/taxledger\">Electronic\r\n                                        Liability Register</a>\r\n                                </li>\r\n                                <li data-ng-hide=\"udata.utype == 'TC'\">\r\n                                    <a\r\n                                        data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/ledger/paymenttowardsdemand\">Payment\r\n                                        towards Demand</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-if=\"udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP')\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_STATEMENTS_R1_URL}}/ledgersw/auth/ledgers/negliab\">Negative\r\n                                        liability statement - Composition Taxpayers</a>\r\n                                </li>\r\n\r\n                                <!-- CR21773C -->\r\n                                <li>\r\n                                    <a href=\"{{servers.GST_STATEMENTS_R1_URL}}/ledgersw/auth/ledgers/negliabreg\">Negative\r\n                                        liability statement - Regular Taxpayers</a>\r\n                                </li>\r\n                                <!--CR-21773B : Addition of Electronic Credit Reversal and Re-claimed statement navigation link-->\r\n                                <li\r\n                                    data-ng-if=\"(udata.appStatus=='A' || udata.appStatus =='C') && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'TP' || udata.regType == 'CO' || !!udata.sezFlag)\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/ledger/revreclaimstmt\">Electronic\r\n                                        Credit Reversal and Re-claimed Statement</a>\r\n                                </li>\r\n                                <!--CR26198-->\r\n                                <li\r\n                                    data-ng-if=\"(udata.appStatus=='A' || udata.appStatus =='C') && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'TP' || udata.regType == 'CO' || !!udata.sezFlag)\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/ledger/rcmliabldg\">RCM\r\n                                        Liability/ITC Statement</a>\r\n                                </li>\r\n\r\n\r\n                            </ul>\r\n                        </li>\r\n                        <li class=\"has-sub\" data-ng-show=\"udata && udata.role == 'login'\">\r\n                            <a\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/quicklinks/returns\">Returns</a>\r\n                            <ul data-ng-class=\"{'isubmenu ret post': udata && udata.utype!='O' && udata.utype!='UN' ,'isubmenu ret  oidr': udata && udata.utype=='O','isubmenu serv': udata && udata.utype=='UN'}\"\r\n                                data-ng-hide=\"udata.utype=='TR'\">\r\n                                <li>\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/dashboard\">Returns\r\n                                        Dashboard</a>\r\n\r\n                                <li>\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/efiledReturns\">View\r\n                                        Filed Returns</a>\r\n                                </li>\r\n                                <li>\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/trackreturnstatus\">Track\r\n                                        Return Status</a>\r\n                                </li>\r\n                                <li data-ng-if=\"udata.utype !== 'CO' && udata.utype !== 'TS'\">\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/transition/trans1\"\r\n                                        target=\"_self\">Transition Forms</a>\r\n                                </li>\r\n                                <!-- commenting as it is not mentioned in fo-matrix and a defect is raised on Suomoto cancellation filing clarifications-->\r\n\r\n                                <li data-ng-hide=\"udata.utype=='UN'\">\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/itcform/links\">ITC\r\n                                        Forms</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-show=\"(udata.utype=='TP' || udata.utype=='NT' || udata.regType=='CA')&& udata.regType!='CO' && udata.regType!='ID' && udatasp.appStatus!='SP' \">\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/finalreturn\">Final\r\n                                        Return</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-if=\"udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CO'  || udata.regType == 'TP')\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/annualreturn\">Annual\r\n                                        Return</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-if=\"(udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP')) || (udata.utype == 'TPCAEX' && udata.regType == 'CA') || (udata.utype == 'O')\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/comptds\">TDS and TCS\r\n                                        credit received </a>\r\n                                </li>\r\n                                <!--Comparison report CR 17153 - adding the link to landing page changes begin-->\r\n                                <li\r\n                                    data-ng-if=\"udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP')\">\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/comparison\">Tax\r\n                                        liabilities and ITC comparison</a>\r\n                                </li>\r\n                                <!--Comparison report CR 17153 - adding the link to landing page changes end-->\r\n                                <!--Optin for Quarterly Return link CR- 18145-->\r\n                                <li data-ng-if=\"udata.regType=='NT' || udata.regType=='TP'  || udata.regType =='CO'\">\r\n                                    <a data-ng-click=\"manageProfile()\">Opt-in for Quarterly Return</a>\r\n                                </li>\r\n                                <!--Optin for Quarterly Return link CR- 18145 End-->\r\n                                <!-- CR-23810 Liability Mismatch Starts -->\r\n                                <li\r\n                                    data-ng-if=\"udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP' || udata.sezFlag\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/returnComp\">Return\r\n                                        Compliance</a>\r\n                                </li>\r\n\r\n                                <!-- CR 25787 IMS Dashboard-->\r\n                                <li\r\n                                    data-ng-if=\"udata && udata.role == 'login' && (udata.utype == 'TP' || udata.utype == 'TPCAEX') && imsLinkEnable && (udata.regType == 'NT' ||  udata.regType=='CA'|| udata.regType == 'CO' || udata.regType=='TP' || udata.sezFlag)\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/imsweb/auth/imsDashboard\">Invoice\r\n                                        Management System (IMS) Dashboard</a>\r\n                                </li>\r\n                                <!-- CR 25787 IMS Dashboard-->\r\n\r\n                                <!-- CR 26286 Application for Unbarring Returns starts -->\r\n                                <li data-ng-if=\"udata && udata.role == 'login'\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/unbarringreturns/alreadyraisedreq\">Application\r\n                                        for Unbarring Returns</a>\r\n                                </li>\r\n                                <!-- CR 26286 Application for Unbarring Returns ends  -->\r\n\r\n                                <!-- CR-23810 Liability Mismatch End -->\r\n                                <!-- DO NOT REMOVE THIS CODE - CR 25786 Credit Limit Check for High Risk Taxpayer Starts -->\r\n                                <!-- <li\r\n                                data-ng-if=\"udata && udata.role == 'login' && udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP' || udata.sezFlag)\">\r\n                                    <a target=\"_self\" data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/increasingcreditlimit/alreadyraisedreq\">Application for increasing credit limit</a>\r\n                                </li> -->\r\n                                <!-- DO NOT REMOVE THIS CODE - CR 25786 Credit Limit Check for High Risk Taxpayer Ends  -->\r\n                                <!-- CR26009 Changes -->\r\n                                <li data-toggle=\"tooltip\"\r\n                                    title=\"Only manufacturer of pan masala/tobacco products allowed to file.\"\r\n                                    data-ng-if=\"udata && udata.role == 'login' && udata.isManufacturer == 'Y' && (udata.appStatus == 'C' || udata.appStatus == 'A') && udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'TP')\">\r\n                                    <a target=\"_self\"\r\n                                        data-ng-href=\"{{servers.GST_SRM_R1_URL}}/srmweb/auth/srmsearch\">SRM Forms (Pan\r\n                                        Masala/Tobacco)</a>\r\n                                </li>\r\n                            </ul>\r\n                        </li>\r\n                        <li class=\"has-sub\">\r\n                            <a data-ng-show=\"(udata && udata.role == 'panLogin')\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/quicklinks/payments/trn\">Payments</a>\r\n                            <a data-ng-show=\"!udata\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/quicklinks/payments\">Payments</a>\r\n                            <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/quicklinks/payments\">Payments</a>\r\n                            <ul class=\"isubmenu pay\"\r\n                                data-ng-class=\"{'post': udata && udata.role == 'login'  && udata.utype!='O' && udata.utype!='UN', 'pan': udata && udata.role == 'panLogin', 'oidr': udata && udata.utype=='O', 'isubmenu pay postuinpay': udata && udata.utype=='UN'}\">\r\n                                <li>\r\n                                    <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                        data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/\">Create Challan</a>\r\n                                </li>\r\n                                <li>\r\n                                    <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                        data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/challanhistory\">Challan\r\n                                        History</a>\r\n                                </li>\r\n                                <li>\r\n                                    <a data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/trackpayment\">Track Payment\r\n                                        Status</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && udata.role == 'login'\">\r\n                                    <a\r\n                                        data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/litserv/auth/deferred/instalmentpayment\">Application\r\n                                        for Deferred Payment/Payment in Instalments</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && udata.role == 'login'\">\r\n                                    <a\r\n                                        data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/ledger/instalmentcalendar\">Instalment\r\n                                        Calendar</a>\r\n                                </li>\r\n                                <li>\r\n                                    <a data-ng-show=\"!udata\"\r\n                                        data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/grievance\">Grievance\r\n                                        against Payment(GST PMT-07)</a>\r\n                                    <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                        data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/grievance\">Grievance\r\n                                        against Payment(GST PMT-07)</a>\r\n                                </li>\r\n                            </ul>\r\n\r\n                        </li>\r\n\r\n                        <li class=\"has-sub\">\r\n                            <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/quicklinks/userservices\">User\r\n                                Services</a>\r\n                            <ul class=\"isubmenu services\"\r\n                                data-ng-class=\"{'services': !udata,'oth': udata && udata.role == 'login' && udata.utype != 'UN','isubmenu services post': (udata && udata.role == 'panLogin' || udata && udata.role == 'login' && udata.utype == 'O'),'isubmenu pay postuin': (udata  && udata.utype == 'UN'),'isubmenu us rf': (udata  && udata.utype == 'RF')}\">\r\n                                <li\r\n                                    data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin') && udata.utype!='TR'\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/savedapp\">My Saved\r\n                                        Applications</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' ) && udata.utype!='ES'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/litserv/auth/drc03register\"\r\n                                        data-ng-class=\"{'disabledanchor' : udata.disableMenu}\">DRC-03 Register</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' )\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/litserv/auth/case/search\">My\r\n                                        Applications</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login')\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/certs\">View/Download\r\n                                        Certificates</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin')\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/notices\">View Notices\r\n                                        and Orders</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' || udata.utype=='O' || udata.utype == 'UN') \">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/notices\">View\r\n                                        Additional Notices/Orders</a>\r\n                                </li>\r\n                                <li\r\n                                    data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin') && udata.utype!='TR'\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/submissions\">View My\r\n                                        Submissions</a>\r\n                                </li>\r\n                                <!-- <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin')\">\r\n                                    <a data-ng-hr