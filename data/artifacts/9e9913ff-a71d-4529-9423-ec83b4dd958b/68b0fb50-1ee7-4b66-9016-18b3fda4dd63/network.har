          NewPassword: $scope.data.password,\r\n            confirmPassword: $scope.data.repassword,\r\n\t\t\tmessage:shareData.msg\r\n        };\r\n\r\n        var userDetails = JSON.stringify(details);\r\n        ajax.post(\"/services/resetpwd\", userDetails, function () {\r\n            $().blockPage(true);\r\n        }, function () {\r\n            $().blockPage(false);\r\n        }).then(function (response) {\r\n\r\n            if (response.successCode === \"SWEB_9019\") {\r\n                $scope.oneClick = false;\r\n                $scope.GenOtp = false;\r\n                $scope.Userdet = false;\r\n                $scope.question = false;\r\n                $scope.forgotpasswor = false;\r\n                $scope.frtpass = false;\r\n                $scope.alertMsgLogin = false;\r\n                $('#alertMsg').removeClass('alert-danger');\r\n                $('#alertMsg').addClass('alert-success');\r\n                $('#alertMsg').removeClass('err');\r\n                $window.scrollTo(0, 0);\r\n                $scope.fp_success = \"SWEB_9019\";\r\n                shareData.successCode = \"SWEB_9019\";\r\n                $location.path('/login');\r\n            } else if (response.errorCode === \"SWEB_9011\") {\r\n                $scope.alertMsgLogin = false;\r\n                $scope.oneClick = false;\r\n                $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                $window.scrollTo(0, 0);\r\n            } else if (response.errorCode === \"SWEB_8000\") {\r\n                $scope.alertMsgLogin = false;\r\n                $scope.oneClick = false;\r\n                $('#fo-pwd').focus();\r\n                $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                $window.scrollTo(0, 0);\r\n            } else if (response.errorCode === \"SWEB_9017\") {\r\n                $scope.alertMsgLogin = false;\r\n                $scope.oneClick = false;\r\n                $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                $window.scrollTo(0, 0);\r\n            } else if (response.errorCode === \"SWEB_9029\") {\r\n                $scope.alertMsgLogin = false;\r\n                $scope.oneClick = false;\r\n                $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                $window.scrollTo(0, 0);\r\n            } else if (response.errorCode === \"SWEB_9027\") {\r\n                $scope.forgotpass_3.$setPristine();\r\n                delete $scope.data.password\r\n                delete $scope.data.repassword;\r\n                $scope.alertMsgLogin = false;\r\n                $scope.oneClick = false;\r\n                $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                $window.scrollTo(0, 0);\r\n            }else if (response.errorCode === \"SWEB_9003\") {\r\n                $scope.forgotpass_3.$setPristine();\r\n                delete $scope.data.password\r\n                delete $scope.data.repassword;\r\n                $scope.alertMsgLogin = false;\r\n                $scope.oneClick = false;\r\n                $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                $window.scrollTo(0, 0);\r\n            }\r\n\r\n        }, function (response) {\r\n\r\n        });\r\n\r\n\r\n    };\r\n\r\n    //forgotpass new pass\r\n    $scope.secProceed1 = function () {\r\n        $scope.oneClick = true;\r\n        $scope.oneClick1 = true;\r\n        $scope.oneClick2 = false;\r\n\r\n        if ($scope.forgotpass_3.pwd.$valid && $scope.forgotpass_3.repwd.$valid) {\r\n\r\n            if ($scope.data.password === $scope.data.repassword) {\r\n                if ($scope.forgotpass_3.$setPristine) {\r\n                    $scope.forgotpass_3.$setPristine();\r\n                    $scope.forgotpass_3.$submitted = false;\r\n\r\n                    $scope.oneClick = true;\r\n                    $scope.oneClick1 = true;\r\n                    $scope.oneClick2 = false;\r\n                    $scope.GenOtp = false;\r\n                    $scope.question = true;\r\n                    $scope.alertMsgLogin = true;\r\n                    $('#newc').show();\r\n                    $('#newc1').hide();\r\n                    $('#city').focus();\r\n                    $scope.savePass();\r\n                }\r\n\r\n            }\r\n\r\n\r\n        } else {\r\n            $scope.alertMsgLogin = true;\r\n            $('#fo-pwd').focus();\r\n\r\n        }\r\n\r\n\r\n    };\r\n\r\n\r\n}\r\n"},"headersSize":1329,"bodySize":5180,"redirectURL":"","_transferSize":6509},"cache":{},"timings":{"dns":-1,"connect":-1,"ssl":-1,"send":0,"wait":17.289,"receive":1.661},"serverIPAddress":"23.222.248.33","_serverPort":443,"_securityDetails":{"protocol":"TLS 1.2","subjectName":"*.gst.gov.in","issuer":"DigiCert Global G3 TLS ECC SHA384 2020 CA1","validFrom":1778198400,"validTo":1795391999}},{"pageref":"page@208d3e1db68ef3d6564c6188af16a787","startedDateTime":"2026-05-22T16:51:10.787Z","time":20.513,"request":{"method":"GET","url":"https://static.gst.gov.in/uiassets/js/services/createuserCtrl1.0.js","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Accept","value":"*/*"},{"name":"Accept-Encoding","value":"gzip, deflate, br, zstd"},{"name":"Accept-Language","value":"en-IN"},{"name":"Connection","value":"keep-alive"},{"name":"Host","value":"static.gst.gov.in"},{"name":"Referer","value":"https://services.gst.gov.in/"},{"name":"Sec-Fetch-Dest","value":"script"},{"name":"Sec-Fetch-Mode","value":"no-cors"},{"name":"Sec-Fetch-Site","value":"same-site"},{"name":"User-Agent","value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/148.0.7778.96 Safari/537.36"},{"name":"sec-ch-ua","value":"\"Chromium\";v=\"148\", \"HeadlessChrome\";v=\"148\", \"Not/A)Brand\";v=\"99\""},{"name":"sec-ch-ua-mobile","value":"?0"},{"name":"sec-ch-ua-platform","value":"\"Windows\""}],"queryString":[],"headersSize":569,"bodySize":0},"response