     up: \"fa fa-arrow-up\",\n\t\t\t\t\tdown: \"fa fa-arrow-down\",\n\t\t\t\t\tnext: 'fa fa-angle-right',\n\t\t\t\t\tprevious: 'fa fa-angle-left'\n\t\t\t\t},\n\t\t\t\tminDate:moment().subtract(scope.minDays, 'days').millisecond(0).second(0).minute(0).hour(0),\n  \t\t\t\tmaxDate:moment().add(scope.maxDays, 'days').second(59).minute(59).hour(23)\n\t\t\t});\n\t\t\telement.on(\"paste\", function (e) {\n\t\t\t\te.preventDefault();\n\t\t\t})\n\t\t\telement.on('dp.change', function(event) {\n                scope.$apply(function() {\n                    ctrl.$setViewValue($(event.target).val());\n                });\n            });\n\t\t\telement.on('blur', function (event) {\n                scope.$apply(function () {\n                    ctrl.$setViewValue($(event.target).val());\n                });\n            });\n\t\t}\n\t};\n});\nmyApp.directive('attachStak', ['ajax', '$compile', '$timeout', 'utilFunctions', '$filter', 'FormSubmitter', function(ajax, $compile, $timeout, utilFunctions, $filter, FormSubmitter) {\n\n    function link(scope, elem, attrs) {\n        scope.submit = function() {\n            if (scope.submitCk()) {\n                //checking form completion\n                scope.callStak();\n            }\n        };\n        // scope.stakDisableMsg = \"To file using STAK, Register on STAK APP mobile application and activate it from my profile section on GST Portal\";\n        //changing button label\n        if (scope.formvalue) {\n            scope.stakBtnValue = \"File with Stak\";\n        } else {\n            scope.stakBtnValue = \"File with Stak\";\n        }\n\n        scope.setErr = function(msg, type) {\n            switch (type) {\n                case \"error\":\n                    scope.errtype = \"danger\";\n                    break;\n                case \"warning\":\n                    scope.errtype = \"warning\";\n                    break;\n                case \"success\":\n                    scope.errtype = \"success\";\n                    break;\n            }\n            if (msg == \"\") {\n                delete scope.err;\n            } else {\n                scope.err = msg;\n            }\n        };\n        scope.validateStak = true;\n        scope.checktOtp = function(){\n\n            if(scope.totp.length == '6'){\n            scope.validateStak = false;\n            }\n            else {\n                scope.validateStak = true;\n            }\n        }\n        scope.verifyStak = function() {\n            if (!scope.totp || scope.totp == '') {\n                scope.setErr(\"Please enter OTP\", 'error');\n                return;\n            } \n            else if (!/^\\d*\\.?\\d*$/.test(scope.totp)) {\n                scope.setErr(\"Invalid OTP entered\", 'error');\n                return;\n            } \n            else {\n                scope.setErr(\"\");\n            }\n\n            ajax.post(scope.signUrl, {\n                    \"tOtp\": scope.totp,\n                    \"returnType\": scope.formType,\n                    \"pan\": scope.pan,\n                    \"deviceId\": scope.deviceid,\n                    \"mobileNum\": scope.mobileno,\n                    \"uuid\": scope.uuid,\n                    \"gstin\": scope.gstin\n                    \n                }, {}, function() {\n                    scope.setErr(\"Please wait, validating OTP..\", 'warning');\n                    }).then(function(resp) {\n                    if (resp.status_cd == \"0\") {\n\t\t\t\t\t\tif(resp.error.error_cd == \"STAK_ER_12\"){\n\t\t\t\t\t\t\tscope.setErr('The STAK you have entered is incorrect or expired. ' + resp.error.message + ' You shall be blocked for the day thereafter.', 'error');\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse if(resp.error.error_cd == \"1001\"){\n\t\t\t\t\t\t\tscope.setErr('Internal Server Error.', 'error');\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse if(resp.error.error_cd == \"1002\" || resp.error.error_cd == \"STAK_ER_1009\"){\n\t\t\t\t\t\t\tscope.setErr('This mobile number is not activated for STAK. Kindly activate it from My Profile section in GST Portal.', 'error');\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse if(resp.error.error_cd == \"1004\"){\n\t\t\t\t\t\t\tscope.setErr('This mobile number is not activated for STAK. Kindly activate it from My Profile section in GST Portal.', 'error');\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse if(resp.error.error_cd == \"1005\"){\n\t\t\t\t\t\t\tscope.setErr('The device id has been changed. Please deactivate the existing device and activate AS again to refresh the latest device id.', 'error');\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse if(resp.error.error_cd == \"1010\"){\n\t\t\t\t\t\t\tscope.setErr('Due to 5 incorrect attempts, you have been blocked to use the STAK verification for the day. Kindly use EVC/ DSC for verification.', 'error');\n\t\t\t\t\t\t\tscope.validateStak = true;\n\t\t\t\t\t\t}\n\t\t\t\t\t\telse{\n\t\t\t\t\t\t\tscope.reset();\n\t\t\t\t\t\t\tscope.setErr(\"Unable to submit form. Please try again.\", 'error');\n\t\t\t\t\t\t}\n                       \n                    } \n\t\t\t\t\t// else if (resp.stscd == \"1\" || resp.stscd == \"SUCCESS\") {\n                    //     scope.reset();\n                    //     scope.callBack({\n                    //         'data': resp\n                    //     });\n                    // } \n\t\t\t\t\telse {\n                        scope.reset();\n                        //resp = { errorCd: \"DSCEVC502\", stscd: \"0\", message: \"Your OTP is expired please try again\" };\n                        scope.callBack({\n                            'data': resp\n                        });\n                    }\n                }, function() {\n                    scope.reset();\n                    scope.setErr(\"Unable to submit form. Please try again.\", 'error');\n                })\n            };\n\n     scope.reset = function() {\n            scope.totp = \"\";\n            $(\"#otpPrompt1\").modal('hide');\n            $(\".modal-backdrop\").remove();\n        };\n\n        $(\"#otpinput1\").keypress(function(e){\n            e.stopPropagation();\n            });\n            $(\"#otpinput1\").keydown(function(e){\n            e.stopPropagation();\n            });\n            \n        scope.callStak = function() {\n            scope.validateStak = true;\n            if (scope.deviceid) {\n                scope.deviceID = scope.deviceid.substr(0, 2) + utilFunctions.maskString(scope.deviceid.substr(2, scope.deviceid.length-2), 'prepend') + scope.deviceid.substr(scope.deviceid.length-2, scope.deviceid.length);\n            }\n            if (scope.mobileno) {\n                scope.mobile = scope.mobileno.substr(0, 2) + utilFunctions.maskString(scope.mobileno.substr(2, 6), 'prepend') + scope.mobileno.substr(8, 10);\n            }\n            $timeout(function() {\n                $(\"#otpinput1\").focus();\n            }, 400);\n            $(\"#otpPrompt1\").modal({\n                show: true,\n                backdrop: 'static'\n            });\n\t\t\tif(scope.deviceid == \"undefined\" || scope.deviceid == \"null\" || scope.mobileno == \"undefined\" || scope.mobileno == \"null\"){\n\t\t\t\t\n\t\t\t}\n\n\t\t\telse {\n            scope.setErr(\"Enter the six-digit STAK key available on your STAK mobile application installed on device id \" + scope.deviceID + \" with mobile number \" + scope.mobile + \".\", 'success');\n\t\t\t}\n        };\n\n        \n    }\n    return {\n        restrict: 'A',\n        scope: {\n            \"signUrl\": \"@\",\n            \"rPayload\": \"@\",\n            \"callBack\": \"&\",\n            \"submitCk\": \"&\",\n            \"formType\": \"@\",\n            \"tranId\": \"@\",\n            \"username\": \"@\",\n            \"mobileno\": \"@\",\n            \"stCode\": \"@\",\n            \"uuid\": \"@\",\n            \"userBlkStatus\": \"@\",\n            \"deviceid\": \"@\",\n            \"formvalue\": \"@\",\n            \"pan\": \"@\",\n            \"gstin\": \"@\",\n            \"disablestak\": \"@\",\n           \"captchaValue\": \"=\",\n\t\t   \"hovermsg\": \"@\"\n           \n        },\n        compile: function(tElement) {\n            return link;\n        },\n\n        template: function(ele, attrs, scope) {\n            return \"<button type='button' title = \\\"{{disablestak == 'true' ? hovermsg : ''}}\\\" data-ng-disabled = \\\"disablestak == 'true'\\\" class='btn btn-primary' data-ng-click='submit()'>{{stakBtnValue}}</button><div id='otpPrompt1' class='modal fade text-left' role='dialog'><div class='modal-dialog'><div class='modal-content'><div class='modal-header'><h4 class='modal-title'>STAK Verification</h4></div><div class='modal-body'><div class='alert alert-{{errtype}} rowtp-mar' data-ng-if='err'><p data-ng-bind='err'></p></div><label class='reg m-cir'>Enter STAK</label><form novalidate><input type='password' name='totp' id='otpinput1' class='form-control upper-input' data-capitalize='' data-ng-model='totp' maxlength='6' data-ng-change = 'checktOtp()' autofocus></form></div><div class='modal-footer'><button type='button' class='btn btn-default' data-ng-click='reset()'>Cancel</button><button type='button' data-ng-click='verifyStak()' data-ng-disabled = 'validateStak' class='btn btn-primary'>Validate STAK</button> </div><div class='row'style='padding: 15px;margin-top: -25px !important;' ><div class='col-sm-12 xs-12'></div></div></div></div></div>\";\n        }\n    };\n}]);"},"headersSize":1331,"bodySize":56936,"redirectURL":"","_transferSize":58267},"cache":{},"timings":{"dns":-1,"connect":-1,"ssl":-1,"send":0,"wait":47.793,"receive":8.547},"serverIPAddress":"23.222.248.33","_serverPort":443,"_securityDetails":{"protocol":"TLS 1.2","subjectName":"*.gst.gov.in","issuer":"DigiCert Global G3 TLS ECC SHA384 2020 CA1","validFrom":1778198400,"validTo":1795391999}},{"pageref":"page@208d3e1db68ef3d6564c6188af16a787","startedDateTime":"2026-05-22T16:51:10.738Z","time":24.048000000000002,"request":{"method":"GET","url":"https://static.g