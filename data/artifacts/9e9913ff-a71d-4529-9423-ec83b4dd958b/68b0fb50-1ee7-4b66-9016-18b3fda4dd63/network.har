dia-src 'self' blob: mediastream *.gst.gov.in *.youtube.com;; connect-src 'self' *.gst.gov.in *.youtube.com"},{"name":"Content-Type","value":"application/javascript"},{"name":"Date","value":"Fri, 22 May 2026 16:51:11 GMT"},{"name":"ETag","value":"\"69f83f34-90d7\""},{"name":"Expires","value":"Fri, 22 May 2026 20:46:13 GMT"},{"name":"Last-Modified","value":"Mon, 04 May 2026 06:39:48 GMT"},{"name":"Pragma","value":"public"},{"name":"Strict-Transport-Security","value":"max-age=31536000; includeSubDomains;"},{"name":"Vary","value":"Accept-Encoding"},{"name":"x-content-type-options","value":"nosniff"},{"name":"x-frame-options","value":"SAMEORIGIN"},{"name":"x-xss-protection","value":"1; mode=block"}],"content":{"size":37079,"mimeType":"application/javascript","compression":30610,"text":"/*jslint browser: true*/\r\n/*global $, jQuery, angular, myApp, fologinCtrl, $val*/\r\n\"use strict\";\r\nmyApp.controller(\"loginCtrl\", loginCtrl);\r\nmyApp.controller(\"menuCtrl\", menuCtrl);\r\nmyApp.controller(\"welcomeCtrl\", welcomeCtrl);\r\n\r\nmenuCtrl.$inject = ['$scope', '$http', 'cache', '$rootScope', 'shareData', '$location', 'ajax', '$route', 'version', '$window', '$log'];\r\n\r\nfunction menuCtrl($scope, $http, cache, $rootScope, shareData, $location, ajax, $route, version, $window, $log) {\r\n  \r\n    $scope.trackarn = [];\r\n    $scope.trackarn  =  shareData.trackarn;\r\n\r\n    $scope.servers = $().getServers();\r\n\r\n    $scope.callEditReg = function () {\r\n\r\n\r\n        window.location.href = $scope.servers[\"GST_REGISTRATION_URL\"] + \"/registration/auth/business-details\";\r\n    };\r\n\r\n\r\n    $scope.dashboard = function () {\r\n\r\n        window.location.href = '/services/auth/welcome';\r\n\r\n    };\r\n\r\n\r\n    $rootScope.buttonflag = false;\r\n    $rootScope.editflag = true;\r\n    $rootScope.editflag1 = true;\r\n    $rootScope.popupflag = false;\r\n\r\n    $scope.mysavedapp = function () {\r\n        ajax.get(\"/services/auth/mig/trackarn\").then(function (response) {\r\n            if (response.errorCode === \"SWEB_8000\") {\r\n                $rootScope.errorflag = true;\r\n                $rootScope.successflag = false;\r\n                $rootScope.errorMsg1 = \"System error occurred. Please try after sometime\";\r\n            } else if (response.errorCode === \"FO8006\") {\r\n                $rootScope.errorflag = true;\r\n                $rootScope.successflag = false;\r\n                $rootScope.errorMsg1 = \"No Record Found\";\r\n            } else {\r\n\r\n                if (response.sts === \"DFT\" || response.sts === \"VAE\") {\r\n                    $rootScope.editflag = false;\r\n                    $rootScope.editflag1 = false;\r\n                } else if (response.sts === \"PSG\") {\r\n                    $rootScope.editflag = false;\r\n                    $rootScope.editflag1 = true;\r\n                }\r\n\r\n                $rootScope.successflag = true;\r\n                $rootScope.errorflag = false;\r\n                $scope.trackarn = angular.copy(response);\r\n                $rootScope.trackarn = angular.copy(response);\r\n                if ($rootScope.trackarn.sts === \"MIG\") {\r\n                    $rootScope.buttonflag = true;\r\n                }\r\n                //sharedData.set($scope.trackarn);\r\n                \r\n                shareData.trackarn = $scope.trackarn;\r\n\t\t\t\t\r\n\t\t\tajax.get(\"/master/applnt/\" + response.frmdc).then(function(response1) {\r\n              $scope.applntfrmdc = response1.data[0].n;\r\n\t\t\t\t   }, function(err) {\r\n            $scope.errors = \"HTTP \" + err.code + \": \" + err.msg;\r\n                 });\r\n            }\r\n\r\n        });\r\n        $location.path(\"/auth/mig/dashboard\");\r\n    };\r\n\r\n\r\n\r\n$scope.toggle = false;\r\n    $scope.download = function () {\r\n\t\r\n        ajax.get(\"/services/auth/formdownload\").then(function (response) {\r\n            if (!angular.isUndefined(response.sts)) {\r\n              $scope.toggle = true;\r\n                if (response.sts === \"FO8006\") {\r\n\t\t\t\t    $scope.dwnldMsg = \"Request for form download is submitted\";\r\n                    $rootScope.popupflag = true;\r\n                } else if (response.sts === \"FO8007\") {\r\n\t\t\t        $scope.dwnldMsg = \"Form generation for download is under process, please try after some time\";\r\n                    $rootScope.popupflag = true;\r\n                } else if (response.sts === \"FO8008\") {\r\n                    $scope.dwnldMsg = \"Form Download Request Failed\";\r\n                    $rootScope.popupflag = true;\r\n                }\r\n            } else if (!angular.isUndefined(response.url)) {\r\n\t\t\t$scope.toggle = false;\r\n\r\n\t\t        var url = \"/document/dir/\" + response.url;\r\n\t\t\t\r\n                location.href = url;\r\n\r\n            }\r\n\r\n        });\r\n\r\n    };\r\n\r\n\r\n\r\n    $scope.downloadPdf = function () {\r\n        ajax.get(\"/services/auth/ackdwnld\").then(function (response) {\r\n\r\n            var frmDesc1 = \"\";\r\n            ajax.get(\"/master/applnt/\" + response.frmDesc).then(function(response1) {\r\n\t\t\t\r\n             var sts = \"\";\r\n            if (response.status === \"DFT\") {\r\n                sts = \"Draft\";\r\n            } else if (response.status === \"PFV\") {\r\n                sts = \"Submitted and Pending for verification\";\r\n            } else if (response.status === \"MIG\") {\r\n                sts = \"Migrated\";\r\n            } else if (response.status === \"VAE\") {\r\n                sts = \"Validation Error\";\r\n            } else if (response.status === \"PSG\") {\r\n                sts = \"Pending Signature\";\r\n            } else if (response.status === \"PSB\") {\r\n                sts = \"Pending for Submission\";\r\n            } else if (response.status === \"SUB\") {\r\n                sts = \"Submitted\";\r\n            } else if (response.status === \"APR\") {\r\n                sts = \"Approved\";\r\n            } else if (response.status === \"RJT\") {\r\n                sts = \"Rejected\";\r\n            } else if (response.status === \"DEL\") {\r\n                sts = \"Deleted\";\r\n            }\r\n           \r\n        \r\n\r\n            var docDefinition = {\r\n                // a string or { width: number, height: number }\r\n                pageSize: 'A4',\r\n\r\n                // by default we use portrait, you can change it to landscape if you wish\r\n                pageOrientation: 'landscape',\r\n\r\n                // [left, top, right, bottom] or [horizontal, vertical] or just a number for equal margins\r\n                pageMargins: [25, 60, 25, 60],\r\n                content: [{table: {widths: ['*'],\r\n                            body: [[{text: [{text: '\\t\\tAcknowledgment\\n\\n',\r\n                                            style: 'header'\r\n                                        }, {text: '\\t\\tForm GST- \"Application for Enrolment of Existing Tax Payer\" has been filed against Application Reference Number (ARN) \\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t' + response.arn + '.\\n\\n',\r\n                                            style: 'appform'\r\n                                        }, {text: '\\t\\tForm Description \\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t:\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t',\r\n                                            style: 'acknowledgmentName'\r\n                                        }, {text: response1.data[0].n + '\\n\\n',\r\n                                            style: 'acknowledgmentValue'\r\n                                        }, {text: '\\t\\tDate of Filing      \\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t:\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t',\r\n                                            style: 'acknowledgmentName'\r\n                                        }, {text: response.dateofFil + '\\n\\n',\r\n                                            style: 'acknowledgmentValue'\r\n                                        }, {text: '\\t\\tTaxpayer Trade Name\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t:\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t',\r\n                                            style: 'acknowledgmentName'\r\n                                        }, {text: response.tradeName + '\\n\\n',\r\n                                            style: 'acknowledgmentValue'\r\n                                        }, {text: '\\t\\tTaxpayer Legal Name \\t\\t\\t\\t\\t\\t\\t\\t\\t\\t:\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t',\r\n                                            style: 'acknowledgmentName'\r\n                                        }, {text: response.legalName + '\\n\\n',\r\n                                            style: 'acknowledgmentValue'\r\n                                        }, {text: '\\t\\tProvisional ID Number\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t:\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t\\t',\r\n                                            style: 'acknowledgmentName'\r\n                                        }, {text: response.gstnId + '\\n\\n',\r\n                                            style: 'acknowledgmentValue'\r\n                                        }]\r\n                                    }\r\n\r\n                                ]\r\n                            ]\r\n                        }\r\n                    },\r\n\r\n                   '\\n',\r\n\r\n\t\t\t\t\t{\r\n                        ul: [\r\n                            '\\t\\tIt is a system generated acknowledgement and does not require any signature.\\n\\n'\r\n                        ],\r\n                        style: 'disclaimer'\r\n                    }, /*{\r\n                        ol: [\r\n                            '\\t\\tThe Form is filed without signatures. Please attach Digital Signature or e-Sign and resubmit the Form. In absence of Signature, Final Registration Certificate will not be issued. GSTIN will not be activated.'\r\n                        ],\r\n                        style: 'disclaimer'\r\n                    }*/\r\n\r\n                ],\r\n                styles: {\r\n                    acknowledgmentName: {\r\n                        fontSize: 16,\r\n                        bold: true\r\n                    },\r\n                    acknowledgmentValue: {\r\n                        fontSize: 16\r\n                    },\r\n                    header: {\r\n                        alignment: 'left',\r\n                        bold: true,\r\n                        fontSize: 16\r\n                    },\r\n                    appform: {\r\n                        alignment: 'left',\r\n                        fontSize: 14\r\n                    },\r\n                    disclaimer: {\r\n                        fontSize: 13,\r\n                        margin: [20, 0]\r\n                    }\r\n\r\n                }\r\n\r\n            };\r\n\r\n            pdfMake.createPdf(docDefinition).download(response.arn + \"_MIGFORM.pdf\");\r\n\r\n        });\r\n\t\t\r\n\t\t\t\t   }, function(err) {\r\n            $scope.errors = \"HTTP \" + err.code + \": \" + err.msg;\r\n                 });\r\n    };\r\n}\r\n\r\nloginCtrl.$inject = ['$scope', 'cache', '$rootScope', 'shareData', '$location', 'ajax', '$route', '$window', '$timeout', '$templateCache', '$log', 'utilFunctions', 'validations', '$compile', '$sce'];\r\n\r\n\r\nfunction loginCtrl($scope, cache, $rootScope, shareData, $location, ajax, $route, $window, $timeout, $templateCache, $log, utilFunctions, validations, $compile, $sce) {\r\n    /* init controller */\r\n     /*risk code to be added*/\r\n\r\n    $scope.initRBADetails = function () {\r\n        $scope.client = new ca.rm.Client();\r\n        var contextPath = $location.path();\r\n\r\n        $scope.client.setProperty(\"baseurl\", contextPath);\r\n        $scope.client.setProperty(\"format\", \"json\");\r\n        $scope.client.setProperty(\"didname\", \"RBA_COOKIE\"); ////response set\r\n        $scope.client.processDNA();\r\n\r\n    };\r\n    $scope.initRBADetails();\r\n /*risk code to be added*/\r\n    utilFunctions.initCache();\r\n    $scope.servers = $().getServers();\r\n    $scope.trans = utilFunctions.initLanguage('services');\r\n    $rootScope.$on(\"LangChanged\", function(event, mass) {\r\n        $scope.trans = utilFunctions.initLanguage('services');\r\n    });\r\n    $scope.$on('$viewContentLoaded', function() {\r\n        $window.scrollTo(0, 0);\r\n        angular.element(document.querySelector('[autofocus]')).focus();\r\n    });\r\n    /*init completed*/\r\n\r\n\r\n    $scope.focus = function(ele) {\r\n        $timeout(function() {\r\n            if (angular.element(ele)) {\r\n                angular.element(ele).focus();\r\n            }\r\n        });\r\n    };\r\n\r\n    setInterval(function() {\r\n\r\n        if (window.location.href.indexOf(\"/waiting\") > 0) {\r\n\r\n\r\n            ajax.get(\"/services/checksysavailability\").then(function(response) {\r\n\r\n                if (response.successCode === \"true\") {\r\n                    window.location.href = \"/services/login\";\r\n                } else {\r\n                    window.location.href = \"/services/waiting\";\r\n                }\r\n            });\r\n        }\r\n    }, 60000);\r\n\r\n    var successCode = shareData.successCode,\r\n        deps, dep;\r\n    $scope.consent = true;\r\n    $scope.validations = validations;\r\n    $scope.findUserType = function(username) {\r\n        if (username && username !== null && username !== undefined) {\r\n            if (username.charAt(0).match($scope.validations.formats.number) || username.match($scope.validations.formats.pan)) {\r\n                return \"uid\";\r\n            } else {\r\n                return \"username\";\r\n            }\r\n        }\r\n        return \"\";\r\n    };\r\n\r\n\r\n\r\n    $scope.getCData = function(item) {\r\n\r\n        if (cache.get(item).length > 0) {\r\n            $scope[item] = cache.get(item);\r\n        } else {\r\n            ajax.get($scope.resources[item]).then(function(response) {\r\n                $scope[item] = response.data;\r\n                cache.set(item, response.data);\r\n                delete $scope.errors[item];\r\n            }, function(err) {\r\n                $scope.errors[item] = err.msg;\r\n            });\r\n        }\r\n\r\n    };\r\n\r\n    if ($route.current) {\r\n        deps = $route.current.$$route.deps || [];\r\n        for (dep in deps) {\r\n            $scope[deps[dep]] = cache.get(deps[dep]) || [];\r\n            if ($scope[deps[dep]].length === 0) {\r\n                $scope.getCData(deps[dep]);\r\n            }\r\n        }\r\n    }\r\n    $scope.errors = {};\r\n    /* services code */\r\n    $scope.setPristine = function(form, ele, prop) {\r\n        $scope[form][ele].$setValidity(prop, true);\r\n    }\r\n\r\n    $scope.showLogin = function() {\r\n        $scope.consent = false;\r\n        $('#fo-user').focus();\r\n    }\r\n\r\n\r\n    //success message for fp and fu\r\n    $scope.alertMsgSuccess = true;\r\n\r\n    if (window.location.href.indexOf(\"/login?usrcr=1\") > 0) {\r\n        $scope.alertMsgSuccess = false;\r\n        $scope.successMsg = $scope.trans[\"SUCSS_USR_CR\"];\r\n    }\r\n\r\n    if (successCode === \"SWEB_9019\") {\r\n        $scope.alertMsgSuccess = false;\r\n        $scope.successMsg = $scope.trans[\"SUCSS_\" + successCode];\r\n    } else if (successCode === \"SWEB_9020\") {\r\n        $scope.alertMsgSuccess = false;\r\n        $scope.successMsg = $scope.trans[\"SUCSS_\" + successCode];\r\n    }\r\n\r\n    $scope.captchaObj = {\r\n\r\n    };\r\n\r\n    $scope.saveUserLogin = function() {\r\n\r\n        $scope.errors[\"login_error\"] = false;\r\n        $scope.client.processDNA();\r\n        $scope.alertMsgSuccess = true;\r\n        $scope.lform.mFP = $scope.client.getDNA();\r\n        $scope.lform.deviceID = $scope.client.getDID();\r\n        /*CR#21637 code changes start*/\r\n        if(localStorage.getItem(\"isPostPP\") != null){\r\n\t\t\tlocalStorage.removeItem(\"isPostPP\");\r\n\t\t}\r\n        /*CR#21637 code changes end*/\r\n        if ($scope.loginform.$valid) {\r\n            $scope.lform.type = \"username\";\r\n            ajax.post(\"/services/authenticate\", $scope.lform, {}, function() {\r\n                $().blockPage(true);\r\n            }, function() {\r\n                $().blockPage(false);\r\n            }).then(function(response) {\r\n                 if (response && response.url && response.message) {\r\n                    var rbaResponse = JSON.parse(response.message);\r\n                    shareData.loginDetails = response;\r\n                    switch (response.errorCode) {\r\n                    case 'RSK_1000':\r\n\r\n                        $scope.client.setDID(rbaResponse.deviceID);\r\n                        $location.path(\"/otpforauth\");\r\n                        break;\r\n                    case 'RSK_1001':\r\n                        // rbaResponse.ruleMatched\r\n                        window.location.href = \"/services/error/blocked?msgCd=\" + rbaResponse.ruleMatched;\r\n                        break;\r\n\r\n                        /* case 'RSK_1002':\r\n                             $location.path(\"/otpforauth\");\r\n                             break;*/\r\n                    default:\r\n                        window.location.href = \"/services/auth/\";\r\n\r\n                        break;\r\n                    }\r\n\r\n                    //$location.path(\"/otpforauth\");\r\n\r\n                } else if (response && response.message === \"auth\" && window.location.href.indexOf('src=PAY') > 0  && window.location.href.indexOf('next=OPTIN') > 0) {\r\n\t\t\t\t\t// request for login from PAYMENT module filing preference warning popup\r\n\t\t\t\t\t// instead of dashboard redirect to filing preference selection page \r\n                    window.location.href = $scope.servers[\"GST_RETURNS_R1_URL\"] + '/returns/auth/managertnprofile';\r\n                }else if (response && response.message === \"auth\" && window.location.href.indexOf('src=PAY') > 0  && window.location.href.indexOf('next=RETDASH') > 0) {\r\n\t\t\t\t\t// request for login from PAYMENT module filing preference warning popup\r\n\t\t\t\t\t// instead of dashboard redirect to filing preference selection page \r\n                    window.location.href = $scope.servers[\"GST_RETURNS_R1_URL\"] + '/returns/auth/dashboard';\r\n                }else if (response && response.message === \"auth\" && window.location.href.indexOf('einvoice') > 0) {\r\n\t\t\t\t\t// request for login from einvoice module\r\n\t\t\t\t\t// instead of dashboard redirect to einvoice dashboard page \r\n                    console.log(\" window.location.href.indexOf('einvoice') is : \", window.location.href.indexOf('einvoice'));\r\n                    window.location.href = $scope.servers[\"GST_EINVOICE_URL\"] + '/einvoice/dashboard';\r\n                } else if (response && response.message === \"auth\") {\r\n                    window.location.href = \"/services/auth/\";\r\n                } else if (response.errorCode === \"mobileapp\") {\r\n                    $window.location.href =\"/services/auth/uploadjson\";\r\n                } else if(response.errorCode === \"SWEB_2002\"){                   \r\n                    $window.location.href =\"/services/auth/restrictupload\";\r\n                } else if (response && response.message === null && response.successCode === null) {\r\n                    $window.location.href = $scope.servers[\"GST_PAYMENTS_R1_URL\"] + response.url;\r\n                } else {\r\n                    if (response && response.errorCode) {\r\n                        //$scope.newRegForm.bd_Ext_type.$setValidity(\"required\", false);\r\n                        $scope.captchaObj.refresh();\r\n                        delete $scope.lform.captcha;\r\n                        delete $scope.lform.password;\r\n                        $(\"#user_pass\").focus();\r\n\r\n                        switch (response.errorCode) {\r\n                            case \"SWEB_9006\":\r\n                                $location.path(\"/serverbusy\");\r\n                                break;\r\n                            case \"AUTH_9033\":\r\n                                //Password has expired.\r\n                                $window.location.href = \"/services/auth/changepassword\";\r\n                                break;\r\n\t\t\t\t\t\t\tcase \"AUTH_9033_MIG\":\r\n\t\t\t\t\t\t\t\t//Password has expired – R0 user.\r\n\t\t\t\t\t\t\t\t$window.location.href = \"/services/auth/mig/changepassword\";\r\n\t\t\t\t\t\t\t\tbreak;\r\n                            case \"SWEB_9000\":\r\n                                //Invalid captcha\r\n                                $scope.loginform.$setPristine();\r\n                                $scope.loginform.user_name.$setDirty();\r\n                                $scope.loginform.captcha.$setValidity(\"invalid_captcha\", false);\r\n                                break;\r\n                            case \"SWEB_9034\":\r\n                                //Invalid captcha\r\n                                $scope.loginform.$setPristine();\r\n                                $scope.loginform.user_name.$setDirty();\r\n                                $scope.errors[\"login_error\"] = true;\r\n                                $scope.errors[\"login_error_desc\"] = $scope.trans[\"ERR_\" + response.errorCode];\r\n                                break;\r\n\t\t\t\t\t\t\tcase \"SWEB_9036\":\r\n                                //Invalid R0 user\r\n                                $scope.loginform.$setPristine();\r\n                                $scope.loginform.user_name.$setDirty();\r\n                                $scope.errors[\"login_error\"] = true\r\n                                $scope.errors[\"login_error_desc\"] = $scope.trans[\"ERR_\" + response.errorCode];\r\n                                break;\r\n\t\t\t\t\t\t\t case \"SWEB_8001\":\r\n\t                                //User login using old username and password\r\n\t                                $scope.loginform.$setPristine();\r\n\t                                $scope.loginform.user_name.$setDirty();\r\n\t                                $scope.errors[\"login_error\"] = true;\r\n\t                                $scope.errors[\"login_error_desc\"] = $scope.trans[\"ERR_\" + response.errorCode];\r\n\t                                break; \r\n\t\t\t\t\t\t\t case \"SWEB_8002\":\r\n\t                                //redis issue encountered\r\n\t                                $scope.loginform.$setPristine();\r\n\t                                $scope.loginform.user_name.$setDirty();\r\n\t                                $scope.errors[\"login_error\"] = true;\r\n\t                                $scope.errors[\"login_error_desc\"] = $scope.trans[\"ERR_\" + response.errorCode];\r\n\t                                break; \r\n                            case \"AUTH_9002\":\r\n                            case \"SWEB_9014\":\r\n                            case \"SWEB_8000\":\r\n                            case \"false\":\r\n                            case false:\r\n                                //Invalid Username or Password\r\n                                //System error\t\r\n                                //wrong pass - 3 times - acc locked\r\n                                $scope.errors[\"login_error\"] = true;\r\n                                $scope.loginform.$setPristine();\r\n                                $scope.loginform.user_name.$setDirty();\r\n                                $scope.errors[\"login_error_desc\"] = $scope.trans[\"ERR_\" + response.errorCode];\r\n                                break;\r\n                        }\r\n           