c.gst.gov.in"},{"name":"Referer","value":"https://services.gst.gov.in/"},{"name":"Sec-Fetch-Dest","value":"script"},{"name":"Sec-Fetch-Mode","value":"no-cors"},{"name":"Sec-Fetch-Site","value":"same-site"},{"name":"User-Agent","value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/148.0.7778.96 Safari/537.36"},{"name":"sec-ch-ua","value":"\"Chromium\";v=\"148\", \"HeadlessChrome\";v=\"148\", \"Not/A)Brand\";v=\"99\""},{"name":"sec-ch-ua-mobile","value":"?0"},{"name":"sec-ch-ua-platform","value":"\"Windows\""}],"queryString":[],"headersSize":563,"bodySize":0},"response":{"status":200,"statusText":"OK","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Access-Control-Allow-Credentials","value":"true"},{"name":"Access-Control-Allow-Headers","value":"DNT,X-CustomHeader,Keep-Alive,User-Agent,X-Requested-With,If-Modified-Since,Cache-Control,Content-Type"},{"name":"Access-Control-Allow-Methods","value":"GET"},{"name":"Access-Control-Allow-Origin","value":"*"},{"name":"Cache-Control","value":"public, must-revalidate, proxy-revalidate, max-age=14102"},{"name":"Connection","value":"keep-alive"},{"name":"Content-Encoding","value":"gzip"},{"name":"Content-Length","value":"56936"},{"name":"Content-Security-Policy","value":"default-src 'self' *.gst.gov.in *.youtube.com; script-src 'self' 'unsafe-inline' 'unsafe-eval' *.gst.gov.in *.youtube.com seal.entrust.net; img-src 'self' *.gst.gov.in *.youtube.com data: blob: filesystem:; style-src 'self' 'unsafe-inline' *.gst.gov.in; font-src 'self' *.gst.gov.in; child-src 'self' *.gst.gov.in *.youtube.com; object-src 'self' *.gst.gov.in *.youtube.com; frame-src 'self' *.youtube.com; media-src 'self' blob: mediastream *.gst.gov.in *.youtube.com;; connect-src 'self' *.gst.gov.in *.youtube.com"},{"name":"Content-Type","value":"application/javascript"},{"name":"Date","value":"Fri, 22 May 2026 16:51:11 GMT"},{"name":"ETag","value":"\"69f83f35-43c9a\""},{"name":"Expires","value":"Fri, 22 May 2026 20:46:13 GMT"},{"name":"Last-Modified","value":"Mon, 04 May 2026 06:39:49 GMT"},{"name":"Pragma","value":"public"},{"name":"Strict-Transport-Security","value":"max-age=31536000; includeSubDomains;"},{"name":"Vary","value":"Accept-Encoding"},{"name":"x-content-type-options","value":"nosniff"},{"name":"x-frame-options","value":"SAMEORIGIN"},{"name":"x-xss-protection","value":"1; mode=block"}],"content":{"size":277658,"mimeType":"application/javascript","compression":220722,"text":"/*jslint browser: true, sloppy:true, nomen: true, node: true, bitwise: true, regexp: true*/\n/*global $, jQuery, angular, myApp, regex, transctrl, accessctrl, translationSrv, RouteProviderConfig, moment, WebSocket, Uint8Array, FileReader, MediaStreamTrack, console, getComputedStyle, FormData*/\n\n\"use strict\";\nif (!myApp) {\n\tvar myApp = angular.module(\"myApp\", ['ngRoute', 'LocalStorageModule', 'ngProgress']);\n\tvar RouteProviderConfig = function ($routeProvider, $locationProvider) {\n\n\t}\n}\nmyApp.controller(\"alertCtrl\", [\"$scope\", \"$rootScope\", \"$timeout\", \"NgTableParams\", \"ajax\", \"$window\", \"ngTableEventsChannel\", function ($scope, $rootScope, $timeout, NgTableParams, ajax, $window, ngTableEventsChannel) {\n\t\n\t$scope.alert = {}; \n\t$scope.onLoad = function () {\n\t\tajax.post(\"/services2/auth/web/alerts/count\",{}).then(function (response) {\n\t\t\tif (response) {\n\t\t\t\t$scope.alert.info = response;\n\t\t\t}\n\t\t});\n\t};\n\n\t$scope.markAsRead = function(alertID) {\n\n\t\t$scope.request = {};\n\t\t$scope.array = [];\n\t\t$scope.array.push(alertID);\n\t\t$scope.request = {\n\t\t\t\"alertId\":$scope.array,\n\t\t\t\"read\": \"Y\"\n\t\t}\n\n\t\tajax.post(\"/services2/auth/web/alerts/update\", $scope.request).then(function (response) {\n\t\t\tconsole.log(response);\n\t\t\t$window.location.href = \"/services/auth/viewallalerts\";\n\t\t}, function (err) {\n\t\t\tconsole.log(err);\n\t\t\t$window.location.href = \"/services/auth/viewallalerts\";\n\t\t});\n\t}\n\n\n\n\t$scope.listOfAlertsToUpdate = [];\n\n\tfunction clear() {\n\t\t$scope.listOfAlertsToUpdate.length = 0;\n\t}\n\n\t$scope.showAllAlerts = function() {\n\t\t//var pagesChangedEvent = _.partial(updateEvent);\n\t\tngTableEventsChannel.onPagesChanged(function updateEvent() {\n\n\t\t\tclear();\n\t\t\t$scope.alert.index = ($scope.alertsTable.page() - 1 )*$scope.alertsTable.count();\n\t\t\tfor (var i=$scope.alert.index; \n\t\t\t\ti < (($scope.alert.index + $scope.alertsTable.count()) > $scope.alert.allAlerts.alerts.length ? $scope.alert.allAlerts.alerts.length : ($scope.alert.index + $scope.alertsTable.count())); \n\t\t\t\ti++){\n\t\t\t\t\t\n\t\t\t\tif($scope.alert.allAlerts.alerts[i].isRead !== \"Y\"){\n\t\t\t\t\t$scope.listOfAlertsToUpdate.push($scope.alert.allAlerts.alerts[i].alertId);\n\t\t\t\t}\n\t\t\t}\n\t\t\tconsole.log($scope.listOfAlertsToUpdate);\n\t\t\t$scope.request = {\n\t\t\t\t\"alertId\": $scope.listOfAlertsToUpdate,\n\t\t\t\t\"read\": \"Y\"\n\t\t\t}\n\t\n\t\t\tajax.post(\"/services2/auth/web/alerts/update\", $scope.request).then(function (response) {\n\t\t\t\tconsole.log(response);\n\t\t\t}, function (err) {\n\t\t\t});\n\t\t}, $scope);\n\n\t\tajax.post(\"/services2/auth/web/alerts/all\",{}).then(function (response) {\n\t\t\tif (response) {\n\t\t\t\t$scope.alert.allAlerts = response;\n\t\t\t}\n\n\t\t\tif ($scope.alert.allAlerts && $scope.alert.allAlerts.alerts.length > 0){\n\n\t\t\t\t$scope.alertsTable = new NgTableParams({\n\t\t\t\t\tpage: 1,\n\t\t\t\t\tcount: 5,\n\t\t\t\t\tsorting: {\n\t\t\t\t\t\talertId: 'desc'\n\t\t\t\t\t}\n\t\t\t\t}, {\n\t\t\t\t\tcounts: [],\n\t\t\t\t\tdataset: $scope.alert.allAlerts.alerts\n\t\t\n\t\t\t\t});\n\t\t\t}\n\t\t});\n\t}\n}]).controller(\"footerCtrl\", [\"$scope\", \"$rootScope\", function ($scope, $rootScope) {\n\t$rootScope.$on(\"udata\", function (event, mass) {\n\t\tif (mass && mass.udata) {\n\t\t\t$scope.udata = mass.udata;\n\t\t\t$scope.expanded = true;\n\t\t}\n\t});\n\t$scope.expanded = false;\n\t$scope.servers = $().getConstant('servers');\n\t$scope.fexpand = function () {\n\t\t$scope.expanded = !$scope.expanded;\n\t};\n\tconst year = new Date().getFullYear();\n\tconst month = new Date().getMonth() + 1;\n\t$scope.FY = month > 3 ? `${year}-${(year + 1).toString().slice(2,4)}` : `${year - 1}-${year.toString().slice(2,4)}`;\n\t\n}]).controller(\"headerCtrl\", [\"$scope\", \"ajax\", \"$timeout\", \"shareData\", \"$rootScope\", \"$route\", \"utilFunctions\", \"$compile\", \"cache\", \"$location\", \"FormSubmitter\", function ($scope, ajax, $timeout, shareData, $rootScope, $route, utilFunctions, $compile, cache, $location, FormSubmitter) {\n\t$scope.udata = undefined;\n\t$scope.servers = $().getServers();\n\t//adding for masking cr17153\n\t\n\t // IMS link enable and disble with live date\n\t var today = new Date();\n\t var dd = String(today.getDate()).padStart(2, \"0\");\n\t var mm = String(today.getMonth() + 1).padStart(2, \"0\");\n\t var yyyy = today.getFullYear();\n\t $scope.todayDate = yyyy + \"-\" + mm + \"-\" + dd;\n\t let d1 = new Date($scope.todayDate).getTime();\n\t let d2 = new Date($scope.servers.IMSDASH_LIVE_DT).getTime();\n\t if((d1 >=  d2) || ($scope.servers.IMS_TEST == 'Y')) {\n\t\t $scope.imsLinkEnable = true;\n\t } else {\n\t\t $scope.imsLinkEnable = false;\n\t }\n\n\tif ($().getConstant('COMP_REPORT_FLAG')){\n        $scope.compFlag = $().getConstant('COMP_REPORT_FLAG');\n\t};\n\t$scope.showPostPP = function(){\n\t\tlocalStorage.setItem(\"isPostPP\", \"Y\");\n\t}\n\t$scope.ucall = function () {\n\t\tajax.get(\"/services/api/ustatus\").then(function (resp) {\n\t\t\tif (resp && Object.keys(resp).length > 0) {\n\t\t\t\t$scope.udata = resp;\n\t\t\t\tshareData.udata = $scope.udata;\n\t\t\t\t$scope.validSP = false;\n\t\t\t\t// CR 29179A Changes Start - Taxpayer Eligibilty Validation for accessing specified premises\n\t\t\t\tif($scope.udata && $scope.udata.role && $scope.udata.role == \"panLogin\") {\n\t\t\t\t\tif($scope.udata.trnTaxPyrType && ($scope.udata.trnTaxPyrType == \"TP\" || $scope.udata.trnTaxPyrType == \"NT\")) {\n\t\t\t\t\t\tif($scope.udata.trnLiabCd && $scope.udata.trnLiabCd != null) {\n\t\t\t\t\t\t\t$scope.validSP = false;\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\t$scope.validSP = true;\n\t\t\t\t\t\t}\n\t\t\t\t\t}\n\t\t\t\t\t$rootScope.$emit(\"validSP\",  {\n\t\t\t\t\t\t\"validSP\": $scope.validSP\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t\t// CR 29179A Changes End\t\t\t\t\n\t\t\t\t/* CR#18614 and CR#20221 code changes start*/\n\t\t\t\tvar bankTpTypes = ['TP','UN']; //CR-29095 removed 'O', 'NR' as updating bank account details should not be shown to NRTP/OIDAR Taxpayers\n\t\t\t\tvar __compTypTaxpayer = $scope.udata.regType == \"CO\" && $scope.udata.appStatus == \"A\";\n\n\t\t\t\t\n\t\t\t\t \n\t\t\t\tvar __bnkNotAddTaxpayer = shareData.udata.bnkStat == \"N\" && $scope.udata.appStatus == \"A\" && $scope.udata.role == \"login\" && bankTpTypes.indexOf($scope.udata.utype) > -1;\n\t\t\t\tif(__compTypTaxpayer || __bnkNotAddTaxpayer) {\n\t\t\t\t\tvar _triggerUdata = (__compTypTaxpayer && __bnkNotAddTaxpayer) ? \"triggerUdataInBnk\" : __compTypTaxpayer ?  \"triggerUdataInComp\" : \"triggerUdataInBnk\";\n\t\t\t\t\tif (__compTypTaxpayer) {\n\t\t\t\t\t\t__validateCompTP(_triggerUdata);\n\t\t\t\t\t}\n\t\t\t\t\tif(__bnkNotAddTaxpayer) { /* CR#20221 if condition */\n\t\t\t\t\t\t__validateBankTP(_triggerUdata)\n\t\t\t\t\t} \n\t\t\t\t} \n\t\t\t\telse {\n\t\t\t\t\t$rootScope.$emit(\"udata\", {\n\t\t\t\t\t\t\"udata\": $scope.udata\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t\t/* CR#18614 and CR#20221 code changes end*/\n\t\t\t\tif (shareData.udata.ASBS_STATE_CD) {\n\t\t\t\t\t$scope.getStatelist();\n\t\t\t\t}\n\t\t\t\tif ($scope.udata.appStatus == \"C\") {\n\t\t\t\t\tajax.get(\"/services/api/taxpayer/CancellationStatus\").then(function (resp) {\n\t\t\t\t\t\tif (resp && Object.keys(resp).length > 0) {\n\t\t\t\t\t\t\t$scope.udatasp = resp;\n\t\t\t\t\t\t\tshareData.udatasp = $scope.udatasp;\n\t\t\t\t\t\t\t$rootScope.$emit(\"udatasp\", {\n\t\t\t\t\t\t\t\t\"udatasp\": $scope.udatasp\n\t\t\t\t\t\t\t});\n\t\t\t\t\t\t}\n\t\t\t\t\t});\n\t\t\t\t}\n\t\t\t}\n\t\t});\n\n\t}\n\t//einvoice login flag\n\tconsole.log(\"Login flag from einvoice is :\",$().getConstant('flag'));\n\t$scope.hidemenu = false;\n\tconsole.log(\"value of hidemenu outside if is :\",$scope.hidemenu);\n\t\tif ($().getConstant('flag')) {\n\t\t\t$scope.einvflag = $().getConstant('flag');\n\t\t\tif($scope.einvflag == \"einvoice\"){\n\t\t\t\t$scope.hidemenu = true;\n\t\t\t\tconsole.log(\"value of hidemenu inside if is :\",$scope.hidemenu);\n\t\t\t}\n\t\t\tconsole.log(\"Login flag from einvoice inside if is :\",$scope.einvflag);\n    }\n\t    //To enable Einvoice\n\t\tif ($scope.servers['ENABLE_EINVOICE_DASHBOARD'] == \"True\") {\n\t\t\tconsole.log(\"Value of Enable Einv dashboard is :\" + $scope.servers['ENABLE_EINVOICE_DASHBOARD']);\n\t\t\t$scope.enableEinv = true;\n\t\t\t// console.log(\"enableEinv\"+enableEinv);\n\t\t} else {\n\t\t\tconsole.log(\"Value of Enable Einv dashboard is :\" + $scope.servers['ENABLE_EINVOICE_DASHBOARD']);\n\t\t\t$scope.enableEinv = false;\n\t\t\t// console.log(\"enableEinv\"+enableEinv);\n\t\t}\n\n\t/* CR#18614 code change start */\n\tvar __validateCompTP = function (triggerUdata) {\n\t\tvar payload = {\n\t\t\t\"gstin\": $scope.udata.gstin,\n\t\t};\n\t\tajax.get('/services/auth/api/comp/validatecomp', payload).then(function (resp) {\n\t\t\tif (resp && Object.keys(resp).length > 0 && !resp.error) {\n\t\t\t\t$scope.compsp = resp;\n\t\t\t\t$scope.compsp.PAN = $scope.udata.gstin.substr(2, 10);\n\t\t\t\t$rootScope.$emit(\"compsp\", {\n\t\t\t\t\t\"compsp\": $scope.compsp\n\t\t\t\t});\n\t\t\t\tif ($scope.compsp && $scope.compsp.thresholdLimAATO == \"exceeded\") {\n\t\t\t\t\tif($(\".maskBank\").length == 1) {\n\t\t\t\t\t\t$(\".maskBank\").remove();\n\t\t\t\t\t}\n\t\t\t\t\t//$(\"#main\").prepend(\"<div class='maskComp' style='position:absolute;width:100%;height:100%;cursor:pointer'></div>\");\n\t\t\t\t//\t$(\".nav.navbar-nav\").css({\n\t\t\t\t\t//\t\"position\": \"relative\",\n\t\t\t\t\t//\t\"z-index\": \"-1\"\n\t\t\t\t\t//});\n\t\t\t\t\t//$scope.disableMenuShowTT();\n\t\t\t\t\ttriggerPopup(\"maskComp\");\n\t\t\t\t}\n\t\t\t}\n\t\t\tif (triggerUdata == \"triggerUdataInComp\") {\n\t\t\t\t$rootScope.$emit(\"udata\", {\n\t\t\t\t\t\"udata\": $scope.udata\n\t\t\t\t});\n\t\t\t}\n\t\t});\n\t};\n\tvar triggerPopup = function (showPP) {\n\t\t$(\".\" + showPP).click(function (e) {\n\t\t\tif (showPP == \"maskComp\") {\n\t\t\t\t$scope.EnableCmpUsrPP();\n\t\t\t}\n\t\t\telse if(showPP == \"maskBank\"){\n\t\t\t\t$scope.popupMsg();\n\t\t\t}\t\t\n\t\t});\n\t}\n\t$scope.disableMenuShowTT = function (toggleMsg) {\n  \t\t/* CR#22679 code changes start*/\n        if ($scope.bankrsp && $scope.bankrsp.bankTimeEx == 'Y') {\n            $scope.enableServices = true;\n        }\n  \t\t/* CR#22679 code changes stop*/\n\t\t$scope.udata.disableMenu = true;\n\t\tvar disableIds = ['myPrflDis', 'emblemDis', 'emblemTitDis', 'siteDis'];\n\t\t$('.menuList[data-toggle=\"tooltip\"]').tooltip({\n\t\t\ttitle: toggleMsg ? toggleMsg : \"\",\n\t\t\thtml: true,\n\t\t});\n        /* CR#22679 code changes start */\n        $('.smenu li[data-toggle=\"tooltip\"]').tooltip({\n            title: toggleMsg ? toggleMsg : \"\",\n            html: true,\n        });\n        $('.smenu li.has-sub ul .isubmenu .leg .post[data-toggle=\"tooltip\"]').tooltip({\n            title: toggleMsg ? toggleMsg : \"\",\n            html: true,\n        });\n        /* CR#22679 code changes stop */\n\t\t$('.breadcrumb').children('li').addClass('disabled');\n    \t/* CR#22679 code changes start */\n        $('.breadcrumb').tooltip({\n            title: toggleMsg ? toggleMsg : \"\",\n            html: true,\n        });\n        /* CR#22679 code changes stop */\n\t\t$('.breadcrumb li a').css({\n\t\t\t'cursor': 'not-allowed',\n\t\t\t'text-decoration': 'none'\n\t\t});\n\t\tfor (var i = 0; i < disableIds.length; i++) {\n\t\t\tvar elementId = document.getElementById(disableIds[i]);\n\t\t\tif (elementId) {\n\t\t\t\telementId.setAttribute('oncontextmenu', 'return false');\n\t\t\t}\n\t\t}\n\t};\n\t/* CR#18614 code changes end*/\n\t/* CR#20221 code changes start*/\n\tvar __validateBankTP = function(triggerUdata) {\n\t\tvar bankPayload = {\n\t\t\t\"appStatus\" : $scope.udata.appStatus,\n\t\t\t\"bnkStatus\" : $scope.udata.bnkStat\n\t\t};\n\t\tajax.get('/services/auth/api/bankpop', bankPayload).then(function (resp) {\n\t\t\tif (resp && Object.keys(resp).length > 0 && !resp.error) {\n\t\t\t\t$scope.bankrsp = resp;\n\t\t\t\t$rootScope.$emit(\"bankrsp\", {\n\t\t\t\t\t\"bankrsp\": $scope.bankrsp\n\t\t\t\t});\n\t\t\t}\n\t\t\tif(triggerUdata == \"triggerUdataInBnk\") {\n\t\t\t\t$rootScope.$emit(\"udata\", {\n\t\t\t\t\t\"udata\": $scope.udata\n\t\t\t\t});\n\t\t\t}\n\t\t});\t\n\t};\n\t$scope.clearPostPP = function (){\n\t\tif(localStorage.getItem(\"isPostPP\") != null){\n\t\t\tlocalStorage.removeItem(\"isPostPP\");\n\t\t}\n\t}\n\t$scope.popupMsg = function() {\n\t\tif (shareData.udata.bnkStat == 'N') {\n\t\t\tvar isPopup = document.getElementById(\"confirmDlg\");\n\t\t\tif(isPopup){\n\t\t\t\treturn;\n\t\t\t}\n\t\t\tvar idtype = \"GSTIN\";\n\t\t\tif (shareData.udata.utype == 'TR') {\n\t\t\t\tidtype = \"Temporary ID\";\n\t\t\t}\n\t\t\tvar errMsg, submsg;\n\t\t\terrMsg = \"Since you have crossed the time period to add the Bank Account Details. GSTIN Registration may be cancelled if such details are not filled at the earliest.\";\n\t\t\tsubmsg = \"Please add immediately to proceed further on the GST portal.\";\n\t\t\tvar conf = utilFunctions.createDialogue({\n\t\t\t\t\"type\": \"fileamendment\",\n\t\t\t\t\"message\": errMsg,\n\t\t\t\t\"submsg\": submsg,\n\t\t\t\t\"title\": \"Dear Taxpayer,\",\n\t\t\t\t\"callback\": \"amendmentCall()\",\n\t\t\t\t\"ok_btn_title\": \"FILE AMENDMENT\"\n\t\t\t});\n\t\t\t$('body').append($compile(conf)($scope));\n\t\t\t$(\"#confirmDlg\").modal({\n\t\t\t\tshow: true,\n\t\t\t\tbackdrop: 'static'\n\t\t\t});\n\t\t}\t\n\t};\n\t$scope.amendmentCall = function () {\n\t\t$scope.servers = $().getConstant('servers');\n\t\tswitch (shareData.udata.utype) {\n\t\t\tcase 'TP':\n\t\t\t\t$scope.amnURL = $scope.servers.GST_REGISTRATION_R1_URL + '/registration/auth/amend/noncore/business';\n\t\t\t\tbreak;\n\t\t\tcase 'NREX':\n\t\t\tcase 'NR':\n\t\t\tcase 'TD':\n\t\t\tcase 'TS':\n\t\t\tcase 'O':\n\t\t\t\t$scope.amnURL = $scope.servers.GST_REGISTRATION_R1_URL + '/registration/auth/comnamend/noncore/basicdtls';\n\t\t\t\tbreak;\n\t\t\tcase 'TR':\n\t\t\t\t$scope.amnURL = $scope.servers.GST_REGISTRATION_R1_URL + '/registration/auth/comnamend/noncore/bank';\n\t\t\t\tbreak;\n\t\t}\n\t\tFormSubmitter.submit($scope.amnURL, \"POST\", { 'amendFlag': 'Y' });\n\t}\n\t/* CR#20221 code changes end*/\n\t/* CR#18614 code changes start*/\n\t$scope.EnableCmpUsrPP = function () {\n\t\tvar isthresholdLimit = $scope.compsp && ($scope.compsp.thresholdLimAATO == \"lessTen\" || $scope.compsp.thresholdLimAATO == \"lessFive\" || $scope.compsp.thresholdLimAATO == \"exceeded\");\n\t\tvar isPopup = document.getElementById(\"compWdDlg\");\n\t\tif (!$scope.compsp || !isthresholdLimit || isPopup) {\n\t\t\treturn;\n\t\t}\n\t\tvar compMsg, QntLimit;\n\t\tQntLimit = $scope.compsp.thresholdLimAATO == \"lessTen\" ? \"10\" : \"5\";\n\t\tvar currency = $scope.compsp.turnOverAmount.toLocaleString('en-IN', {\n\t\t\tminimumFractionDigits: 2,\n\t\t\tmaximumFractionDigits: 2\n\t\t});\n\t\tif ($scope.compsp.thresholdLimAATO == \"lessTen\" || $scope.compsp.thresholdLimAATO == \"lessFive\") {\n\t\t\tcompMsg = \"The Annual Aggregate Turnover for the Financial Year \" + $scope.compsp.fy + \" under the PAN (\" + $scope.compsp.PAN + \") is \" + QntLimit + \" lakhs less the quantum specified. The Annual Aggregate Turnover under the PAN (\" + $scope.compsp.PAN + \") is Rs.\" + currency + \". Kindly opt out of composition Levy if you expect the Annual Aggregate Turnover under the PAN to exceed the Quantum Specified.\";\n\t\t} else if ($scope.compsp.thresholdLimAATO == \"exceeded\") {\n\t\t\tcompMsg = \"The Annual Aggregate Turnover for the Financial Year \" + $scope.compsp.fy + \" under the PAN (\" + $scope.compsp.PAN + \") has already exceeded the quantum specified Kindly opt out of composition Levy.\";\n\t\t}\n\t\tvar conf = utilFunctions.createDialogue({\n\t\t\t\"type\": \"compWithDraw\",\n\t\t\t\"message\": compMsg,\n\t\t\t\"callback\": \"withdrawComp()\",\n\t\t});\n\t\t$('body').append($compile(conf)($scope));\n\t\t$(\"#compWdDlg\").modal({\n\t\t\tshow: true,\n\t\t\tbackdrop: 'static'\n\t\t});\n\t};\n\t$scope.withdrawComp = function () {\n\t\t$(\"#compWdDlg\").modal('hide');\n\t\tif ($scope.compsp.thresholdLimAATO == \"exceeded\") {\n\t\t\tFormSubmitter.submit($scope.servers.GST_REGISTRATION_R1_URL + \"/registration/auth/wtdrwcomp\", \"POST\", {\n\t\t\t\t\"fy\": $scope.compsp.fy,\n\t\t\t\t\"thresholdLimAATO\": $scope.compsp.thresholdLimAATO,\n\t\t\t\t\"turnOverAmount\": $scope.compsp.turnOverAmount,\n\t\t\t\t\"isCompLogin\": \"Y\"\n\t\t\t});\n\t\t}\n\t};\n\t/* CR#18614 code change end */\n\t$rootScope.$on('$routeChangeSuccess', function (event, current) {\n\t\tif($route.current && $route.current.$$route && $route.current.$$route.nostatus) {\n\t\t\tif($route.current.$$route.nostatus === true) {\n\t\t\t\treturn ;\n\t\t\t} else {\n\t\t\t\t$scope.ucall();\t\n\t\t\t}\n\t\t} else {\n\t\t\t$scope.ucall();\n\t\t}\n\t});\n    $scope.redirectFn = function () {\n        window.location.href = $scope.servers['GST_SERVICES_R1_URL']+\"/services/auth/dashboard\";\n    } \n    \n    \n    $scope.getStatelist = function(){\n        if(shareData.udata.stcd){\n        if(shareData.udata.ASBS_STATE_CD){\n            var stateCode =  shareData.udata.stcd;\n            var stlist = shareData.udata.ASBS_STATE_CD;\n            $scope.msmeStateCodesList = stlist.split(',');\n            if ($scope.msmeStateCodesList.length > 0) {\n                for(var i=0; i < $scope.msmeStateCodesList.length ; i++){\n                    if(stateCode == $scope.msmeStateCodesList[i]){\n                        $scope.showLink = true ;\n                        //console.log($scope.showLink);\n                    }\n                }\n            }     \n        }\n    }\n    }\n    \n    \n    $scope.msmeSoftwarePopup = function(){\n          \n        var conf = utilFunctions.createDialogue({\n            \"type\": \"Warning\",\n            \"title\": \"Accounting And Billing Software Services\",\n            \"message\": \"The download functionality is available to the Micro, Small and Medium Enterprises (MSMEs) having turnover less than 1.5 crores. Do you have turnover less than 1.5 crore?\",\n            \"callback\": \"showSoftwareDetails()\",\n            \"ok_btn_title\": \"Yes\",\n            \"cancel_btn_title\": \"No\",\n            \"cancelcallback\": \"destroyModal\"\n        });\n        $('body').append($compile(conf)($scope));\n        $(\"#confirmDlg\").modal('show');\n        \n    }\n\t/* Optin for Quarterly Return link CR- 18145 */\n\t$scope.manageProfile = function () {\n\t\twindow.location.href = $scope.servers['GST_RETURNS_R1_URL'] + \"/returns/auth/managertnprofile\";\n\t}\n\t$scope.smtwarningPopup = function () {\n\n\t\tvar conf = utilFunctions.createDialogue({\n\t\t\t\"type\": \"Warning\",\n\t\t\t\"title\": \"Warning\",\n\t\t\t\"message\": \"Link is not available for Suspended /Cancelled taxpayer\",\n\t\t\t\"callback\": \"destroyModal\",\n\t\t\t\"ok_btn_title\": \"OK\",\n\t\t\t\"cancel_btn_title\": \"Cancel\",\n\t\t\t\"cancelcallback\": \"destroyModal\"\n\t\t});\n\t\t$('body').append($compile(conf)($scope));\n\t\t$(\"#confirmDlg\").modal('show');\n\n\t}\n\t$scope.warningsvdpopup = function () {\n\n\t\tvar conf = utilFunctions.createDialogue({\n\t\t\t\"type\": \"Warning\",\n\t\t\t\"title\": \"Warning\",\n\t\t\t\"message\": \"You cannot file Core Amendment Application since your GSTIN is suspended.\",\n\t\t\t\"callback\": \"destroyModal\",\n\t\t\t\"ok_btn_title\": \"OK\",\n\t\t\t\"cancel_btn_title\": \"Cancel\",\n\t\t\t\"cancelcallback\": \"destroyModal\"\n\t\t});\n\t\t$('body').append($compile(conf)($scope));\n\t\t$(\"#confirmDlg\").modal('show');\n\n\t}\n    $scope.showSoftwareDetails = function(){\n        window.location.href = $scope.servers['GST_SERVICES_R1_URL']+\"/services/auth/msmeSoftware\";\n    }\n    \n    $scope.destroyModal = function () {\n        utilFunctions._destroyDialogue();\n        $(\".modal-backdrop\").remove();\n        $(\"body\").removeClass(\"modal-open\");\n        $(\"body\").css(\"padding-right\", \"0\");\n    };\n    $scope.getPdf = function(type){\n        var url;\n        if(type == 1){\n            url= $scope.servers['GST_TUTORIAL_R1_URL'] +\"/offlineutilities/returns/NewGSTReturn_Normal.pdf\";\n            window.open(url, '_blank')\n        }else if(type == 2){\n             url= $scope.servers['GST_TUTORIAL_R1_URL'] +\"/offlineutilities/returns/NewGSTReturn_Sahaj.pdf\";\n            window.open(url, '_blank')\n        }else if(type == 3){\n             url= $scope.servers['GST_TUTORIAL_R1_URL'] +\"/offlineutilities/returns/NewGSTReturn_Sugam.pdf\";\n            window.open(url,'_blank')\n        }\n    }\n    \n}]).controller(\"sitemapctrl\", function($scope, $rootScope, shareData){\n    $scope.servers = $().getServers();\n\t$rootScope.$on(\"udata\", function (event, mass) {\n\t\tif (mass && mass.udata) {\n\t\t\t$scope.udata = mass.udata;\n\t\t}\n\t});\n\t$rootScope.$on(\"udatasp\", function (event, mass) {\n        if (mass && mass.udatasp) {\n            $scope.udatasp = mass.udatasp;\n        }\n    });\n\t// CR 29179A Changes Start - Taxpayer Eligibilty Validation for accessing specified premises\n\t$rootScope.$on(\"validSP\", function(event, mass) {\n\t\tif (mass && mass.validSP) {\n\t\t\t$scope.validSP = mass.validSP;\n\t\t}else {\n\t\t\t$scope.validSP = false;\n\t\t}\n\t});\n\t// CR 29179A Changes End\n}).controller(\"gstpdashboardctrl\", function ($scope, $rootScope) {\n\t$rootScope.$on(\"udata\", function (eve