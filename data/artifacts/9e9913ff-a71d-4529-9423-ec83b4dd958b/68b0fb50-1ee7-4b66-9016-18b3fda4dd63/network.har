else {\r\n          $window.location.href = $scope.servers[\"GST_REGISTRATION_URL\"] + \"/registration/auth/business-details\"; \r\n       }\r\n    } ;\r\n     $scope.data = {};\r\n     $scope.validateRbaOtp = function (form) {\r\n        $scope.details = JSON.parse(shareData.loginDetails.message);\r\n\r\n\r\n        if (form.$valid && $scope.details.otpAuthSts) {\r\n\r\n            var api, rbaRequest, details;\r\n\r\n            switch (shareData.loginDetails.errorCode) {\r\n               \r\n            case 'RSK_1000':\r\n                rbaRequest = JSON.parse(shareData.loginDetails.message);\r\n                details = {\r\n\r\n                    otp: $scope.data.otp\r\n                };\r\n                rbaRequest.otpDetails = JSON.stringify(details);\r\n\r\n                api = \"/validate/rba/otp\";\r\n                break;\r\n\r\n\r\n            }\r\n\r\n            ajax.post(\"/services\" + api, rbaRequest, {}, function () {\r\n                $().blockPage(true);\r\n            }, function () {\r\n                $().blockPage(false);\r\n            }).then(function (response) {\r\n                if (response.message === \"true\" || response.message === \"auth\") {\r\n                    window.location.href = \"/services/auth/\";\r\n\r\n                } else {\r\n                     var msg, alert_dlg=\"\";\r\n                    var item={};\r\n                    item.link='/services/login';\r\n                    \r\n                    msg = \"OTP is Incorrect. Click \" +\"<a href='\"+item.link+\"'>\"+\"here</a>\"+ \" to login again\";\r\n                    $scope.errorMsg=$sce.trustAsHtml(msg);\r\n                    $('[name=errContainer]').empty().append($compile(alert_dlg)($scope));\r\n                }\r\n            }, function (err) {\r\n                $().blockPage(false);\r\n            });\r\n\r\n        } \r\n    };\r\n    $scope.onLoadOtp = function () {\r\n        var OtpSts, msg, alert_dlg;\r\n        OtpSts = JSON.parse(shareData.loginDetails.message);\r\n        if (OtpSts.otpAuthSts) {\r\n            if(OtpSts.ruleMatched){\r\n                // msg = \"One-Time Password (OTP) authentication is required as \"+$scope.trans[\"RBA_\"+OtpSts.ruleMatched] +\". OTP has been generated and sent to your registered Email Address and Mobile Number\";\r\n            \t//RQM 25950 Enhanced RBA OTP TEMPLATE\r\n            \tmsg = \"Dear User, Please enter the One-Time Password (OTP) sent to your registered Email Address and Mobile Number. This extra step is for your security because \"+$scope.trans[\"RBA_\"+OtpSts.ruleMatched];\r\n            }else{\r\n                msg = \"One-Time Password (OTP) has been sent to your registered Email Address and Mobile Number\";\r\n            }\r\n            \r\n            alert_dlg = utilFunctions.createAlert({\r\n                \"title\": \"\",\r\n                \"type\": \"success\",\r\n                \"message\": msg\r\n            });\r\n\r\n        } else {\r\n            msg = \"Please try after some time\";\r\n            alert_dlg = utilFunctions.createAlert({\r\n                \"title\": \"\",\r\n                \"type\": \"danger\",\r\n                \"message\": msg\r\n            });\r\n        }\r\n\r\n        $('[name=errContainer]').empty().append($compile(alert_dlg)($scope));\r\n\r\n\r\n    };\r\n\t\r\n\t$scope.newregclick=function(){\t\t\t\t\r\n\t\t window.location.href = $scope.servers[\"GST_REGISTRATION_R1_URL\"] + \"/registration/\";\t\t \r\n\t\t\r\n\t}\r\n\r\n\r\n}\r\n\r\nwelcomeCtrl.$inject = ['$scope', 'cache', '$rootScope', 'shareData', '$location', 'ajax', '$route', '$window', '$timeout', '$templateCache', '$log', 'utilFunctions', 'validations', '$compile'];\r\n\r\n\r\nfunction welcomeCtrl($scope, cache, $rootScope, shareData, $location, ajax, $route, $window, $timeout, $templateCache, $log, utilFunctions, validations, $compile) {\r\n    /* init controller */\r\n   \r\n\r\n    utilFunctions.initCache();\r\n    $scope.servers = $().getServers();\r\n    $scope.trans = utilFunctions.initLanguage('services');\r\n    $rootScope.$on(\"LangChanged\", function(event, mass) {\r\n        $scope.trans = utilFunctions.initLanguage('services');\r\n    });\r\n    $scope.$on('$viewContentLoaded', function() {\r\n        $window.scrollTo(0, 0);\r\n        angular.element(document.querySelector('[autofocus]')).focus();\r\n    });\r\n    /*init completed*/\r\n\r\n    $scope.getCData = function(item) {\r\n\r\n        if (cache.get(item).length > 0) {\r\n            $scope[item] = cache.get(item);\r\n        } else {\r\n            ajax.get($scope.resources[item]).then(function(response) {\r\n                $scope[item] = response.data;\r\n                cache.set(item, response.data);\r\n                delete $scope.errors[item];\r\n            }, function(err) {\r\n                $scope.errors[item] = err.msg;\r\n            });\r\n        }\r\n\r\n    };\r\n\r\n    if ($route.current) {\r\n        deps = $route.current.$$route.deps || [];\r\n        for (dep in deps) {\r\n            $scope[deps[dep]] = cache.get(deps[dep]) || [];\r\n            if ($scope[deps[dep]].length === 0) {\r\n                $scope.getCData(deps[dep]);\r\n            }\r\n        }\r\n    }\r\n   \r\n\r\n\r\n    \r\n        $scope.uploadWebJson=function() {\r\n        ajax.get(\"/services/verify/regstatus\",{},{}, function () {\r\n           $().blockPage(true); \r\n        }, function () {\r\n            $().blockPage(false);\r\n        }).then(function (response){\r\n            if(response.errorCode == 'SWEB_9021') {\r\n               // window.location.href = $scope.servers[\"GST_REGISTRATION_URL\"] + \"/registration/auth/business-details\";\r\n            } else if(response.successCode == 'auth') {\r\n                $window.location.href = $scope.servers[\"GST_REGISTRATION_URL\"] + \"/registration/auth/business-details\";\r\n            } else if(response.successCode == 'SWEB_2001') {\r\n              //  $window.location.href = $scope.servers[\"GST_REGISTRATION_URL\"] + \"/registration/auth/business-details\";\r\n            } else if(response.successCode == 'upload') {\r\n                 $window.location.href ='/services/auth/regoptions';\r\n            } else if(response.successCode == 'SWEB_2002') {\r\n                $window.location.href =\"/services/auth/restrictupload\";\r\n            }  else if(response.successCode == 'mobileapp') {\r\n                 $window.location.href =\"/services/auth/uploadjson\";\r\n            }\r\n        });\r\n    }\r\n\r\n\r\n\r\n}"},"headersSize":1329,"bodySize":6469,"redirectURL":"","_transferSize":7798},"cache":{},"timings":{"dns":-1,"connect":-1,"ssl":-1,"send":0,"wait":22.742,"receive":1.306},"serverIPAddress":"23.222.248.33","_serverPort":443,"_securityDetails":{"protocol":"TLS 1.2","subjectName":"*.gst.gov.in","issuer":"DigiCert Global G3 TLS ECC SHA384 2020 CA1","validFrom":1778198400,"validTo":1795391999}},{"pageref":"page@208d3e1db68ef3d6564c6188af16a787","startedDateTime":"2026-05-22T16:51:10.765Z","time":18.950000000000003,"request":{"method":"GET","url":"https://static.gst.gov.in/uiassets/js/services/forgotCtrl1.1.js","httpVersion":"HTTP/1.1","cookies":[],"headers":[{"name":"Accept","value":"*/*"},{"name":"Accept-Encoding","value":"gzip, deflate, br, zstd"},{"name":"Accept-Language","value":"en-IN"},{"name":"Connection","value":"keep-alive"},{"name":"Host","value":"static.gst.gov.in"},{"name":"Referer","value":"https://services.gst.gov.in/"},{"name":"Sec-Fetch-Dest","value":"script"},{"name":"Sec-Fetch-Mode","value":"no-cors"},{"name":"Sec-Fetch-Site","value":"same-site"},{"name":"User-Agent","value":"Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36 (KHTML, like Gecko) HeadlessChrome/148.0.7778.96 Safari/537.36"},{"name":"sec-ch-ua","value":"\"Chromium\";v=\"148\", \"HeadlessChrome\";v=\"148\", \"Not/A)Brand\";v=\"99\""},{"name":"sec-ch-ua-mobile","value":"?0"},{"name":"sec-ch-ua-platform","value":"\"Windows\"