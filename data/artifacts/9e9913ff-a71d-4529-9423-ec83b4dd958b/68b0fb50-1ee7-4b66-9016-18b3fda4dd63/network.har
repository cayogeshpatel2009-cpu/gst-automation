\n            };\n        },\n        template: '<div class=\"dropdowngrp\"><button ng-click=\"toggle()\" class=\"btn btn-primary dropbtn\"><span class=\"dropdwnSpan\" ng-bind=\"btnName\"></span>&nbsp;<span class=\"caret dropdwnSpan\"></span></button><div id=\"myDropdown\" class=\"dropdown-content\" ng-class=\"{\\'show\\': showContent}\"><a role=\"button\" ng-repeat=\"(key,value) in options\" ng-click=\"buttonClick(key)\" ng-bind=\"value\"></a></div></div>'\n    };\n});\nmyApp.directive('downloadDoc', function() {\n    return {\n        restrict: 'A',\n        scope: {\n            url: '=',\n\t\t\thashkey: '=',\n\t\t\tarn: '=',\n\t\t\tmod: '='\n        },\n        link: function(scope, ele, attr) {\n            var eventName = attr.evetName || 'click';\n            ele.on(eventName, function() {\n                var isIE = false;\n                if (navigator.userAgent.indexOf('Trident/') != '-1') { isIE = true; }\n\n                //Cheking if IE browser then create element \"a\"\n                if (isIE) {\n                    var referLink = document.createElement('a');\n                    referLink.href = scope.url + scope.hashkey;\n                    referLink.target = \"_blank\";\n                    referLink.click();\n                } else {\n\t\t\t\t\topen(scope.url + scope.hashkey + '&arn=' + scope.arn + '&mod=' + scope.mod, '_blank');\n                }\n            });\n        }\n    };\n});\n\nmyApp.directive('downloadDocSecure', function() {\n    return {\n        restrict: 'A',\n        scope: {\n            url: '=',\n\t\t\thashkey: '=',\n\t\t\tarn: '=',\n\t\t\tekey: '=',\n\t\t\tmod: '='\n        },\n        link: function(scope, ele, attr) {\n            var eventName = attr.evetName || 'click';\n            ele.on(eventName, function() {\n                var isIE = false;\n                if (navigator.userAgent.indexOf('Trident/') != '-1') { isIE = true; }\n\n                //Cheking if IE browser then create element \"a\"\n              