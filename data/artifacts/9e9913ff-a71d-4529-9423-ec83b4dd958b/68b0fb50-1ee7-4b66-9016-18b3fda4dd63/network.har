ong>{{title}}</strong> {{message}}.</div>'\n\t};\n});\nmyApp.directive('bankDialogue', function () {\n    return {\n        restrict: \"E\",\n        scope: {\n\t\t\ttitle : \"@\",\n            message: \"@\",\n\t\t\tsubmsg : \"@\",\n            callback: \"&\",\n            okTitle: \"@\",\n            viewskipbtn: \"@\"\n        },\n        template:  function(attrs){\n            var isNewPopup = attrs[0].attributes[0].nodeValue;\n            if(isNewPopup){ \n\t\t\t\tvar output = '<div id=\"confirmDlg\" class=\"modal fade fade-scale\" role=\"dialog\"><div class=\"modal-dialog sweet\" style=\"width:470px !important\"><div class=\"modal-content\"><div class=\"modal-body\"><div class=\"bankWarning\"><i class=\"fa fa-exclamation-triangle fa-3x \" aria-hidden=\"true\" style=\"font-size: larger;\"></i>Warning</div><p>{{title}}</p><p class=\"text-justify\">{{message}}</p><p class=\"text-justify\">{{submsg}}</p></div><div class=\"modal-footer\"><a class=\"btn btn-primary\" ng-click=\"callback()\" target=\"_blank\" >{{okTitle}}</a><a class=\"btn btn-default\" data-dismiss=\"modal\" target=\"_blank\">CANCEL</a></div></div></div></div>';\n                return output;\n            }\n            else{\n                var output ='<div id=\"confirmDlg\" class=\"modal fade fade-scale\" role=\"dialog\"><div class=\"modal-dialog sweet\" style=\"width:464px !important\"><div class=\"modal-content\"><div class=\"modal-body\"><div class=\"m-icon m-warning pulseWarning\"><span class=\"micon-body pulseWarningIns\"></span><span class=\"micon-dot pulseWarningIns\"></span></div><p class=\"text-justify\">{{message}}</p></div><div class=\"modal-footer\"><a class=\"btn btn-primary\" ng-click=\"callback()\" target=\"_blank\" >{{okTitle}}</a><a class=\"btn btn-primary\" data-dismiss=\"modal\" ng-if=\"viewskipbtn==1\">SKIP</a></div></div></div></div>';\n                return output;\n            }\n        },\n        link: function (scope, element, attrs){\n            $('#confirmDlg').on('shown.bs.modal', function() {\n                $(this).find('button[id=\"okTitle\"]').focus();\n            });\n            console.log('Testing');\n        }\n\t};\n});\n\nmyApp.directive('revokeAuthDialogue', function() {\n    return {\n        restrict: \"E\",\n        scope: {\n            title: \"@\",\n            message: \"@\",\n            submsg: \"@\",\n            callback: \"&\",\n            okTitle: \"@\",\n            viewskipbtn: \"@\"\n        },\n        template: function(attrs) {\n            var isNewPopup = attrs[0].attributes[0].nodeValue;\n            if (isNewPopup) {\n                var output = \n                '<div id=\"confirmDlg\" class=\"modal fade fade-scale\" role=\"dialog\">' +\n                    '<div class=\"modal-dialog sweet\" style=\"width:75% !important\">' +\n                        '<div class=\"modal-content\">' +\n                            '<div class=\"modal-body\" style = \"padding: 40px 40px 0px 40px;\">' +\n                                '<p class=\"text-justify\" style=\"align-items: center;flex-direction: column;justify-content: center;display: flex;\">{{message}} <span class=\"break-here\" style=\"display: block;\">If you wish to continue, kindly enter the valid reason and click on Revoke button.</span></p>' +\n                                '<div class=\"form-group\" style=\"display:flex; width: 100%; gap: 1rem; justify-content: center; align-items: center;\">' +\n                                    '<label for=\"revokeReason\" style=\"font-weight:normal\">Reason for revoke</label>' +\n\t\t\t\t\t\t\t\t\t'<input id=\"revokeReason\" ng-model=\"revokeReason\" maxlength=\"500\" placeholder=\"Please specify the reason for revoke(maximum 500 characters)\" style=\"width:75%; height:48px; display:flex; align-items:center; vertical-align:middle;\" />' +\n                                '</div>' +\n                            '</div>' +\n                            '<div class=\"modal-footer\">' +\n                                '<a class=\"btn btn-default\" style=\"width: 18rem;\" data-dismiss=\"modal\" ng-click=\"clearReason()\" target=\"_blank\">CANCEL</a>' +\n                                '<a class=\"btn btn-primary\" style=\"width: 18rem;\" ng-click=\"onOk()\" target=\"_blank\">{{okTitle}}</a>' +\n                            '</div>' +\n                        '</div>' +\n                    '</div>' +\n                '</div>';\n                return output;\n            }\n        },\n        link: function(scope, element, attrs) {\n            $('#confirmDlg').on('shown.bs.modal', function() {\n                $(this).find('button[id=\"okTitle\"]').focus();\n            });\n            scope.clearReason = function() {\n                scope.revokeReason = '';\n            };\n            scope.onOk = function() {\n                scope.callback({revokeReason: scope.revokeReason});\n                scope.revokeReason = '';\n            };\n        }\n    };\n});\n/* CR#18614 code changes start \nmyApp.directive('compDialogue', function(){\n\treturn {\n\t\trestrict: \"E\",\n\t\tscope: {\n\t\t\ttitle : \"@\",\n\t\t\tmessage : \"@\",\n\t\t\tcallback : \"&\"\n\t\t},\n\t\ttemplate : '<div id=\"compWdDlg\" class=\"modal fade fade-scale\" role=\"dialog\"><div class=\"modal-dialog sweet\" style=\"width:520px !important\"><div class=\"modal-content\"><div class=\"modal-body\"><div class=\"popup-warning-icon\" ><i class=\"fa fa-exclamation-triangle fa-3x \" aria-hidden=\"true\" style=\"font-size: larger;\"></i><br> Warning</div><p class=\"text-justify\">{{message}}</p></div><div class=\"modal-footer\"> <a class=\"btn btn-primary\" ng-click=\"callback()\" target=\"_blank\" >OK</a></div></div></div></div>'\n\t};\n});*/\n/* CR#18614 code changes end */\nmyApp.directive('adhrTable', function () {\n\treturn {\n\t\trestrict: \"E\",\n\t\tcontrollerAs: 'dir',\n\t\tscope: {\n\t\t\trmdbtnviewvalue: \"@\",\n\t\t\tadhrheadingmsg: \"@\",\n\t\t\tdata: \"=\",\n\t\t\tcallback: \"&\",\