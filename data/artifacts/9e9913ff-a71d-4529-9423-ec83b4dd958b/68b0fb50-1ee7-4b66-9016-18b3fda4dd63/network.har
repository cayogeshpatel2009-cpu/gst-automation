l, $val*/\r\n\"use strict\";\r\nmyApp.controller(\"forgotCtrl\", forgotCtrl);\r\n\r\nforgotCtrl.$inject = ['$scope', 'cache', '$rootScope', 'shareData', '$location', 'ajax', '$route', 'version', '$window', '$timeout', '$templateCache', '$log', 'utilFunctions', 'validations', '$compile'];\r\nmyApp.directive('watchChange', function () {\r\n    return {\r\n        scope: {\r\n            onchange: '&watchChange'\r\n        },\r\n        link: function (scope, element, attrs) {\r\n            element.on('input', function () {\r\n                scope.$apply(function () {\r\n                    scope.onchange();\r\n                });\r\n            });\r\n        }\r\n    };\r\n});\r\n\r\nfunction forgotCtrl($scope, cache, $rootScope, shareData, $location, ajax, $route, version, $window, $timeout, $templateCache, $log, utilFunctions, validations, $compile) {\r\n\r\n    /* init controller */\r\n    utilFunctions.initCache();\r\n    $scope.servers = $().getServers();\r\n    $scope.trans = utilFunctions.initLanguage('services');\r\n    $rootScope.$on(\"LangChanged\", function (event, mass) {\r\n        $scope.trans = utilFunctions.initLanguage('services');\r\n    });\r\n    $scope.$on('$viewContentLoaded', function () {\r\n        $window.scrollTo(0, 0);\r\n        angular.element(document.querySelector('[autofocus]')).focus();\r\n    });\r\n    /*init completed*/\r\n    var deps, dep;\r\n    $scope.validations = validations;\r\n    $scope.alertMsgLogin = true;\r\n    $scope.oneClick = false;\r\n    $scope.forgtuser = true;\r\n    $scope.frtusername = true;\r\n    $scope.frtpass = true;\r\n    $scope.forgotpasswor = true;\r\n    $scope.errorMsg1={};\r\n    $scope.focus = function (ele) {\r\n        $timeout(function () {\r\n            if (angular.element(ele)) {\r\n                angular.element(ele).focus();\r\n            }\r\n        });\r\n    };\r\n\r\n    $scope.resources = {\r\n        \"questions\": \"/master/secques\"\r\n    }\r\n\r\n\r\n    $scope.getCData = function (item) {\r\n\r\n        if (cache.get(item).length > 0) {\r\n            $scope[item] = cache.get(item);\r\n        } else {\r\n            ajax.get($scope.resources[item]).then(function (response) {\r\n                $scope[item] = response.data;\r\n                cache.set(item, response.data);\r\n                delete $scope.errors[item];\r\n            }, function (err) {\r\n                $scope.errors[item] = err.msg;\r\n            });\r\n        }\r\n\r\n    };\r\n\r\n    if ($route.current) {\r\n        deps = $route.current.$$route.deps || [];\r\n        for (dep in deps) {\r\n            $scope[deps[dep]] = cache.get(deps[dep]) || [];\r\n            if ($scope[deps[dep]].length === 0) {\r\n                $scope.getCData(deps[dep]);\r\n            }\r\n        }\r\n    }\r\n    $scope.errors = {};\r\n    /* services code */\r\n    $scope.setPristine = function (form, ele, prop) {\r\n        $scope[form][ele].$setValidity(prop, true);\r\n    }\r\n\r\n\r\n    $scope.showLogin = function () {\r\n        $scope.consent = false;\r\n        $('#fo-user').focus();\r\n    }\r\n\r\n    var patterns = {};\r\n    patterns.username = $scope.validations.formats.pwdtooltip_user;\r\n    patterns.uppercase = $scope.validations.formats.pwdtooltip_uppercase;\r\n    patterns.lowercase = $scope.validations.formats.pwdtooltip_lowercase;\r\n    patterns.number = $scope.validations.formats.pwdtooltip_num;\r\n    patterns.symbol = $scope.validations.formats.pwdtooltip_symbol;\r\n    patterns.pwd = $scope.validations.formats.pwdtooltip_pwd;\r\n    $(\".password-helper\").keyup(function () {\r\n        var val = $(this).val();\r\n        if (val.length > 7) {\r\n            $(this).parent().find(\".minlength\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".minlength\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".minlength\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".minlength\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.uppercase.test(val)) {\r\n            $(this).parent().find(\".upperChar\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".upperChar\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".upperChar\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".upperChar\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.lowercase.test(val)) {\r\n            $(this).parent().find(\".lowerChar\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".lowerChar\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".lowerChar\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".lowerChar\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.number.test(val)) {\r\n            $(this).parent().find(\".numberic\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".numberic\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".numberic\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".numberic\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.symbol.test(val)) {\r\n            $(this).parent().find(\".symbol\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".symbol\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".symbol\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".symbol\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.pwd.test(val)) {\r\n            $(this).parent().find(\".validpwd\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".validpwd\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".validpwd\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".validpwd\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n    });\r\n\r\n\r\n    $scope.loadCaptcha = function () {\r\n        $(\"#imgCaptcha\").addClass(\"captcha-loading\").removeClass(\"captcha\");\r\n        $scope.errors[\"captcha\"] = \"Loading CAPTCHA...\"\r\n        $(\"#imgCaptcha\").on(\"load\", function () {\r\n            $(this).removeClass('captcha-loading').addClass(\"captcha\");\r\n            $timeout(function () {\r\n                delete $scope.errors[\"captcha\"];\r\n            }, 100);\r\n\r\n        });\r\n        $(\"#imgCaptcha\").on(\"error\", function () {\r\n            $(this).removeClass('captcha-loading').addClass(\"captcha\");\r\n            $scope.$apply(function () {\r\n                $scope.errors[\"captcha\"] = \"Unable to load CAPTCHA image. Please click refresh button to load.\";\r\n            });\r\n        });\r\n    };\r\n\r\n\r\n    $scope.captchaObj = {\r\n\r\n    };\r\n\r\n    $scope.backToLogin = function () {\r\n        $scope.consent = false;\r\n        window.location.href = \"/services/login\";\r\n    };\r\n\r\n\r\n\r\n    //forgotuser generate OTP\r\n\t//$scope.Seccaptcha = false;\r\n    $scope.disableClickUser = function () {\r\n        $scope.errorMsg2={};\r\n        $scope.errorMsg2[\"login_error\"] = false;\r\n\r\n        var gst = $scope.validations.gstin($scope.data.username);\r\n\r\n\r\n\r\n        if ($scope.forgotuser_1.user_name.$valid && $scope.forgotuser_1.cap.$valid) {\r\n            $scope.oneClick = true;\r\n            $scope.em = $scope.data.username;\r\n\t        //$scope.Seccaptcha = true;\r\n            var details = {\r\n                uid: $scope.data.username,\r\n                captcha: $scope.data.captcha\r\n\r\n            };\r\n\r\n\r\n            //forgotuser_1name 1st button(request OTP)\r\n            ajax.post(\"/services/check/idusername\", details, function () {\r\n                $().blockPage(true);\r\n            }, function () {\r\n                $().blockPage(false);\r\n            }).then(function (response) {\r\n                $scope.role = response.message;\r\n                $scope.mobileNo = response.errorCode;\r\n                if (response.message === \"false\") {\r\n                    if ($scope.forgotuser_1.$setPristine) {\r\n                        $scope.forgotuser_1.$setPristine();\r\n                        $scope.captchaObj.refresh();\r\n\r\n                        $scope.forgotuser_1.user_name.$setDirty();\r\n                        $('#fo-user').focus();\r\n                        $scope.data.captcha = null;\r\n                        $scope.alertMsgLogin = false;\r\n                        $scope.oneClick = false;\r\n                        $scope.errorMsg1 = \"OTP is not generated. Kindly click on Generate OTP\";\r\n                    }\r\n                } else if (response.errorCode === \"SWEB_9006\") {\r\n                    $location.path(\"/serverbusy\");\r\n                } else if (response.errorCode === \"SWEB_8000\") {\r\n                    $scope.captchaObj.refresh();\r\n                    $('#fo-user').focus();\r\n                    $scope.data.captcha = null;\r\n                    $scope.alertMsgLogin = false;\r\n                    $scope.oneClick = false;\r\n                    $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                } else {\r\n                    if ($scope.forgotuser_1.$setPristine) {\r\n                        $scope.forgotuser_1.$setPristine();\r\n                        $scope.forgotuser_1.user_name.$setDirty();\r\n                        $scope.captchaObj.refresh();\r\n                        $scope.data.captcha = null;\r\n                        $scope.oneClick = false;\r\n                        $scope.alertMsgLogin = false;\r\n\r\n                        if (response.errorCode === \"SWEB_9000\") {\r\n                            $('#fo-captcha').focus();\r\n\r\n                            $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        } else if (response.errorCode === \"SWEB_9032\") {\r\n                            $('#fo-user').focus();\r\n                            $scope.data = null;\r\n                            $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        } else if (response.errorCode === \"SWEB_9031\") {\r\n                            $('#fo-user').focus();\r\n                            $scope.data = null;\r\n                            $scope.newMsg=\"The details related to this Registration Number has been reset and new username has not been created. Please create a new username and password to proceed further.In case you do not have your login details, please contact your Jurisdictional Tax authority.\";\r\n                            $scope.errorMsg1 = $scope.newMsg;\r\n                        } else if (response.errorCode === \"SWEB_9028\") {\r\n                            $('#fo-user').focus();\r\n                            $scope.data = null;\r\n                            $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        } else if (response.errorCode === \"SWEB_9034\") {\r\n                            $('#fo-user').focus();\r\n                            $scope.data = null;\r\n                            $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        } else if (response.errorCode === \"SWEB_9036\") {\r\n                            $scope.errorMsg2[\"login_error\"] = true;\r\n                            $scope.forgotuser_1.$setPristine();\r\n                            $scope.forgotuser_1.user_name.$setDirty();\r\n                            $scope.errorMsg2[\"login_error_desc\"] = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        }else if(response.successCode == \"true\") {\r\n                            if ($scope.forgotuser_1.$setPristine) {\r\n                                $scope.forgotuser_1.$setPristine();\r\n\r\n                                $scope.data.em = response.url;\r\n\r\n                                $scope.data.mob = response.message;\r\n\r\n                                $scope.oneClick = false;\r\n                                $scope.alertMsgLogin = true;\r\n                                $scope.GenOtp = true;\r\n                                $scope.emailuser = false;\r\n                                $scope.forgtuser = false;\r\n                                $scope.UserPwd = false;\r\n                                $('#otp').removeClass(\"not-active\");\r\n                                $('.z1').removeClass(\"step-on\");\r\n                                $('.z1').addClass(\"step-done\");\r\n\r\n                                $('.z2').addClass(\"step-on\");\r\n                                $('#otp').addClass(\"on-page\");\r\n                                $('#upin').hide();\r\n                                $('#upin1').show();\r\n                                $('#fo-otp').focus();\r\n\t\t\t\t\t\t\t\tvar msg = 'One-Time Password (OTP) has been sent to your registered Email Address (' + ($scope.data.em || '-') + ') and Mobile Number (' + ($scope.data.mob || '-') + ')';\r\n                                var alert_dlg = utilFunctions.createAlert({\r\n                                    \"title\": \"Success : \",\r\n                                    \"type\": \"success\",\r\n                                    \"message\": msg\r\n                                });\r\n                                $('[name=errContainer]').append($compile(alert_dlg)($scope));\r\n\r\n                            }\r\n                        }\r\n                        else{\r\n                            $('#fo-captcha').focus();\r\n                            $scope.errorMsg1 = $scope.trans[\"ERR_SWEB_9000\"]; \r\n                        }\r\n                    }\r\n                }\r\n\r\n\r\n\r\n            }, function (response) {\r\n\r\n            });\r\n\r\n        } else if ($scope.forgotuser_1.user_name.$valid && $scope.forgotuser_1.cap.$valid) {\r\n            if ($scope.forgotuser_1.$setPristine) {\r\n                $scope.forgotuser_1.$setPristine();\r\n                $scope.forgotuser_1.user_name.$setDirty();\r\n                $scope.captchaObj.refresh();\r\n                $('#fo-user').focus();\r\n                $scope.data.captcha = null;\r\n                $scope.alertMsgLogin = false;\r\n                $scope.oneClick = false;\r\n                $scope.errorMsg1 = \"The Provisional ID entered by you doesn’t exists as per our records. Please enter your valid Provisional ID.\";\r\n            }\r\n\r\n        }\r\n        //start defect fix-2491//\r\n        else if (!($scope.validations.gstin($scope.data.username))) {\r\n            if ($scope.forgotuser_1.$setPristine) {\r\n                $scope.forgotuser_1.$setPristine();\r\n                $scope.forgotuser_1.user_name.$setDirty();\r\n                $scope.captchaObj.refresh();\r\n                $('#fo-user').focus();\r\n                $scope.data.captcha = null;\r\n                $scope.data.username = null;\r\n                $scope.alertMsgLogin = false;\r\n                $scope.oneClick = false;\r\n                $scope.errorMsg1 = \"The Provisional ID entered by you doesn’t exists as per our records. Please enter your valid Provisional ID.\";\r\n            }\r\n        }\r\n        //end defect fix-2491//\r\n        else {\r\n            $scope.alertMsgLogin = true;\r\n            $('#fo-user').focus();\r\n        }\r\n        \r\n     $scope.newregclick=function(){\t\t\t\t\r\n\t window.location.href = $scope.servers[\"GST_REGISTRATION_R1_URL\"] + \"/registration/\";\t\t \r\n\t\t\r\n\t}  \r\n\r\n    };\r\n\r\n    //forgotuser validate OTP\r\n    $scope.secProceed = function () {\r\n\r\n        if ($scope.forgotuser_2.e_otp.$valid && $scope.forgotuser_2.cap.$valid) {\r\n            $scope.oneClick = false;\r\n\t\t\t$scope.oneClick1=true;\r\n\t\t\t//$scope.Seccaptcha = true;\r\n\r\n            var details = {\r\n\r\n                otp: $scope.data.eotp,\r\n\t\t\t\tcaptcha: $scope.data.captcha\r\n            };\r\n\r\n\r\n            var otpDetails = JSON.stringify(details);\r\n\r\n\r\n            ajax.post(\"/services/validate/otp\", otpDetails, function () {\r\n                $().blockPage(true);\r\n            }, function () {\r\n                $().blockPage(false);\r\n            }).then(function (response) {\r\n\r\n                if (response.message === \"true\" && response.successCode==null) {\r\n                    if ($scope.forgotuser_2.$setPristine) {\r\n                        $scope.forgotuser_2.$setPristine();\r\n                        $scope.oneClick = false;\r\n                        $('#sec').removeClass(\"not-active\");\r\n                        $('#sec').addClass(\"on-page\");\r\n                        $('#otp').show();\r\n\r\n                        $scope.GenOtp = true;\r\n\r\n                        $scope.alertMsgLogin = true;\r\n                        $('#fo-otp').focus();\r\n                        $scope.usersubmit();\r\n                    }\r\n                } else if (response.errorCode === \"SWEB_8000\") {\r\n                    if ($scope.forgot