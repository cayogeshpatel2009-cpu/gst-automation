s\",\r\n\t\"LBL_EARLIER_REG_NO\":\"Earlier Registration No.\",\r\n\t\"LBL_REG_TYPE\":\"Type Of Earlier Registration(VAT/Excise/Service Tax/ Others)\",\r\n    \"LBL_PROVISIONAL_ID\":\"Provisional ID\",\r\n\t\"LBL_DISP_CIR\":\"Display Circulars\",\r\n    \"LBL_MSG_INF1\":\"should be of 3 to 200 characters, can contain alphabets and special characters(. ')\",\r\n    \"LBL_PREV\":\"Preview\",\r\n    \"LBL_DELETE\":\"Delete\",\r\n    \"LBL_SELE_FRM_DAT\":\"Select From Date\",\r\n    \"LBL_SELE_TO_DAT\":\"Select To Date\",\r\n    \"LBL_ENT_GRIVNUM\":\"Enter Grievance Number\",\r\n    \"LBL_PLS_PROV_GRTRNUM\":\"Please provide the Grievance Tracking Number\",\r\n    \"LBL_SUB_GRIV\":\"Submit Grievance\",\r\n    \"LBL_ENQ_STAT\":\"Enquire Status\",\r\n    \"LBL_SEL_ADATE\":\"Select a Date\",\r\n    \"LBL_MSG_INF2\":\"should be of 3 to 2000 characters, can contain alphabets, numbers and special characters\",\r\n    \"LBL_MSG_INF3\":\"can be 3 to 200 characters long and can contain alphanumeric and special characters(. ')\",\r\n    \"LBL_STATUS_OFCPIN\":\"The status of CPIN\",\r\n    \"LBL_ISNTPAD_GRIVNTRAI\":\"is NOT PAID. Grievance cannot be raised\",\r\n    \"LBL_DUP_CPIN\":\"Duplicate CPIN\",\r\n    \"MSG_FORNEFT_GRVREL\":\"For NEFT/RTGS CPIN, change the grievance related to - 'NEFT/RTGS related issues'\",\r\n    \"ERR_CPIN_ENT_NT\":\"'CPIN entered do not belong to NEFT/RTGS mode of Payment'\",\r\n    \"ERR_CPIN_ENT_DISHON\":\"'Grievance cannot be raised as the status of CPIN is Cheque/DD Dishonored. Please contact the concerned Bank.'\",\r\n    \"ERR_DAT_AMTDEB_CANLESS\":\"'Date on which amount debited cannot be less than Challan creation date'\",\r\n    \"LBL_SAV_WITHCOLON\":\"'SAVE'\",\r\n    \"LBL_CAN_WITHCOLON\":\"'Cancel'\",\r\n    \"LBL_ADD\":\"ADD\",\r\n    \"LBL_ENT_CPIN\":\"Enter CPIN\",\r\n    \"LBL_ENT_UTR\":\"Enter UTR\",\r\n    \"LBL_ENT_BANNAME\":\"Enter Bank Name\",\r\n    \"LBL_SEARC_BNK_NAME\":\"Search Bank Name\",\r\n    \"LBL_ENT_BRN\":\"Enter BRN\",\r\n    \"LBL_ENT_CHK_NUM\":\"Enter Cheque Number\",\r\n    \"LBL_ENT_CHKDD_NUM\":\"Enter Cheque / DD Number\",\r\n    \"LBL_ENT_BRNBAN\":\"Enter BRN / BAN\",\r\n    \"LBL_SEARPAY_GAT\":\"Search Payment Gateway\",\r\n    \"LBL_SEAR_NAME\":\"Search Name\",\r\n    \"ERR_GSTI_PAN_NOTMAT\":\"GSTIN and PAN do not match\",\r\n    \"ERR_CPIN_NOTBELSELSTAT\":\"'CPIN entered do not belong to the selected State'\",\r\n    \"ERR_ENT_PAN\":\"Enter Permanent Account Number (PAN)\",\r\n    \"LBL_DISP_NOTI\":\"Display Notifications\",\r\n    \"ERR_FILL_OTP_SENMOB\":\"Fill OTP sent to Mobile\",\r\n    \"LBL_CLICK_HERETO\":\"Click here to\",\r\n    \"LBL_WITH_NEWCRED\":\"with the new credentials .\",\r\n    \"LBL_SUSCC_CREATED_USER\":\"You have successfully Created the USER.\",\r\n    \"LBL_DISP_PRESREL\":\"Display PressReleases\",\r\n    \"LBL_ALL_STATES\":\"All States\",\r\n    \"LBL_ALL_UNITER\":\"All Union Territories\",\r\n\t\"LBL_CHECK_TIN_6\": \"Check Registration Status\",\r\n\t\"LBL_CHECK_TIN_26\": \"ID Type\",\r\n\t\"LBL_CHECK_TIN_102\": \"Provisional ID\",\r\n\t\"LBL_CHECK_TIN_115\": \"Activated\",\r\n\t\"LBL_CHECK_TIN_116\": \"Provisional\",\r\n\t\"LBL_CHECK_TIN_117\": \"Submitted and Pending for verification\",\r\n\t\"LBL_CHECK_TIN_118\": \"Migrated\",\r\n\t\"LBL_CHECK_TIN_119\": \"Validation Error\",\r\n\t\"LBL_CHECK_TIN_120\": \"Cancelled\",\r\n\t\"LBL_CHECK_TIN_121\": \"Pending Signature\",\r\n\t\"LBL_CHECK_TIN_122\": \"Pending for Processing\",\r\n\t\"LBL_CHECK_TIN_123\": \"Pending for Submission\",\r\n\t\"LBL_CHECK_TIN_124\": \"Approved\",\r\n\t\"LBL_CHECK_TIN_125\": \"Rejected\",\r\n\t\"LBL_CHECK_TIN_126\": \"GSTIN generated for migration\",\r\n\t\"LBL_CHECK_TIN_127\": \"Pending for Clarification\",\r\n\t\"LBL_CHECK_TIN_128\": \"Pending for Order\",\r\n\t\"LBL_CHECK_TIN_129\": \"Submitted for Verification\",\r\n\t\"LBL_CHECK_TIN_130\": \"Response Submitted\",\r\n\t\"LBL_CHECK_TIN_134\": \"Sent to State Authority\",\r\n\t\"LBL_CHECK_TIN_135\": \"Not Applicable\",\r\n\t\"LBL_CHECK_TIN_136\": \"Sent for Clarification\",\r\n\t\"LBL_CHECK_TIN_139\": \"Active Pending Verification\",\r\n\t\"LBL_CHECK_TIN_146\": \"No Records Found\",\r\n\t\"LBL_REF_IMG\": \"Refresh Image\",\r\n\t\"LBL_CHKTIN_TIT1\": \"Provisional ID has been activated and user ID chosen by taxpayer after providing email and mobile number, but Enrolment Form has not been completed and signed\",\r\n\t\"LBL_CHKTIN_TIT2\": \"Provisional ID issued. File Application for Enrolment on GST portal.\",\r\n\t\"LBL_CHKTIN_TIT3\": \"The application is submitted successfully and is being processed. You will be intimated once application is processed\",\r\n\t\"LBL_CHKTIN_TIT4\": \"Enrolment successfully completed after submission of signed Enrolment Form\",\r\n\t\"LBL_CHKTIN_TIT5\": \"PAN details are not matching with Income-tax database or CIN/DIN not matching with MCA database or Aadhaar not matching with Aadhaar database. Email sent with details of error. Please Rectify and Re-submit form on Portal.\",\r\n\t\"LBL_CHKTIN_TIT6\": \"Provisional ID/Enrolment has been cancelled\",\r\n\t\"LBL_CHKTIN_TIT7\": \"Application Filed successfully. Pending with Tax Officer for Processing. Officer has 3 working days to process.\",\r\n\t\"LBL_CHKTIN_TIT8\": \"Application is Approved. GSTIN and password emailed to Applicant.\",\r\n\t\"LBL_CHKTIN_TIT9\": \"Application is Rejected by tax officer.\",\r\n\t\"LBL_CHKTIN_TIT10\": \"Notice for seeking Clarification issued by officer. File Clarification within 7 days of date of notice on portal.\",\r\n\t\"LBL_CHKTIN_TIT11\": \"Clarification Filed successfully by Applicant. Pending with Tax Officer for Order. He has 7 working days to pass order.\",\r\n\t\"LBL_CHKTIN_TIT12\": \"Response Submitted\",\r\n\t\"LBL_CHKTIN_TIT13\": \"Application for Enrolment (including Part-B) Filed successfully. It is pending with Tax Officer for Verification.\",\r\n\t\"LBL_CONSENT_GSTN\": \"GSTN has been assigned the task of collection of data of existing taxpayers under indirect taxes for their smooth transition to GST. Since I would like to continue my business operations under GST regime, I agree to provide details sought by GSTN as per Form devised under the Model Goods and Services Tax Act (GST Act). I understand that the GST Act shall come into force as on  the date to be notified by the Central/ State Government and the provisional registration number issued shall be effective only from the date to be notified.\",\r\n\t\"LBL_CONTINUE\": \"Continue\",\r\n\t\"LBL_CONTACTS_206\": \"Search Result based on Center\",\r\n\t\"LBL_CONTACTS_208\": \"Search Result based on State\",\r\n\t\"LBL_CONTACTS_210\": \"Search is resulting more than 100 records. Please refine your search criteria to view other records.\",\r\n\t\"LBL_CONTACTS_TIT1\": \"Enter Tax Official Name\",\r\n\t\"LBL_DASH_157\": \"View All\",\r\n\t\"LBL_DASH_160\": \"No record found\",\r\n\t\"LBL_DASHGSTP_157\": \"busName\",\r\n\t\"LBL_DASHGSTP_158\": \"uid\",\r\n\t\"LBL_DASHGSTP_97\": \"Taxpayer Classification\",\r\n\t\"LBL_DASHGSTP_34\": \"Pending Requests\",\r\n\t\"LBL_DISENGAGE\": \"Diasengage\",\r\n\t\"LBL_REVO_REQ\": \"Revoke Request\",\r\n\t\"LBL_ENGADIS_70\": \"Enrolment Number / GSTP ID is a mandatory field\",\r\n\t\"LBL_ENGADIS_89\": \"Input should be of minimum 3 characters\",\r\n\t\"LBL_ENGADIS_96\": \"State is mandatory\",\r\n\t\"LBL_SEAR_CRIT\": \"searchCrit\",\r\n\t\"LBL_ENGADIS_140\": \"Search is resulting more than 100 records. Please refine your search criteria to view other records.\",\r\n\t\"LBL_FDBK_MSG\": \"Feedback Message\",\r\n\t\"LBL_WANT_TO_SUB\": \"Do you want to submit the feedback?\",\r\n\t\"LBL_SUB1\": \"Submit\",\r\n\t\"LBL_FRGTPASS_27\": \"The last date for filing Form GST REG-26 for enrolment/ migration of existing taxpayers is over. Since you did not complete the migration process within the allowed period, the Provisional ID has been cancelled. However, you may apply as a new taxpayer at GST portal by\",\r\n\t\"LBL_FRGTPASS_28\": \"Clicking Here\",\r\n\t\"LBL_FRGTPASS_175\": \"Password should be of 8 to 15 characters which should comprise of at least one number, one special character, one upper case and one lower case letter\",\r\n\t\"LBL_FRGTPASS_148\": \"Lower Case\",\r\n\t\"LBL_FRGTPASS_149\": \"Number\",\r\n\t\"LBL_FRGTPASS_151\": \"Upper Case\",\r\n\t\"LBL_FRGTPASS_153\": \"Symbol\",\r\n\t\"LBL_FRGTPASS_154\": \"Min Length\",\r\n\t\"LBL_FRGTPASS_155\": \"Valid Password\",\r\n\t\"LBL_HOLI_LIST\": \"Holiday list\",\r\n\t\"LBL_FILT_BY\": \"Filter by\",\r\n\t\"LBL_YEAR\": \"Year\",\r\n\t\"LBL_PLS_SEL_YEAR\": \"Please select a Year\",\r\n\t\"LBL_HOLID_TYP\": \"Holiday Type\",\r\n\t\"LBL_EXP_ALL\": \"Expand All\",\r\n\t\"LBL_COL_ALL\": \"Collapse All\",\r\n\t\"LBL_LIST1\": \"List\",\r\n\t\"LBL_CALND1\": \"Calendar\",\r\n\t\"LBL_DAT_ANDDAY\": \"Date and Day\",\r\n\t\"LBL_CEN_STAT\": \"Centre / State\",\r\n\t\"LBL_ENTER_LNAME\": \"Enter Legal Name\",\r\n\t\"LBL_PLS_ENTVNAME\": \"Please enter valid name\",\r\n\t\"LBL_PLS_ENT3CHARERR\": \"Please enter atleast 3 characters in legal name\",\r\n\t\"ERR_ENT_VALNAME\": \"Please enter a valid legal name\",\r\n\t\"LBL_NAM_AREA\": \"Name/Area\",\r\n\t\"LBL_EXT_USER\": \"Existing User\",\r\n\t\"LBL_MSG1_LOGIN\": \"If you have already created your Username and Password, click\",\r\n\t\"LBL_MSG1_LOGIN2\": \"here\",\r\n\t\"LBL_MSG1_LOGIN3\": \"to log in.\",\r\n\t\"LBL_ZPRO_IDVERI\": \"Provisional ID Verification\",\r\n\t\"LBL_ENTER_MOB_NUMMSG1\": \"Please enter Mobile Number and Email Address of Primary Authorised Signatory. All future correspondences from the GST portal will be sent on this registered Mobile Number and Email Address only. Changes to this will be non-editable till\",\r\n\t\"LBL_PLSENT_OTP_EMAD\": \"Please enter the OTPs sent to your Email Address\",\r\n\t\"LBL_PLSCHK_SPAMFOL\": \"(Please check Spam Folder too) and Mobile Number\",\r\n\t\"LBL_SUCC_LOGOUT\": \"You have successfully logged out of GST Portal.\",\r\n\t\"LBL_AGN_REQ_SECREAS\": \"again.You are requested to close this page for security reasons.\",\r\n\t\"LBL_SELE_YESNO\": \"Select 'Yes ' or ' No ' to enable or disable API access for your GSTIN/UIN/GSTPID\",\r\n\t\"LBL_SELE_DUR_SESS\": \"Select duration of your session.Your API session will be active during this duration.After this duration you have to initiate a new session by providing OTP again.\",\r\n\t\"LBL_CONF1\": \"Confirm\",\r\n\t\"LBL_DOWNL_FORM\": \"download form\",\r\n\t\"LBL_DOWN_ACKN\": \"download acknowledgement\",\r\n\t\"LBL_DAT_OFSUB\": \"Date of Submission\",\r\n\t\"LBL_APP_TPE\": \"Application Type\",\r\n\t\"LBL_LEGNAME_BUIS\": \"Legal name of Business\",\r\n\t\"LBL_PROV_PEND_SIG\": \"Provisional Pending Signature\",\r\n\t\"LBL_SUBMITED\": \"Submitted\",\r\n\t\"LBL_DELETED\": \"Deleted\",\r\n\t\"LBL_SMAL_EDIT\": \"edit\",\r\n\t\"LBL_FRM_DOWNMESG\": \"Form Download Message\",\r\n\t\"LBL_CAP_OK\": \"OK\",\r\n\t\"LBL_CREATION_DAT\": \"Creation Date\",\r\n\t\"LBL_EXP_DAT\": \"Expiry Date\",\r\n\t\"LBL_DET_OFSTAT\": \"Details of status\",\r\n\t\"LBL_ERR_DET\": \"Error details\",\r\n\t\"LBL_EDIT_1\": \"Edit\",\r\n\t\"LBL_CLICKHERE_REAS1\": \"Click to see the reasons for Errors.\",\r\n\t\"LBL_MYSAVAPPR1_69\": \"Causes of Validation Error\",\r\n\t\"LBL_MYSAVAPPR1_84\": \"To Modify your application please\",\r\n\t\"LBL_MYSAVAPPR1_86\": \"Click Here\",\r\n\t\"LBL_MYSAVAPPR1_88\": \"Or you can Edit it from dashboard by closing this window\",\r\n\t\"LBL_MYSAVAPPR1_99\": \"Close\",\r\n\t\"LBL_MYSAVAPPR1_111\": \"Meaning of status\",\r\n\t\"LBL_MYSAVAPPR1_119\": \"Draft\",\r\n\t\"LBL_MYSAVAPPR1_120\": \"Form is saved, but not submitted. Submit within 15 days of first time save.\",\r\n\t\"LBL_MYSAVAPPR1_123\": \"Pending for Validation\",\r\n\t\"LBL_MYSAVAPPR1_124\": \"Form submitted. Data is being validated from CBDT/MCA/UIDAI as the case may be. Check after some time.\",\r\n\t\"LBL_MYSAVAPPR1_128\": \"PAN details are not matching with Income-tax database or CIN/DIN not matching with MCA database or Aadhaar not matching with Aadhaar database. Email sent with details of error. Please Rectify and Re-submit form on Portal.\",\r\n\t\"LBL_DOYOU_WANT\": \"Do you want to upload json?\",\r\n\t\"LBL_YOUR_ENRO_AUTHSIG\": \"Your enrolment data is already uploaded. Please follow instructions in the email sent to Primary Authorized Signatory.\",\r\n\t\"LBL_SAC1\": \"SAC\",\r\n\t\"LBL_SRCH_BASHSN\": \"Search Result based on HSN Code\",\r\n\t\"LBL_SRCH_BASHSNNAME\": \"Search Result based on HSN Name\",\r\n\t\"LBL_AND_HSNNAME\": \"and HSN Name\",\r\n\t\"LBL_EFF_PERIOD\": \"and Effective Period\",\r\n\t\"LBL_TO1\": \"to\",\r\n\t\"LBL_SEAR_BAS_SERVCLASSCOD\": \"Search Result based on Service Classification Code\",\r\n\t\"LBL_SEAR_BAS_SERVCLASSCODNAM\": \"Search Result based on Service Classification Code Name\",\r\n\t\"LBL_AND_SERV_CLASS\": \"and Service Classification Code Name\",\r\n\t\"LBL_SER_CLAS_CODNAME\": \"Service Classification Code Name\",\r\n\t\"LBL_SEARCH_HSNCHAP\": \"Search HSN Chapter\",\r\n\t\"LBL_SEARC_SER_CLAS_COD\": \"Search Service Classification Codes\",\r\n\t\"LBL_WIOUTAND_HSNNAME\": \"HSN Name\",\r\n\t\"LBL_RES_BASON_GSTUIN\": \"Search Result based on GSTIN/UIN\",\r\n    \"LBL_CURR_FIN_YEAR\":\"Current Financial Year\",\r\n    \"LBL_PREV_FIN_YEAR\":\"Previous Financial Year\",\r\n    \"LBL_SHOW_CALC_FORMULA\":\"Show calculation formula\",\r\n\t\"LBL_INFO_LIAB_PAID\":\"% of Liability paid represents quantum of liability auto populated from GSTR-1 that was declared/paid in GSTR-3B.\",\r\n    \"LBL_FOOTNOTE_LIAB_PAID\":\"Note: Liability percentage is displayed for the periods only after GSTR-1 & GSTR-3B are Filed and GSTR-2B is generated.\",\r\n\t\"LBL_PRINCIPAL\": \"Principal\",\r\n\t\"LBL_ADDITIONAL\": \"Additional\",\r\n    \"LBL_SEAR_RES_BYPAN\":\"Search Result based on PAN\",\r\n\t\"ERR_CURRE_HEAVYSYUSAGE\": \"Currently GST system is facing heavy system usage. In order to provide you with optimal service, we request you to wait for some time.\",\r\n\t\"ERR_INCON_CAUSED\": \"Sorry for the inconvenience caused.\",\r\n\t\"ERR_COM_BACK_WAIT\": \"You can come back later or wait for some time for system to take you to login.\",\r\n\t\"LBL_LAST_ACCESS_TIME\": \"Last access time\",\r\n\t\"LBL_ENTER_LEGNAMEBUIS\": \"Enter Legal Name Of Business\",\r\n\t\"LBL_SUCCES_LOGINMSG\": \"You have successfully logged in. Please choose enrolment data file to be uploaded.  You will receive email on the status of your submission.  Subsequently to edit or view the status of your application, please visit the GST web portal.\",\r\n\t\"LBL_FIR_TIM_LOG\": \"First time login\",\r\n\t\"LBL_LOGIN_FIRST_TIM\": \"If you are logging in for the first time, click\",\r\n\t\"LBL_VER_FOR_MCPTR3\": \"Form GST PCT-05 | [See Rule-83(6)]\",\r\n\t\"LBL_VER_FOR_MCPTR5\": \"Authorisation / withdrawal of authorisation for Goods and Services Tax Practitioner\",\r\n\t\"LBL_VER_FOR_MCPTR9\": \"The Authorized Officer\",\r\n\t\"LBL_VER_FOR_MCPTR10\": \"Central Tax/State Tax.\",\r\n\t\"LBL_VER_FOR_MCPTR13\": \"PART A\",\r\n\t\"LBL_VER_FOR_MCPTR16\": \"Sir / Madam\",\r\n\t\"LBL_DOHERE_BY\": \"do hereby\",\r\n\t\"LBL_I_AM\": \"I\",\r\n\t\"LBL_VER_FOR_MCPTR23\": \"solemnly authorize\",\r\n\t\"LBL_VER_FOR_MCPTR27\": \"withdraw authorization of\",\r\n\t\"LBL_BEAR_ENROL_NUM\": \"bearing Enrolment Number\",\r\n\t\"LBL_FOR_PURP48\": \"for the purposes of Section 48 read with rule 83(6) to perform the following activities on behalf of\",\r\n\t\"LBL_BEAR_GSTIN\": \"bearing GSTIN\",\r\n\t\"LBL_LIST_OF_ACTIVITY\": \"List of Activities\",\r\n\t\"LBL_CHK_BOX\": \"Check Box\",\r\n\t\"LBL_THE_CONS_OFTHE\": \"The consent of the\",\r\n\t\"LBL_ISATTACH_HER\": \"is attached herewith.\",\r\n\t\"LBL_PARTB\": \"PART B\",\r\n\t\"LBL_VER_FOR_MCPTR67\": \"Consent of the Goods and Services Tax Practitioner\",\r\n\t\"LBL_DOHER_SERV_TXPRACT\": \"do hereby solemnly accord my consent to act as the Goods and Services Tax Practitioner on behalf of\",\r\n\t\"LBL_GSTIN_ISO\": \"GSTIN\",\r\n\t\"LBL_ENROL_NUMB\": \"Enrolment Number\",\r\n\t\"LBL_ONL_RESP_ACTISPE\": \"only in respect of the activities specified by\",\r\n\t\"LBL_REJECT1\": \"Reject\",\r\n\t\"LBL_GSTPID\": \"GSTP ID\",\r\n\t\"LBL_NAM_GST_PRACT\": \"Name of GST Practitioner\",\r\n\t\"LBL_ENROLL_AUTH\": \"Enroling Authority\",\r\n\t\"LBL_STAT_UT\": \"State / UT\",\r\n\t\"LBL_DAT_OFENROL\": \"Date of Enrolment\",\r\n\t\"LBL_PROF_ADDRES\": \"Professional Address\",\r\n\t\"LBL_MEMB_TYPE\": \"Membership Type\",\r\n\t\"LBL_GSTPID_STAT\": \"GSTP ID Status\",\r\n\t\"LBL_ENROL_SOUGHT\": \"Enrolment Sought As\",\r\n\t\"LBL_REQ_SUB_PLSAFT\": \"Request has been submitted. Please try after sometime.\",\r\n\t\"LBL_REQ_PROC_AFT\": \"Your request is getting processed. Please try after 10 minutes.\",\r\n\t\"LBL_STCK_INTI_COMSC\": \"Stock intimation for opting Composition Scheme\",\r\n\t\"LBL_APPL_OPT_COMP_LEV\": \"Application to Opt for composition Levy\",\r\n\t\"LBL_NAT_OF_BUIS\": \"Nature of Business\",\r\n\t\"LBL_TIT_FOLOGIN1\": \"Request for form download is submitted\",\r\n\t\"LBL_TIT_FOLOGIN2\": \"Form generation for download is under process, please try after some time\",\r\n\t\"LBL_TIT_FOLOGIN3\": \"Form Download Request Failed\",\r\n\t\"LBL_TIT_FOLOGIN4\": \"Your enrolment data is uploaded successfully. An email is being sent to Primary Authorized Signatory. Please follow the instructions in the email.\",\r\n\t\"LBL_TIT_FOLOGIN5\": \"Success\",\r\n\t\"LBL_TIT_FOLOGIN6\": \"Username and Password have been successfully created. Kindly login using these credentials\",\r\n\t\"LBL_TIT_FOLOGIN7\": \"Registration Number provided is invalid. Please enter valid Registration Number.\",\r\n\t\"LBL_TIT_FOLOGIN8\": \"Enter Provisional ID\",\r\n\t\"LBL_TIT_FOLOGIN9\": \"Provisional ID provided is invalid. Please enter valid Provisional ID\",\r\n\t\"LBL_TIT_FOLOGIN10\": \"PAN number provided is invalid. Please enter valid Permanent Account Number(PAN)\",\r\n\t\"LBL_TIT_FOLOGIN11\": \"OTP is not generated. Kindly click on Generate OTP\",\r\n\t\"LBL_TIT_FOLOGIN12\": \"Your RC under is cancelled, therefore, your Provisional ID stands cancelled. Hence you are not permitted to migrate under GST.\",\r\n\t\"LBL_TIT_FOLOGIN13\": \"One-Time Password (OTP) has been sent to your registered Email Address\",\r\n\t\"LBL_TIT_FOLOGIN14\": \"and Mobile Number\",\r\n\t\"LBL_TIT_FOLOGIN15\": \"The Provisional ID entered by you doesn’t exists as per our records. Please enter your valid Provisional ID.\",\r\n\t\"LBL_TIT_FOLOGIN16\": \"Your Password has expired. Please change your password.\",\r\n\t\"LBL_TIT_FOLOGIN17\": \"Username/Password is not valid or activated. Kindly ensure that Enrolment process for your State is started at GST portal. Refer State specific  Enrolment Schedule available at the portal.\",\r\n\t\"LBL_TIT_FOLOGIN18\": \"Provisional ID entered is already mapped to a username.  Kindly login with valid username.\",\r\n\t\"LBL_TIT_FOLOGIN19\": \"Your password is expired. Please use the below link to regenerate the password\",\r\n\t\"LBL_TIT_FOLOGIN20\": \"Password has been successfully changed.\",\r\n\t\"LBL_TIT_FOLOGIN21\": \"Session expired. Kindly login again\",\r\n\t\"LBL_TIT_FOLOGIN22\": \"Authorized signatory\",\r\n\t\"LBL_TIT_FOLOGIN23\": \"Principal place of business\",\r\n\t\"LBL_TIT_FOLOGIN24\": \"Business Details\",\r\n\t\"LBL_TIT_FOLOGIN25\": \"Bank Accounts\",\r\n\t\"LBL_TIT_FOLOGIN26\": \"Unable to load CAPTCHA image. Please click refresh button to load.\",\r\n\t\"LBL_TIT_FOLOGIN27\": \"Please enter a valid email address\",\r\n\t\"LBL_TIT_FOLOGIN28\": \"Please enter a valid mobile number.\",\r\n\t\"LBL_TIT_FOLOGIN29\": \"OTP is not generated. Kindly click on Continue to regenerate OTP\",\r\n\t\"LBL_TIT_FOLOGIN30\": \"Username is already created.Kindly login with username.\",\r\n\t\"LBL_ERROR1\": \"Error\",\r\n\t\"LBL_SUB_WITEVC\": \"Submit with EVC\",\r\n\t\"LBL_POPERR1\": \"Are you sure you want to accept this request?\",\r\n\t\"LBL_POPERR2\": \"Are you sure you want to reject this request?\",\r\n\t\"LBL_CANCEL1\": \"Cancel\",\r\n\t\"LBL_YOU_HAV_SUCC1\": \"You have successfully accepted the request\",\r\n\t\"LBL_YOU_HAV_SUCC2\": \"You have successfully rejected the request\",\r\n\t\"LBL_ALR_ENGDIS\": \"You have already engaged / sent request to a GST Practitioner (GSTP).\",\r\n\t\"LBL_SEAR_BAS_ONENROL\": \"Search Result based on Enrolment Number / GSTP ID\",\r\n\t\"LBL_POPERR3\": \"Are you sure you want to\",\r\n\t\"LBL_POPERR4\": \"the GST Practitioner ?\",\r\n\t\"LBL_POPERR5\": \"You have successfully withdrawn the request to engage GST Practitioner.\",\r\n\t\"LBL_POPERR6\": \"You have successfully sent request to engage the GST Practitioner and the ARN is\",\r\n\t\"LBL_POPERR7\": \"You have successfully disengaged the GST Practitioner.\",\r\n\t\"LBL_LOAD_CAP\": \"Loading CAPTCHA...\",\r\n\t\"LBL_USER_CHANSUCC\": \"Username and password have been successfully changed. Kindly login using these credentials\",\r\n\t\"LBL_POPERR8\": \"Provisional ID format is incorrect. Kindly enter a valid Provisional ID\",\r\n\t\"LBL_POPERR9\": \"One-Time Password (OTP) has been sent to your registered Email Address\",\r\n\t\"LBL_POPERR10\": \"and Mobile Number -\",\r\n\t\"LBL_POPERR11\": \"Compostion Financial Year changed\",\r\n\t\"LBL_POPERR12\": \"You are not eligible to change the Compostion Financial Year\",\r\n\t\"LBL_SESS_EXP_CLK\": \"Session expired. Click\",\r\n\t\"LBL_TO_LOGAGAIN\": \"to login again\",\r\n\t\"LBL_OTP_INCOR\": \"OTP is Incorrect. Click\",\r\n\t\"LBL_OTP_AUTH_REQ\": \"One-Time Password (OTP) authentication is required as\",\r\n\t\"LBL_GEN_EM_MOB\": \"OTP has been generated and sent to your registered Email Address and Mobile Number\",\r\n\t\"LBL_GEN_EM_MOB1\": \"One-Time Password (OTP) has been sent to your registered Email Address and Mobile Number\",\r\n\t\"LBL_OTP_NOTGEN\": \"OTP is not generated. Kindly click\",\r\n\t\"LBL_THIS_DEL_SUR\": \"This action will delete the draft application. Are you sure you want to continue?\",\r\n\t\"LBL_WAR1\": \"Warning\",\r\n\t\"LBL_LOAD_DOT\": \"Loading...\",\r\n\t\"ERR_UNAB_TORET\": \"Error! Unable to retrieve data . Please Try Again.\",\r\n\t\"LBL_ELE_CASH_LEDG\": \"Electronic Cash Ledger\",\r\n\t\"LBL_ELE_CRED_LEDG\": \"Electronic Credit Ledger\",\r\n\t\"LBL_ELEC_LIAB_REG\": \"Electronic Liability Register (Return related)\",\r\n\t\"LBL_ONE_TXPAY_REMSUC\": \"One of the taxpayer successfully removed from your engaged taxpayers list\",\r\n\t\"LBL_REMO_TAXPAYER\": \"Are you sure you want to remove this taxpayer?\",\r\n\t\"LBL_SEAR_BAS_ONTYP\": \"Search Results based on Type\",\r\n\t\"LBL_ERR_UNBL_TORET_DATA\": \"Error! Unable to retrieve data . Please Try Again.\",\r\n\t\r\n  \"400\": \"OTP is invalid\",\r\n  \"OTP0001\": \"GSTIN is null\",\r\n  \"OTP0002\": \"Url parameter and header GSTIN is not matching\",\r\n  \"OTP0003\": \"Pan number is null\",\r\n  \"OTP0004\": \"formType is null\",\r\n  \"OTP0005\": \"Invalid GSTIN\",\r\n  \"OTP0006\": \"Pan Number not matches with authorised signatory pan number \",\r\n  \"OTP0007\": \"OTP generation failed as OTP server is down. Contact Support\",\r\n  \"OTP0008\": \"Auth Token is null\",\r\n  \"OTP0009\": \"User Name is null\",\r\n  \"OTP0010\": \"User does not have authorized signatory for Given Pan number and GSTIN\",\r\n  \"OTP0011\": \"user session is null for provided auth-token and user name\",\r\n  \"OTP0012\": \"Invalid StateCode\",\r\n  \"OTP0013\": \"Invalid Ipuser\",\r\n  \"OTP0014\": \"Ipuser is null\",\r\n  \"OTP0015\": \"txn is null\",\r\n  \"OTP0016\": \"Invalid FormType\",\r\n  \"OTP0017\": \"Invalid Statcode for given GSTIN\",\r\n  \"OTP0018\": \"User is not authorized to File with EVC Option\",\r\n  \"GRVN_DSC_02\": \"Unable to verify DSC sign for GstinRefId\",\r\n  \"GRVN_DSC_03\": \"Mandatory field missing to sign in payload\",\r\n  \"SWEB_10001\": \"No records found\",\r\n  \"SWEB_8000\": \"System error occured\",\r\n  \"SWEB_9035\": \"Invalid GSTIN\",\r\n  \"SWEB_9021\": \"Session expired. Kindly Login again.\",\r\n  \"SWEB_9004\": \"Please enter a valid email ID\",\r\n  \"FO8001\": \"Malformed Request\",\r\n  \"FO8002\": \"The ARN is invalid. Please enter a valid ARN\",\r\n  \"FO8003\": \"The date format passed in the request is invalid\",\r\n  \"FO8004\": \"Start date passed in the request is a future date\",\r\n  \"FO8005\": \"The end date passed in the request is less than start date.\",\r\n  \"FO8006\": \"The date interval passed in the request is greater than 1 year\",\r\n  \"FO8007\": \"The GSTIN passed in the request is invalid\",\r\n  \"FO8008\": \"END date passed in the request is a future date\",\r\n  \"FO8009\": \"Please enter at least one search criteria\",\r\n  \"FO8010\": \"Please select a To Date\",\r\n  \"FO8011\": \"Please select a From Date\",\r\n  \"FO8012\": \"Both start date and END date passed in the request is a future date\",\r\n  \"FO8013\": \"Invalid Number. Please enter a valid  Enrolment Number GSTP ID\",\r\n  \"FO8014\": \"You have already engaged / sent request to a GST Practitioner (GSTP).\",\r\n  \"FO8015\": \"You cannot disengage the GST Practitioner as you are not engaged with him/her\",\r\n  \"FO8000\": \"No records found\",\r\n  \"TEC1004\": \"An unknown internal error occurred\",\r\n  \"EM_SRS_FO_027_01\": \"Please enter the mandatory fields\",\r\n  \"EM_SRS_FO_027_02\": \"Please enter a tracking number\",\r\n  \"EM_SRS_FO_027_03\": \"The tracking number is invalid. Please enter a valid number.\",\r\n  \"EM_SRS_FO_027_04\": \"From Date cannot be greater than To Date\",\r\n  \"EM_SRS_FO_027_05\": \"From Date cannot be a future Date\",\r\n  \"EM_SRS_FO_027_06\": \"To Date cannot be less than From Date\",\r\n  \"EM_SRS_FO_027_07\": \"To date cannot be a future date\",\r\n  \"EM_SRS_FO_027_08\": \"Please select a To Date\",\r\n  \"EM_SRS_FO_027_09\": \"Please select a From Date\",\r\n  \"EM_SRS_FO_027_10\": \"Please select Date\",\r\n  \"EM_SRS_FO_027_11\": \"The Grievance number is invalid. Please enter a valid Grievance number.\",\r\n  \"EM_SRS_FO_027_12\": \"Invalid Mobile number\",\r\n  \"EM_SRS_FO_027_13\": \"Invalid GSTN.Please enter a valid GSTN\",\r\n  \"EM_SRS_FO_027_14\": \"Grievance cannot be raised against same GSTIN\",\r\n  \r\n  \"EM_SRS_FO_027_17\": \"Invalid Date of realization\",\r\n  \"EM_SRS_FO_027_18\": \"Invalid UTR\",\r\n  \"EM_SRS_FO_027_22\": \"Duplicate Ticket\",\r\n  \"EM_SRS_FO_030_03\": \"Please select a state.\",\r\n  \"SWEB_9001\": \"Please enter the mandatory fields\",\r\n  \"FO9001\": \"Request did not include all the mandatory fields\",\r\n  \"FO9002\": \"The state code passed in the request is invalid\",\r\n  \"FO9015\": \"You are not authorised to view the state code passed in the request.\",\r\n  \"FO9003\": \"The date passed in the request is invalid\",\r\n  \"FO9016\": \"The date passed in the request cannot be before 01 July 2017\",\r\n  \"FO9005\": \"The date passed in the request is a future date\",\r\n  \"FO9010\": \"The end date passed in the request is less than start date.\",\r\n  \"FO9011\": \"The date interval passed in the request is greater than 24 hours\",\r\n  \"FO9007\": \"The status passed in the request is invalid\",\r\n  \"FO9006\": \"The grievance number passed in the request is invalid.\",\r\n  \"FO9008\": \"The comments passed in the request is invalid.\",\r\n  \"FO90121\": \"Grievance against Payment cannot be updated.\",\r\n  \"FO9013\": \"The grievance number doesnot belong to the state.\",\r\n  \"FO9014\": \"Invalid sign value\",\r\n  \"GEN5001\": \"Mandatory parameters missing\",\r\n  \"GEN5002\": \"Unable to process request due to application issue\",\r\n  \"GEN5003\": \"Malformed Request\",\r\n  \"EM_SRS_FO_026_02\": \"The GSTIN/UIN is not valid. Please enter a valid GSTIN/UIN\",\r\n\r\n  \"IM_SRS_FO_001_01\": \"No records found\",\r\n  \"EM_SRS_FO_016_02\": \"Please enter the mandatory fields\",\r\n  \"EM_SRS_FO_016_03\": \"Please enter the Enrolment Number/GSTP ID\",\r\n  \"FO9012\": \"Input should be Alphanumeric of minimum 3 characters\",\r\n  \"IM_SRS_FO_009_01\": \"There are currently no taxpayers.\",\r\n  \"FO8016\": \"No Request is pending for Acceptance\",\r\n  \"SWEB10001\": \"No records found\",\r\n  \"AUTH101\": \"Authentication Failed\",\r\n  \"TEC1003\": \"Header Value Missing\",\r\n  \"SWEB8000\": \"System error occured\",\r\n  \"SWEB_9000\": \"CAPTCHA is invalid\",\r\n  \"AUTH_9002\": \"Invalid User ID or Password. Please try again with correct details\",\r\n  \"SWEB_9003\": \"OTP is Incorrect. Kindly enter again.\",\r\n  \"SWEB_9005\": \"Please enter a valid mobile number.\",\r\n  \"SWEB_9006\": \"Max User Session Count Reached\",\r\n  \"SWEB_9007\": \"Invalid Username. Please try again.\",\r\n  \"SWEB_9008\": \"GSTIN entered is already mapped to a username.  Kindly login  with valid username.\",\r\n  \"SWEB_9009\": \"Username already exists.Kindly choose another username.\",\r\n  \"SWEB_9010\": \"Username should be of 8 to 15 characters (where the minimum length is 8 characters and maximum length is 15 characters) which should start with an alphabet, can be contain alphabets, numbers and special characters (dot [.] or underscore  [_] or hyphen [-])\",\r\n  \"SWEB_9011\": \"Password should be of 8 to 15 characters (where the minimum length is 8 characters and maximum length is 15 characters) which should comprise of at least one number, special character and letters( at least one upper and lower case)\",\r\n  \"SWEB_9012\": \"Token is not generated\",\r\n  \"SWEB_9013\": \"Your password is expired. Please use the below link to regenerate the password\",\r\n  \"SWEB_9014\": \"You have entered a wrong password for 3 consecutive times. Your account has been locked. Kindly access Forgot Password link to reset your password.\",\r\n  \"SWEB_9015\": \"Username and password have been successfully changed. Kindly login using these credentials\",\r\n  \"SWEB_9016\": \"You have successfully logged out of GST Portal.Click here to Login again.You are requested to close this page for security reasons.\",\r\n  \"SWEB_9017\": \"Passwords do not match. Kindly enter again\",\r\n  \"SWEB_9018\": \"Your answer to security question is incorrect. Please try again\",\r\n  \"SWEB_9019\": \"Your password has been successfully reset. Kindly login using the new password\",\r\n  \"SWEB_9020\": \"Username has been emailed to your registered email ID. Kindly check your email\",\r\n  \"SWEB_9022\": \"Password has been successfully changed.\",\r\n  \"SWEB_9023\": \"Passwords do not match. Kindly re-enter the details.\",\r\n  \"SWEB_9024\": \"Please enter the new password and re-confirm new password.\",\r\n  \"SWEB_9025\": \"Invalid Password.\",\r\n  \"SWEB_9027\": \"Password cannot be the same as the last 5 passwords. Please re-enter new password.\",\r\n  \"SWEB_9026\": \"Old Password entered is incorrect\",\r\n  \"SWEB_9028\": \"The email ID entered by you doesn't match our records. Please enter your registered email ID.\",\r\n  \"SWEB_9029\": \"Error in changing password\",\r\n  \"SWEB_9030\": \"The username entered matches the pattern of PAN. Kindly choose a different username\",\r\n  \"SWEB_9031\": \"Username is not created. Kindly contact your jurisdictional tax office to obtain username and password.\",\r\n  \"SWEB_9032\": \"Invalid GSTIN\",\r\n  \"AUTH_9033\": \"User Password has expired. Contact Support.\",\r\n  \"SWEB_9034\": \"Unable to Update Password.\",\r\n  \"AUTH_9035\": \"User Account is locked. Contact Support.\",\r\n  \"SWEB_9036\": \"Password should be of 8 to 15 characters, should comprise of at least one alphabet, one number, once upper case letter, one lower case letter and one special character\",\r\n  \"SWEB_10002\": \"Please enter OTP sent to your registered mobile number and email ID\",\r\n  \"SWEB_10003\": \"Token is regenerated and sent to ur mobile number and email ID\",\r\n  \"S1000\": \"System Error\",\r\n  \"AUTH1000\": \"Invalid Token\",\r\n  \"AUTH1050\": \"Invalid ClientId & Username Combination\",\r\n  \"AUTH1051\": \"Invalid appKey & Authtoken Combination\",\r\n  \"AUTH4032\": \"Invalid USER\",\r\n  \"AUTH4033\": \"Invalid Session\",\r\n  \"AUTH4034\": \"Invalid OTP\",\r\n  \"AUTH4035\": \"Invalid Parameter action in request body\",\r\n  \"AUTH4036\": \"Invalid App Key\",\r\n  \"AUTH4037\": \"API access is not available or user expiry Duration is less than or equal to auth token expiry duration\",\r\n  \"AUTH4038\": \"Session Expired\",\r\n  \"AUTH4039\": \"Invalid Data Object\",\r\n  \"AUTH4040\": \"Malformed Request Detected\",\r\n  \"AUTH4043\": \"USER SESSION LIMIT_EXCEEDED\",\r\n  \"AUTH4041\": \"Invalid Parameter state-cd in request header\",\r\n  \"AUTH4050\": \"Invalid Parameter ip-user in request header\",\r\n  \"AUTH4042\": \"RefreshToken Session Cannot Be Extended\",\r\n  \"AUTH4049\": \"User Session is null\",\r\n  \"TEC4001\": \"OTP generation failed as OTP server is down. Contact Support\",\r\n  \"TEC4002\": \"Invalid Data Format\",\r\n  \"TEC4003\": \"Invalid AppKey\",\r\n  \"TEC4004\": \"Invalid HMAC\",\r\n  \"BOWEB_9033\": \"Invalid Token\",\r\n  \"AUTH403\": \"Maximum session allowed for user with this GSP account exceeded.\",\r\n  \"EM_SRS_FO_030_01\": \"Please enter a search criteria\",\r\n  \"EM_SRS_FO_030_02\": \"Please enter the mandatory fields\",\r\n  \"EM_SRS_FO_030_06\": \"To Date cannot be less than From Date\",\r\n  \"EM_SRS_FO_030_08\": \"Please select a To Date\",\r\n  \"EM_SRS_FO_030_09\": \"Please select a From Date\",\r\n  \"EM_SRS_FO_030_11\": \"Please enter an HSN code or name.\",\r\n  \"EM_SRS_FO_030_12\": \"Please enter an SAC code or name.\",\r\n  \"EM_SRS_FO_013_02\": \"Please select a valid financial year\",\r\n  \"EM_SRS_FO_017_02_CODE\": \"The GSTIN/UIN is invalid. Please enter a valid GSTIN/UIN\",\r\n  \"EM_SRS_FO_027_19\": \"Grievance can be raised after 24 hours of debit of amount\",\r\n  \"EM_SRS_FO_027_20\": \"The status of CPIN <CPIN> is NOT PAID. Grievance cannot be raised \",\r\n  \"EM_SRS_FO_027_21\": \"GSTIN and CPIN do not match\",\r\n  \"GRVN_DSC_01\": \"Your DSC is not affixed to the Form. Please retry\",\r\n  \"GRVN_EVC_01\": \"Invalid Session\",\r\n  \"EM_GRVN_MODE_01\": \"For NEFT/RTGS CPIN, change the grievance related to - 'NEFT/RTGS related issues'\",\r\n  \"EM_GRVN_MODE_02\": \"CPIN entered do not belong to NEFT/RTGS mode of Payment.\",\r\n  \"EM_GRVN_PAN_01\": \"Please enter a valid Pan\",\r\n  \"EM_GRVN_EVC_02\": \"Please submit with DSC. As Company or LLP cannot submit with EVC.\",\r\n  \"EM_SRS_FO_027_23\": \"Invalid PAN for entered GSTIN\",\r\n  \"EM_SRS_FO_027_24\": \"Invalid CPIN for entered State\",\r\n  \"EM_SRS_FO_027_29\": \"Tax Consultant cannot raise grievance against Payments/Ledgers\",\r\n  \"DSC_01\": \"Your DSC is not affixed to the Form. Please retry\",\r\n  \"DSC_02\": \"Signature is Invalid or Corrupted\",\r\n  \"SWEB9035\": \"Invalid GSTIN / Other ID\",\r\n  \"LBL_MSME_MAINHEAD\":\"Vendor List - Accounting and Billing Software Products\",\r\n    \"LBL_ERR_MAINHEAD\":\"Errors Description\",\r\n  \"LBL_MSME_HEAD1\":\"Software Name\",\r\n  \"LBL_MSME_HEAD2\":\"Available Versions\",\r\n  \"LBL_MSME_HEAD3\":\"System Requirement\",\r\n  \"LBL_MSME_HEAD4\":\"Support\",\r\n  \"LBL_MSME_HEAD5\":\"Features Offered(Free of Cost)\",\r\n  \"LBL_MSME_HEAD6\":\"Product Detail & Help Manual\",\r\n  \"LBL_MSME_HEAD7\":\"Download link\",\r\n    \"LBL_ERR_COL1\":\"ERROR CODE\",\r\n    \"LBL_ERR_COL2\":\"ERROR DESCRIPTION\",\r\n    \"LBL_ERR_COL3\":\"REASON FOR ERROR\",\r\n    \"LBL_ERR_COL4\":\"SOLUTIONS\",\r\n  \"LBL_MSME_TBLHEAD\":\"Common Free Features\",\r\n  \"LBL_MSME_CONT1\":\"System should have access for Single User \",\r\n  \"LBL_MSME_CONT2\":\"System should be in English and have all item Units , Financial Years Facility\",\r\n  \"LBL_MSME_CONT3\":\"Supplier, Customers Master Directory with all the required field\",\r\n  \"LBL_MSME_CONT4\":\"Sale / Purchase, Cash Bank Ledger \",\r\n  \"LBL_MSME_CONT5\":\"Should be able to Print invoices and ledger \",\r\n  \"LBL_MSME_CONT6\":\"Should have easy migration of data from one accounting  & billing software  to other accounting & billing software \",\r\n  \"LBL_MSME_CONT7\":\"Item (SKU) Search - Search Item by Bar Code, Short Code or by Description. \",\r\n  \"LBL_MSME_CONT8\":\"Item master with HSN code, description, Unit of measure (UoM), price, tax rate etc. \",\r\n  \"LBL_MSME_CONT9\":\"Taxation – Automatic calculation of Taxes (GST) payable. Rate of tax must be editable in the item master\",\r\n  \"LBL_MSME_CONT10\":\"Charges - Includes other charges in the bill.\",\r\n  \"LBL_MSME_CONT11\":\"Cancelling/ Voiding - Sales Bill can be cancelled any time before submission\",\r\n  \"LBL_MSME_CONT12\":\"Search Bill from history- By customer, date or bill number. Min 3 month period for search. For archival, period will be 5 years. Goods return facility\",\r\n  \"LBL_MSME_CONT13\":\"System should be able to issue/display Credit note Debit note including pending & Replacement Notes\",\r\n  \"LBL_MSME_CONT14\":\"Supplier Selection - Enter purchase bill either by Supplier or Cash Purchase. Manage supplier master.\",\r\n  \"LBL_MSME_CONT15\":\"Generation of purchase order and maintenance of purchase register\",\r\n  \"LBL_MSME_CONT16\":\"Linking of suppliers invoice with Purchase Order\",\r\n  \"LBL_MSME_CONT17\":\"Automated inventory update basis purchase\",\r\n  \"LBL_MSME_CONT18\":\"Taxation – Automated calculation of GST payable per Purchase Order.\",\r\n  \"LBL_MSME_CONT19\":\"Search purchase - By supplier, date and bill number, it also should show supplier Wise .Min 3 month period for search. For archival, period will be 5 years.\",\r\n  \"LBL_MSME_CONT20\":\"Generate Profit and Loss and Balance sheet \",\r\n  \"LBL_MSME_CONT21\":\"Sales/ Purchase Register Report - Detailed, Day wise, Item wise Month wise, Quarter for the period selected.\",\r\n  \"LBL_MSME_CONT22\":\"Sales / Purchase receivable and payable Report\",\r\n  \"LBL_MSME_CONT23\":\"Stock Report ,Return History Report\",\r\n  \"LBL_MSME_CONT24\":\"Cash and bank book \",\r\n  \"LBL_MSME_CONT25\":\"System should be able to export reports and all data to Excel/PDF or any other format as required for returns.\",\r\n  \"LBL_MSME_CONT26\":\"Generate outward supply return like GSTR3B, GSTR-1 ,GSTR-4 , GSTR 9 or any other returns as the case may be\",\r\n  \"LBL_MSME_CONT27\":\"Generating mismatch report between downloaded GSTR2A and Local purchase register to help prepare GSTR2.\",\r\n  \"LBL_MSME_CONT28\":\"Create mismatch report based on GSTR-2A downloaded from GST portal and Purchase register maintained by the system and then create GSTR-2\",\r\n  \"LBL_MSME_CONT29\":\"Create draft Annual Return based on monthly/quarterly returns Filed.\",\r\n  \"LBL_DSCLMR\":\"Disclaimer By GSTN\",\r\n  \"LBL_DCLRTN\":\"Declaration by the Taxpayer\",\r\n  \"LBL_MSME_DSCLMR1\":\"GSTN intends to create an ecosystem to offer Accounting & Billing Software(''Software'') for taxpayers whose annual turnover is less than 1.5 Cr and handling and support thereto vis-a-vis the Software.\",\r\n  \"LBL_MSME_DSCLMR2\":\"GSTN makes no representations or warranty whatsoever about the Accounting & Billing Software(''Software'') which you may access through \",\r\n  \"LBL_MSME_DSCLMR3\":\"(''Website''). When you access the software, please understand it is independent from GSTN, and the GSTN has no control over that Software. GSTN does not endorse or accepts any responsibility the use/misuse by such Software. It is upto you to take necessary precautions. GSTN is not collecting taxpayers' data through the Software in any manner. Please read the terms and conditions of the Software properly before proceeding forward.\",\r\n  \"LBL_MSME_DCLRTN\":\"I hereby declare that my annual turnover is less than Rs. 1.5 Cr. I understand and agree that GSTN should not be liable in any way for the services in respect of Accounting and Billing Software.\",\r\n  \"LBL_ACCPT\":\"Accept\",\r\n  \"LBL_ACC_STA\":\"Account Status\",\r\n  \"LBL_NOTE\":\"Please Note:\",\r\n  \"LBL_NOTE_CONT\":\"In case of non-satisfactory support from product owners, the tax payers may write to GSTN on the mail id (ecosystem@gstn.org.in), highlighting their grievance. Please note that they must write to GSTN only after they have exhausted all the escalation levels provided by vendor.\",\r\n  \"LBL_SRN\": \"SRN/FRN\",\r\n  \"ERR_INV_SRN\": \"Please enter a valid SRN\",\r\n  \"ERR_INV_FRN\": \"Please enter a valid FRN\",\r\n  \"HLP_SRN\": \"Enter SRN/FRN\",\r\n  \"HEAD_SRCH_RSLT_SRN\": \"Search Result based on SRN : \",\r\n  \"HEAD_SRCH_RSLT_FRN\": \"Search Result based on FRN : \",\r\n  \"LBL_SERV_REQ_NO\": \"Service Request Number(SRN)\",\r\n  \"LBL_FINA_REQ_NO\": \"Financial Reference Number (FRN)\",\r\n  \"LBL_SRN_STS\": \"Status of SRN\",\r\n  \"LBL_FRN_STS\": \"Status of FRN\",\r\n  \"LBL_ARN_STS\": \"Status of ARN\",\r\n  \"LBL_PROV_ID\":\"Enter Provisional ID\",\r\n  \"LBL_SEARCH_PROV_ID\":\"Enter Provisional ID of the taxpayer\",\r\n  \"HEAD_SEARCH_STATE\": \"State-wise list of Cancelled Provisional IDs\",\r\n  \"LBL_STATE_WISE\" : \"Click on the State-name to open the list of Cancelled Provisional IDs for that State\",\r\n  \"LBL_STATE_LINK\" : \"For State-wise list of Cancelled Provisional IDs, click here\",\r\n  \"LBL_SEAR_RES_BYPROVID\" : \"Search Result based on Provisional ID\",\r\n  \"LBL_ADHR_STS\" : \"Aadhaar Authentication Status\",\r\n  \"LBL_EKYC_STS\" : \"Pending for Aadhaar e-KYC Authentication\",\r\n  \"LBL_EKYC_STS_DESC\" : \"The links for Aadhaar authentication has been sent on email ids of all Promotors/ Partners/ Authorized Signatories. Kindly do the e-KYC of respective individuals.\",\r\n  \"HLP_ADHR_AUTH_STS\": \"Click here to check the Aadhaar Authentication Status\",\r\n  \"LBL_SELE_FIP_DUR_SESS\": \"Please choose a maximum duration to which you want to share data with these agencies. After this duration these agencies has to again authenticate you through “OTP”.\",\r\n  \"LBL_FIP_API_ENABLE\": \"Do you want to Opt-in for Flow Based Lending\",\r\n  \"LBL_FIP_API_LIST\" : \"Please select data, which you want to share with lending agencies:\",\r\n  \"LBL_SELECT_ALL\" : \"Select All\",\r\n  \"LBL_SELE_FIP_YESNO_ONE\" : \"Select ‘Yes’ for allowing Flow Based lending agencies to access your GST data\",\r\n  \"LBL_SELE_FIP_YESNO_TWO\" : \"(Return and other data selected by you in below section).\",\r\n  \"LBL_SELE_FIP_YESNO_THREE\" : \"Select ‘No’ for not allowing Flow Based lending agencies to access your GST data.\",\r\n  \"LBL_FIP_ERR\" : \"Please select at least one API to enable access to FIP-GSP\",\r\n  \"LBL_PROFILE_INFO_ONE\":\"Profile Data include “Legal Name of GSTIN”, “Principal Place of Business details”, “Phone and email  of GSTIN”, “Additional Place of Business details”, “promoters details along with their photo (except Aadhaar and Passport No)”. \", \r\n  \"LBL_PROFILE_INFO_TWO\": \" to see the complete list of field names shared.\",\r\n  \"LBL_CLICK_HERE\": \"Click here\",\r\n  \"LBL_ADHR_AUTH_STS\" :\"Aadhaar Authentication Status\",\r\n  \"LBL_SEND_VERFY_BTN\":\"Send Verification link\",\r\n  \"LBL_SL_NO\": \"Sl No\",\r\n  \"LBL_REGISTRATION_CERTIFICTION\": \"My Registration Certificate\",\r\n  \"LBL_SEND_ADHR_LINK\" :\"Send Aadhaar Authentication Link\",\r\n  \"LBL_UPLOAD_EKYC\":\"Upload E-KYC Documents\",\r\n  \"LBL_IS_CITIZEN\":\"Citizen/Resident of India\",\r\n  \"LBL_PRO_PAR\":\"Promoter/Partner\",\r\n  \"LBL_PRIM_AUTHSIGN\":\"Primary Authorized Signatory\",\r\n  \"LBL_DSGN\":\"Designation\",\r\n  \"LBL_EMAIL\":\"Email\",\r\n  \"LBL_SELECT_ADHR\" :\"Select\",\r\n  \"LBL_UPLOAD_DOCUMENT\":\"Upload Documents\",\r\n  \"LBL_DOCS_UPLOAD\":\"Documents Upload\",\r\n  \"HLP_MAX_FILE_SIZE\": \"Maximum file size for upload is \",\r\n    \"LBL_TYP_EKYC_DOC\": \"Type of E-KYC Document\",\r\n    \"LBL_EXT_MSG_ADHR\":\"Would you like to Authenticate Aadhaar or Upload E-KYC Documents of Partner/Promoter and Primary Authorized Signatory?\",\r\n    \"LBL_EXT_MSG_ADHR_OPTIN_OPTOUT\":\"Would you like to Authenticate Aadhaar of Partner/Promoter and Primary Authorized Signatory?\",\r\n\t\"NR_SUB_STATUS\": \"ARN Generated – Pending for Processing\",\r\n\t\"NR_SUB_REMARKS\": \"Details shared to taxpayer on email/SMS.Pending with jurisdictional tax authority for action\",\r\n\t\"NR_SPFV_STATUS\": \"Site Verification Assigned\",\r\n\t\"NR_SPFV_REMARKS\": \"Application is marked for Site verification\",\r\n\t\"NR_SCLS_STATUS\": \"Site Verification Completed\",\r\n\t\"NR_SCLS_REMARKS\": \"Site Verification is done.\",\r\n\t\"NR_CLR_STATUS\": \"SCN Raised – Pending for Clarification\",\r\n\t\"NR_CLR_REMARKS\": \"Notice issued, login through TRN and respond to the queries\",\t\r\n\t\"NR_RSB_STATUS\": \"Clarification Filed – Pending for Order\",\r\n\t\"NR_RSB_REMARKS\": \"Task is pending with Officer to take action\",\r\n\t\"NR_VAE_STATUS\": \"Validation Error\",\r\n\t\"NR_VAE_REMARKS\": \"Task is pending with Taxpayer as application is in Validation error\",\r\n\t\"NR_ARS_STATUS\": \"Clarification Not Filed – Pending for Order\",\r\n\t\"NR_ARS_REMARKS\": \"Task is pending with Officer to take action\",\r\n\t\"NR_APR_STATUS\": \"Order Issued – Approved\",\r\n\t\"NR_APR_REMARKS\": \"Application is approved Please check the email for login credentials and password.\",\r\n\t\"NR_RJT_STATUS\": \"Order Issued – Rejected\",\r\n\t\"NR_RJT_REMARKS\": \"Application is Rejected by tax-officer.\",\r\n\t\"NR_PFO_STATUS\": \"Clarification Filed/    Clarification Not Filed – Pending for Order\",\r\n\t\"NR_OAR_STATUS\": \"Order Issued – Approved/   Rejected\",\r\n\t\t\r\n\t\r\n\t\"AC_SUB_STATUS\": \"ARN Generated – Pending for Processing\",\r\n\t\"AC_SUB_REMARKS\": \"Application is pending with the Jurisdictional authority. <Action required within 15 working days>\",\r\n\t\"AC_CLR_STATUS\": \"SCN Raised – Pending for Clarification\",\r\n\t\"AC_CLR_REMARKS\": \"Notice issued, please login and respond to the queries <Taxpayer to respond within 7 working days>\",\t\r\n\t\"AC_RSB_STATUS\": \"Clarification Filed – Pending for Order\",\r\n\t\"AC_RSB_REMARKS\": \"Task is pending with Officer to take action < Officer to take action within 7 working days else it will be deemed approved>\",\r\n\t\"AC_ARS_STATUS\": \"Clarification Not Filed – Pending for Order\",\r\n\t\"AC_ARS_REMARKS\": \"Task is pending with Officer to take action < Officer to take action within 7 working days else it will be deemed approved>\",\r\n\t\"AC_APR_STATUS\": \"Order Issued – Approved\",\r\n\t\"AC_APR_REMARKS\": \"Application is approved by tax-officer.\",\r\n\t\"AC_RJT_STATUS\": \"Order Issued – Rejected\",\r\n\t\"AC_RJT_REMARKS\": \"Application is Rejected by tax-officer.\",\r\n\t\"AC_PFO_STATUS\": \"Clarification Filed/   Clarification Not Filed – Pending for Order\",\r\n\t\"AC_OAR_STATUS\": \"Order Issued – Approved/Rejected\",\r\n\t\"AC_VAE_STATUS\": \"Validation Error\",\r\n\t\"AC_VAE_REMARKS\": \"Task is pending with Taxpayer as application is in Validation error\",\r\n\t\r\n\t\r\n\t\"NC_SUB_STATUS\": \"Application Filed – Pending for Processing\",\r\n\t\"NC_SUB_REMARKS\": \"Non-core Amendment application Filed. It will be deemed approved by the system.\",\r\n\t\"NC_APR_STATUS\": \"Approved\",\r\n\t\"NC_APR_REMARKS\": \"Non core Amendment application approved\",\r\n\t\r\n\t\"SC_CLR_STATUS\": \"SCN Issued – Pending for Clarification\",\r\n\t\"SC_CLR_REMARKS\": \"Suo moto cancellation is initiated by Tax officer. GSTIN is suspended. Reply to be submitted within 7 working days.\",\r\n\t\"SC_RSB_STATUS\":\"Clarification Filed - Pending for Order\",\r\n\t\"SC_RSB_REMARKS\": \"Officer to take action\",\r\n\t\"SC_ARS_STATUS\":\"Clarification Not Filed - Pending for Order\",\r\n\t\"SC_ARS_REMARKS\": \"Officer to take action\",\r\n\t\"SC_APR_STATUS\": \"Order Issued - Proceeding Dropped\",\r\n\t\"SC_APR_REMARKS\": \"Proceeding dropped\",\r\n    \"SC_APR_RMRKS\" : \"Cancellation proceeding dropped\",\r\n\t\"SC_RJT_STATUS\": \"Order Issued - Rejected\",\r\n\t\"SC_RJT_REMARKS\": \"Registration cancelled\",\r\n    \"SC_RJT_RMRKS\" : \"Clarification Rejected\",\r\n    \"SC_RJT_RMRK\" : \"Clarification Not Filed - Clarification Rejected\",\r\n\t\"SC_PFO_STATUS\": \"Clarification Filed/   Clarification Not Filed – Pending for Order\",\r\n\t\"SC_OAR_STATUS\": \"Order Issued\",\r\n\r\n\t\"RV_SUB_STATUS\": \"Revocation application Filed and Pending for processing\",\r\n\t\"RV_SUB_REMARKS\": \"Application for Revocation of GSTIN has been Filed and it is with Jurisdictional authority for processing. < 7 working days for action by Officer>\",\r\n\t\"RV_CLR_STATUS\": \"SCN Raised – Pending for Clarification\",\r\n\t\"RV_CLR_REMARKS\": \"Notice issued on the application Filed. <Taxpayer need to response within 7 working days>\",\r\n\t\"RV_RSB_STATUS\": \"Clarification Filed – Pending for Order\",\r\n\t\"RV_RSB_REMARKS\": \"Pending with Officer for Order\",\r\n\t\"RV_ARS_STATUS\": \"Clarification Not Filed – Pending for Order\",\r\n\t\"RV_ARS_REMARKS\": \"Pending with Officer for Order\",\r\n\t\"RV_APR_STATUS\": \"Order Issued for Revocation\",\r\n\t\"RV_APR_REMARKS\": \"Information communicated Application approved\",\r\n\t\"RV_RJT_STATUS\": \"Order Issued for Rejection\",\r\n\t\"RV_RJT_REMARKS\": \"Information communicated Application rejected \",\r\n\t\"RV_PFO_STATUS\": \"Clarification Filed/   Clarification Not Filed – Pending for Order\",\r\n\t\"RV_OAR_STATUS\": \"Order Issued for Revocation/Rejection\",\r\n    \"RV_HSB_STATUS\":\"Condonation for delay filled and Pending for processing with Higher Authority \",\r\n    \"RV_HSB_REMARKS\":\"Application for Revocation of GSTIN has been Filed and it is with Higher Authority. < 7 working days for action by Officer>\",\r\n    \"RV_HCL_STATUS\":\"SCN Raised – Pending for first Clarification\",\r\n    \"RV_HCL_REMARKS\":\"Notice issued on the application Filed. <Taxpayer need to response within 7 working days>\",\r\n    \"RV_HRS_STATUS\":\"Clarification Filed - Pending for First Order\",\r\n    \"RV_HRS_REMARKS\":\"Pending with Higher Authority for Order\",\r\n    \"RV_HAR_STATUS\":\"Clarification Not Filed – Pending for First Order\",\r\n    \"RV_HAR_REMARKS\":\"Pending with Higher Authority for Order\",\r\n    \"RV_HPO_STATUS\" :\"Clarification Filed/Clarification Not Filed – Pending for First Order\",\r\n    \"RV_HOR_STATUS\" :\"Revocation application Filed and Pending for processing/ Condonation of delay Rejected\",\r\n    \"RV_HRJ_STATUS\": \"Condonation of delay Rejected\",\r\n\t\"RV_HRJ_REMARKS\": \"Information communicated Application rejected \",\r\n\r\n\t\"C_SUB_STATUS\": \"Application for Cancellation Filed and pending for Processing\",\r\n\t\"C_SUB_REMARKS\": \"Application for cancellation of GSTIN has been Filed and it is with Jurisdictional authority for action. GSTIN is suspended\",\r\n\t\"C_CLR_STATUS\": \"SCN Raised – Pending for Clarification\",\r\n\t\"C_CLR_REMARKS\": \"Notice issued on the application Filed.\",\t\r\n\t\"C_RSB_STATUS\": \"Clarification Filed – Pending for Order\",\r\n\t\"C_RSB_REMARKS\": \"Task is pending with Officer to take action\",\r\n\t\"C_ARS_STATUS\": \"Clarification Not Filed – Pending for Order\",\r\n\t\"C_ARS_REMARKS\": \"Task is pending with Officer to take action\",\r\n\t\"C_APR_STATUS\": \"Order Issued – Approved\",\r\n\t\"C_APR_REMARKS\": \"Registration is Cancelled.\",\r\n    \"C_APR_RMRKS\" : \"Cancellation Application is rejected.\",\r\n\t\"C_RJT_STATUS\": \"Order Issued – Rejected\",\r\n\t\"C_RJT_SC_STATUS\": \"Registration Cancelled\",\r\n    \"C_RJT_SC_RMRKS\" : \"Cancellation Application is Processed.\",\r\n\t\"C_RJT_REMARKS\": \"Cancellation Application is rejected.\",\r\n    \"C_RJT_RMRKS\" : \"Cancellation Restored\",\r\n\t\"C_PFO_STATUS\": \"Clarification Filed/    Clarification Not Filed – Pending for Order\",\r\n\t\"C_OAR_STATUS\": \"Order Issued – Approved/Rejected\",\r\n    \"W_PFO_STATUS\": \"Clarification filed/    Clarification Not Filed – Pending for Order\",\r\n    \"W_OAR_STATUS\": \"Order Issued – Approved/Rejected\",\r\n    \"PANMC_SUB_STATUS\": \"ARN Generated – Pending for Processing\",\r\n    \"PANMC_SUB_REMARKS\": \"Details submitted to Jurisdictional officer for appropriate action.\",\r\n    \"PANMC_APR_STATUS\": \"Action Taken - Accepted\",\r\n    \"PANMC_APR_REMARKS\": \"Based on your Complaint appropriate action has been initiated\", \r\n    \"PANMC_RJT_STATUS\": \"Action Taken - Rejected\",\r\n    \"PANMC_RJT_REMARKS\": \"Your Complaint is rejected after the examination\", \r\n    \"PANMC_OAR_STATUS\": \"Action Taken - Accepted/Rejected\",\r\n\t\r\n\t\"SRN_PND_STATUS\":\"Pending with MCA\",\r\n\t\"FRN_PND_STATUS\":\"Pending with IFSCA\",\r\n     \"SRN_PND_REMARKS\":\"Application is pending with MCA\",\r\n\t\"FRN_PND_REMARKS\":\"Application is pending with IFSCA.\",\r\n\t\"SRN_PND_ARN_STATUS\":\"NA\",\r\n\t\"FRN_PND_ARN_STATUS\":\"NA\",\r\n\t\"SRN_DFT_STATUS\":\"- COI issued by MCA - TRN {{trn1}} generated – Pending with GST common portal\",\r\n\t\"FRN_DFT_STATUS\":\"TRN {{trn1}} Generated – Pending with GST Common Portal\",\r\n\t\"SRN_DFT_REMARKS\":\"COI is issued by MCA and TRN is generated in GST portal\",\r\n\t\"FRN_DFT_REMARKS\":\"TRN is Generated in GST Portal.\",\r\n\t\"SRN_DFT_ARN_STATUS\":\"NA\",\r\n\t\"FRN_DFT_ARN_STATUS\":\"NA\",\r\n\t\"SRN_SUB_STATUS\":\"- COI issued by MCA - Pending for Processing by GST common portal\",\r\n\t\"FRN_SUB_STATUS\":\"Pending for Processing by GST Common Portal\",\r\n\t\"SRN_SUB_REMARKS\":\"COI is issued by MCA and application is pending for processing with Tax-officer in GST portal\",\r\n\t\"FRN_SUB_REMARKS\":\"Application is pending for processing with Tax-officer in GST Portal.\",\r\n\t\"SRN_SUB_ARN_STATUS\": \"Pending for Processing\",\r\n\t\"FRN_SUB_ARN_STATUS\": \"Pending for Processing\",\r\n\t\"SRN_APR_STATUS\":\"COI issued by MCA - Approved by GST common portal\",\r\n\t\"FRN_APR_STATUS\":\"Approved by GST Common Portal\",\r\n\t\"SRN_APR_REMARKS\":\"- COI is issued by MCA and GST application has been approved by the tax-officer. GSTIN login credentials shared through email.\",\r\n\t\"FRN_APR_REMARKS\":\"GST application has been approved by the Tax-officer. GSTIN login credentials shared through email.\",\r\n\t\"SRN_APR_ARN_STATUS\": \"Approved\",\r\n\t\"FRN_APR_ARN_STATUS\": \"Approved\",\r\n\t\"SRN_RJT_STATUS\":\"COI issued by MCA - Rejected by GST common portal\",\r\n\t\"FRN_RJT_STATUS\":\"Rejected by GST Common Portal\",\r\n\t\"SRN_RJT_REMARKS\":\"- COI is issued by MCA and GST Application has been rejected by the tax-officer\",\r\n\t\"FRN_RJT_REMARKS\":\"GST Application has been rejected by the Tax-officer.\",\r\n\t\"SRN_RJT_ARN_STATUS\": \"Rejected\",\r\n     \"FRN_RJT_ARN_STATUS\": \"Rejected\",\t\r\n\t\"SRN_OAR_STATUS\": \"COI issued by MCA - Approved/Rejected by GST common portal\",\r\n\t\"FRN_OAR_STATUS\": \"Approved/Rejected by GST Common Portal\",\r\n\t\"LBL_WHR_ADHR_AUTH\": \"Whether Aadhaar Authenticated?\",\r\n    \"LBL_EKYC_VERF_STS\": \"Whether e-KYC Verified?\",\r\n    \"INF_COMP_RATNG\": \"The Compliance rating indicates the overall compliance behavior of the taxpayer<br> with respect to return filing. Higher the rating, more compliant is the taxpayer\",\r\n    \"LBL_CORE_BUSS_STS\": \"Core Business Activity Status\",\r\n    \"LBL_BUS_ACTIVITY\": \"Your Current Core Business Activity is -\",\r\n    \"LBL_SELECTION\" : \"If you wish to change your Core Business Activity Kindly select one and Submit again.\",\r\n    \"LBL_SELECT_COREBUSINESS\" : \"Please Identify your Core business as\",\r\n    \"LBL_SELECT_ONE\" : \"Only one selection is allowed\",\r\n    \"LBL_NOTES\" : \"NOTES:\",\r\n    \"LBL_NOTES1\" : \"1. You can select only one core business activity.\",\r\n    \"LBL_NOTES2\" : \"2. In case all activities are applicable to you, Kindly select your core business activity.\",\r\n    \"LBL_NOTES3\" : \"3. Others will include Work Contract and Other Miscellaneous items.\",\r\n    \"LBL_NOTES4\" : \"4. In order to understand the definitions of Manufacturer/Trader/Service Provider, you can click on “Information Button”.\",\r\n    \"LBL_POP_HEADER\" : \"Meaning of Manufacturer, Trader and Service Provider\",\r\n    \"LBL_MANUFACTURER\" : \"MANUFACTURER\",\r\n    \"LBL_MANUFACTURER_DESC\" : \"A manufacturer is a registered person produces new products from raw materials and components using tools, equipment’s and machines and then sells them to the consumers, wholesalers, distributors, retailers or to the other manufacturers. A manufacturer may sell some more brought out items or may provide some ancillary services with his manufactured goods, but he would continue to be classified as manufacturer because it is the Primary Business Activity.\",\r\n    \"LBL_TRADER\" : \"TRADER\",\r\n    \"LBL_TRADER_DESC1\" : \"A trader is a registered person who engages in the buying and selling of goods.\",\r\n    \"LBL_TRADER_DESC2\" : \"Traders have been further classified as -\",\r\n    \"LBL_TRADER_DESC3\" : \"Wholesaler or Distributor\",\r\n    \"LBL_TRADER_DESC4\" : \"Retailer\",\r\n    \"LBL_TRADER_DESC5\" : \"Retailer includes a registered person selling goods through e-commerce operators.\",\r\n    \"LBL_SERVICEPROVIDER\" : \"SERVICE PROVIDER AND OTHERS\",\r\n    \"LBL_SERVICEPROVIDER_DESC\" : \"A service provider is a registered person who provides service to a recipient of service and is neither a manufacturer nor a trader.\",\r\n    \"LBL_SERVICEPROVIDER_DESC1\" : \"e.g. Banking service, IT service, works-contract service, agents, intermediaries, GTAs etc.\",\r\n    \"LBL_CHAR\" : \"Characters upto 1000 field\",\r\n    \"LBL_REASON\" : \"Reason for Change of Core Business Activity\",\r\n    \"LBL_OPT_ADHR\": \"Opted for Aadhaar Authentication\",\r\n    \"LBL_NTR_CORE_BUSS\": \"Nature Of Core Business Activity\",\r\n    \"LBL_NA\" :\"NA\",\r\n    \"ADHR_MYPROFILE_TCS\": \"Aadhaar Authentication facility is available. Would you like to Authenticate Aadhaar of the Primary Authorized Signatory?\",\r\n    \"ADHR_SEND_VER_LINK_SCS_MSG_NT\": \"Aadhaar Authentication Link shared on the Email and Mobile Number registered with GST of the selected Promoter/Partner and Primary Authorized Signatory.\",\r\n\t\"ADHR_SEND_VER_LINK_SCS_MSG_RF_EX\": \"Aadhaar Authentication Link shared on the Email and Mobile Number registered with GST of the selected Promoter/Partner and Primary Authorized Signatory.\",\r\n\t\"RESEND_VERIFICATION_MESG_RF_EX\": \"Aadhaar Authentication Link reshared on the Email and Mobile Number registered with GST of the selected Promoter/Partner and Primary Authorized Signatory.\",\r\n\t\"ADHR_SEND_VER_LINK_SCS_MSG_TPCAEX\": \"Aadhaar Authentication Link shared on the Email and Mobile Number registered with GST of the selected Promoter/Partner and Primary Authorized Signatory.\",\r\n    \"RESEND_VERIFICATION_MESG_TPCAEX\": \"Aadhaar Authentication Link reshared on the Email and Mobile Number registered with GST of the selected Promoter/Partner and Primary Authorized Signatory.\",\r\n    \"ADHR_SEND_VER_LINK_SCS_MSG_TCS\": \"Aadhaar Authentication link are shared on the Email and Mobile Number registered with GST of the Primary Authorized Signatory.\",\r\n\t\"LBL_EKYC_STS_TCS_DESC\" : \"The link for Aadhaar authentication has been sent on email id of Primary Authorized signatory. Kindly do the e-KYC of respective individual.\",\r\n    \"ADHR_MYPROFILETAB_TCS\": \"Would You Like to Authenticate Aadhaar or Upload E-KYC Documents of Primary Authorized Signatory?\",\r\n    \"LBL_GSTN_CMPLNT\": \"Kindly select GSTIN which you want to report on the GST Portal.\",\r\n    \"LBL_REPORT\": \"Report\",\r\n    \"LBL_NM_EM_MB\":\"Kindly validate your email and mobile number.\",\r\n    \"HLP_OTP_EMAIL\": \"Enter OTP sent to your Email Address\",\r\n    \"HLP_OTP_MOBILE\": \"Enter OTP sent to your Mobile Number\",\r\n    \"LBL_OTP_RSND\": \"Need OTP to be resent? Click here\",\r\n    \"ERR_INV_MBNO\" : \"Invalid Mobile Number\",\r\n    \"ERR_INV_EM\" : \"Invalid Email Address\",\r\n\t\"HLP_OTP_MAIL_HELP\": \"OTP will be sent to this Email Address\",\r\n    \"LBL_LGL_PAN\": \"Legal Name as per PAN\",\r\n    \"LBL_YOUR_NM\": \"Your Name\",\r\n    \"HLP_YOUR_NM\" : \"Enter your own Name\",\r\n    \"LBL_SLCT_RPT\" : \"Select to Report\",\r\n    \"LBL_OTP_SUC\" : \"Your OTP has been verified successfully. Kindly\",\r\n    \"LBL_CLK_HRE\" : \"CLICK HERE\",\r\n    \"LBL_CPMLT_ADHR\" :\"to complete your Aadhaar Authentication Process.\",\r\n\t\"LBL_YR_DOB\": \"Your Date of Birth\",\r\n\t\"HLP_DT_FRMT\": \"DD/MM/YYYY\",\r\n\t\"ERR_INV_DATE\": \"Invalid Date\",\r\n    \"ERR_INV_MIN_DOB\": \"It can't be 150 years before\",\r\n\t\"ERR_INV_MAX_DOB\": \"Future Date is not allowed. Please enter valid Date\",\r\n\t\"ERR_MINOR\": \"Complainant cannot not be a minor\",\r\n\t\"LBL_YR_ADD\": \"Your Address\",\r\n\t\"HLP_YR_ADD\": \"Enter your own Address\",\r\n    \"BNK_POP_MSG\" : \"As per Rule 10A, it is mandatory to furnish the bank account details within 30 days from date of grant of registration or before furnishing the details of outward supplies under section 37 in FORM GSTR-1 or using invoice furnishing facility (if applicable) whichever is earlier.\",    \r\n    \"BNK_POP_MSG_EX\" : \"You have crossed the time period to provide bank account details in your registration details. Please add the bank account details immediately otherwise your registration may be cancelled by the Proper Officer.\",\r\n    \"BNK_SUB_MSG_CANCEL\" : \"Kindly update your Bank Account details immediately.\",\r\n    \"BNK_SUB_MSG_EXP\": \"Kindly update your bank account immediately. GSTIN Registration may be cancelled if such details are not updated.\",\r\n    \"BNK_SUB_MSG_EX\" : \"Please ensure that added bank account is linked with the PAN of the business. To proceed further click here.\",\r\n     \"BNK_SUB_MSG_TP1\" : \"Now you are left with \",\r\n    \"BNK_SUB_MSG_TP2\" : \" days as on today to furnish the bank account details. GSTIN Registration may be cancelled if such details are not updated within the timeline.\",    \r\n    \"BNK_SALUTE\" : \"Dear Taxpayer,\",\r\n    \"OLD_BNK_MSG1\" : \"You have not entered your bank account details to your \", \r\n    \"OLD_BNK_MSG2\" : \". Please enter your Bank Account details by filing Application for Amendment (non-core) now to proceed further.\",\r\n\t\"LBL_APCN_WTHDRW\" : \"withdraw\",\r\n    \"LBL_APCN_WTHDRW_TT\" : \"Click to withdraw your Registration Cancellation Application\",\r\n    \"LBL_CANCEL\" : \"Cancel\",\r\n    \"LBL_WTHDRW_WARN\" : \"Are you sure you want to withdraw your Application of Cancellation of Registration?\",\r\n    \"LBL_CONFIRM\" : \"Confirmation\",\r\n    \"LBL_WTHDRW_CNFRM_PT1\" : \"Your Application No. \",\r\n    \"LBL_WTHDRW_CNFRM_PT2\" : \" for cancellation of Registration has been successfully withdrawn and your status has been reverted back to Active from suspended State.\",\r\n    \"WDR_MSG1\" : \"To withdraw your Application for Cancellation of Registration, click on withdraw button.\",\r\n    \"WDR_MSG2\" : \"Application for cancellation of registration cannot be withdrawn as tax officer has initiated action on the application.\",\r\n    \"C_WDR_STATUS\" : \"Withdrawn\",\r\n    \"C_WDR_REMARKS\" : \"Application is withdrawn by the Applicant/Tax payer\",\r\n    \"HLP_ENROLMENT_ID\":\"Enter Aadhaar Enrolment ID\",\r\n    \"LBL_ADH_ENRL_ID\" : \"Aadhaar Enrolment ID\",\r\n    \"ERR_ADH_ENRL_ID\" : \"Please enter valid Enrolment ID\",\r\n    \"LBL_ENRO_INFO\" :\"Aadhaar Enrolment ID slip is mandatorily required to be uploaded along with any other supporting document.\",\r\n    \"ERR_ADH_ENRL_MAND\" : \"Enrolment ID is mandatory\",\r\n    \"ERR_INV_DT_TM\" : \"Invalid Date and Time\",\r\n    \"ERR_FUT_DT_TM\" : \"It cannot be future Date and Time\",\r\n    \"ERR_PAST_DT_TM\" : \"It cannot be prior to 90 days\",\r\n    \"LBL_OK\": \"OK\",\r\n\t\"HLBL_TEMPORARY_ID\" : \"Enter Temporary ID\",\r\n    \"LBL_TEMPORARY_ID\" : \"Temporary ID\",\r\n    \"LBL_FORM\" : \"Form\",\r\n    \"LBL_MODULE\" : \"Module\",\r\n    \"LBL_CREATED_BY\" : \"Created By\",\r\n    \"LBL_DATE_OF_CREATION\" : \"Date of Creation\",\r\n    \"LBL_MORE_DETAILS_LINK\" : \"Click here for more details\",\r\n    \"LBL_TMPREGNUM\":\"Temporary Registration Number\",\r\n    \"LBL_TMPREG_REGNUM\":\"Registration No./ Temporary ID\",\r\n    \"LBL_TMPREG_EFFDATE\":\"Effective Date of Registration/Temporary ID \",\r\n    \"LBL_TMPREG_RSN\":\"Reasons for Temporary Registration \",\r\n    \"LBL_TMPREG_GENDER\":\"Gender\",\r\n    \"LBL_TMPREG_DOB\":\"Date of Birth\",\r\n    \"LBL_FATHERNAME\":\"Father's Name\",\r\n    \"LBL_ADDR_OF_PERSON\":\"Address of the person*\",\r\n    \"LBL_BUILDING_NO\":\"Building No. / Flat No.\",\r\n    \"LBL_FLOORNUM\":\"Floor No.\",\r\n    \"LBL_NAME_OF_THE_PREMISES\":\"Name of the Premises / Building\",\r\n    \"LBL_ROAD_STREET\":\"Road / Street\",\r\n    \"LBL_CITY_TOWN_VLGE\":\"City / Town / Locality /Village\",\r\n    \"LBL_PINCode\":\"PIN Code\",\r\n    \"LBL_TMPREG_PAN\":\"PAN of the Person\",\r\n    \"LBL_TMPREG_OTHR\":\"Other ID (Voter ID No. / Passport No. / Driving License No. / Aadhar No. / Other)\",\r\n    \"LBL_TMPREG_ATTACHMENT\":\"Attachment:\",\r\n    \"LBL_TMPREG_DTLSDOCSEIZ\":\"Details of Documents seized\",\r\n\t\"LBL_ADDRESS\": \"Address\",\r\n\t\"LBL_STAK_ACT_DEC\": \"Activate/ Deactivate STAK\",\r\n\t\"LBL_STAK_SL\": \"S.No\",\r\n\t\"LBL_STAK_NAME\": \"Name\",\r\n\t\"LBL_STAK_PAN\": \"PAN\",\r\n\t\"LBL_STAK_MN\": \"Mobile Number\",\r\n\t\"LBL_STAK_DID\": \"Device Id\",\r\n\t\"LBL_STAK_OS\": \"OS\",\r\n\t\"LBL_STAK_STATUS\": \"Status\",\r\n\t\"LBL_STAK_ACTION\": \"Action\",\r\n    \"LBL_ACTIVATE\" : \"Activate\",\r\n    \"LBL_DEACTIVATE\" : \"Deactivate\",\r\n\t\"LBL_STAK_NOTFOUND\": \"PAN and Mobile Number not registeed with STAK Application\",\r\n\t\"LBL_BIO_STS\":\"Pending for Biometric Authentication\",\r\n\t\"LBL_BIO_STS_DESC\":\"You are requested to get your Biometric Authentication done for Promoter/Partner and Primary Authorized Signatory by visiting the designated GST Suvidha Kendra within the expiry date (15 days from date of submission of Part B of Form Reg 01) so that the registration process may be completed.\",\r\n\t\"LBL_BIO_DOC_STS\":\"Biometric Verified, Document Verification Required\",\r\n\t\"LBL_BIO_DOCSTS_DESC\":\"Your Biometric Verification is already completed. You are requested to get your document verification done for PAS only by visiting the designated GST Suvidha Kendra within the expiry date (15 days from date of submission of Part B of Form Reg 01) so that the registration process may be completed.\",\r\n\t\"LBL_BIO_NOCASE_STS\":\"Pending Document Verification\",\r\n\t\"LBL_BIO_NOCASE_DESC\":\"You are requested to get your Photo Capture and Document Verification done for Promoter/Partner and Primary Authorized Signatory by visiting the designated GST Suvidha Kendra within the expiry date (15 days from date of submission of Part B of Form REG 01) so that the registration process may be completed.\",\r\n\t\"LBL_BIO_ARNGEN_STS\":\"ARN Not Generated\",\r\n\t\"LBL_BIO_ARNGEN_DESC\":\"You have not visited the GST Suvidha Kendra within the expiry date (15 days from date of submission of Part B of Form REG 01) or you have visited the GST Suvidha Kendra but Biometric Authentication/Document Verification is failed or not completed or you have availed option under Rule 14A and Aadhaar Authentication is failed or not completed within expiry date.\",\r\n\t\"LBL_MYSAVE_BIO_NOTE\":\"ARN will not be generated if you have not visited the GSK within expiry date (15 days from date of submission of Part B of Form REG 01) or if you have visited GSK but Biometric Authentication/Document Verification is failed or not completed.\",\r\n\t\"LBL_MYSAVE_BIO_NOTE_NO\":\"ARN will not be generated if you have not visited the GSK within expiry date (15 days from date of submission of Part B of Form REG 01) or if you have visited GSK but Photo is not captured and/or documents which are required to be shown at GSK are not successfully verified.\",\r\n\t\"LBL_MYSAVE_BIO_NOTE_NO1\":\"ARN will not be generated if you have not visited the GSK within expiry date (15 days from date of submission of Part B of Form REG 01) or if you have visited GSK but Biometric Authentication/Document Verification is failed or not completed or if you have availed option under Rule 14A and Aadhaar Authentication is failed or not completed within expiry date.\",\r\n    \"HLP_BIO_AUTH_STS\": \"Click here to check the Biometric Authentication Status\",\r\n\t\"HLP_BIO_NO_AUTH_STS\":\"Click here to check the Document Verification Status\",\r\n\t\"LBL_MYSAVE_BIO_NOTE\":\"ARN will not be generated if you have not visited the GSK within expiry date (15 days from date of submission of Part B of Form Reg 01) or if you have visited GSK but Biometric Authentication/Document Verification is failed or not completed.\",\r\n\t\"LBL_INFORMATION\": \"Information\",\r\n    \"LBL_INF_DISABILITY\":\"This facility is only applicable to the persons falling under section 25(6D) of the CGST Act. Kindly upload necessary document/certificate issued on this behalf by the Government/Competent Authority.\",\r\n\t\"LBL_DISABILITY\":\"Person exempted u/s 25(6D) of the Act\",\r\n    \"LBL_AUTODROP_MSG\" : \"since you have not filed all returns. Once the due returns are filed, proceedings will be dropped for cancellation of the GSTIN within 15 minutes. In case if it is not dropped automatically, you can click on the button to initiate drop proceeding.\",\r\n    \"LBL_AUTODROP_MSG2\" : \" because of non-furnishing of bank account details as per Rule 10A. Once the bank account details are updated, proceedings for cancellation of registration will be dropped within 15 minutes.  If the proceedings are not dropped automatically, click on the “Initiate Drop Proceedings” button to initiate drop proceedings.\",\r\n\t\"LBL_UNREG_USER\":\"Unregistered Applicant\",\r\n\t\"ADHR_SEND_VER_LINK_SCS_MSG_RF\": \"Aadhaar Authentication link are shared on the Email and Mobile Number registered with GST of the Unregistered Applicant.\",\r\n\t\"ADHR_MYPROFILETAB_RF\": \"Please authenticate your Aadhaar before filing refund application. In case Aadhaar is not available, you can upload e-KYC details with Aadhaar Enrollment ID.\",\r\n\t\"LBL_VALIDATE\": \"Validate\",\r\n\t\"LBL_BIO_STS\":\"Pending for Biometric Authentication\",\r\n\t\"LBL_BIO_STS_DESC\":\"Your risk score is high. Therefore, you are requested to get your Biometric Authentication done for Promoter/ Partner and PAS by visiting your jurisdictional office within 15 calendar days so that the registration process may be completed.\",\r\n\t\"LBL_INFORMATION\": \"Information\",\r\n    \"LBL_INF_DISABILITY\":\"This facility is only applicable to the persons falling under section 25(6D) of the CGST Act. Kindly upload necessary document/certificate issued on this behalf by the Government/Competent Authority.\",\r\n\t\"LBL_DISABILITY\":\"Person exempted u/s 25(6D) of the Act\",\r\n\t\"LBL_STAK_SuccessMsgforActivate\": \"Your details are verified successfully, and you are active now on the STAK Application.\",\r\n    \"LBL_STAK_SuccessMsgforDeactivate\":\"You are deactivated on the STAK Application.\",\r\n    \"LBL_STAK_ErrorMsg\": \"PAN and Mobile Number not registered with STAK Application.\",\r\n\t\"DC_URL\": \"/downloadhb/download?docId=\",\r\n\"DC_URL_NEW\": \"/downloadhb/download/new?docId=\",\r\n    \"LBL_TRADE_ADDTIONAL\":\"Additional Trade Name\",\r\n\t\"LBL_No_Data\" :\"Additional trade names not available\",\r\n    \"LBL_EKYC_INFO\":\"If you have Aadhaar, please go for Aadhaar Authentication and do not opt for E-KYC verification\",\r\n    \"LBL_EKYC_DECL\" :\"I don't have Aadhaar hence not opting for Aadhaar Authentication.\",\r\n    \"ERR_EKYC_DECL_REQ\":\"Kindly select the EKYC declaration checkbox\",    \r\n    \"LBL_RTN_FREQ_TBL\" : \"SHOW RETURN FILING FREQUENCY\",\r\n    \"HYP_PREV\" : \"Filing frequency of previous FY\",\r\n    \"HYP_CURR\" : \"Filing frequency of current FY\",\r\n    \"LBL_FREQUENCY\" : \"Frequency\",\r\n    \"LBL_FIN_YR\" : \"Financial Year\",\r\n\t\"LBL_QTR\" : \"Quarter\",\r\n\t\"LBL_FIL_FREQ\" : \"Filing Frequency\",\r\n\t\"LBL_RTN_FREQ\" : \"Return filing frequency\",\r\n\t\"LBL_Q1\" : \"Apr-Jun\",\r\n\t\"LBL_Q2\" : \"Jul-Sep\",\r\n\t\"LBL_Q3\" : \"Oct-Dec\",\r\n\t\"LBL_Q4\" : \"Jan-Mar\",\r\n\t\"LBL_RTN_FREQ_INFO\" : \"As per the GSTR-1 filing frequency till December 2020 and <br> as per the Quarterly Return Monthly Payment [QRMP] <br> scheme from January 2021 onwards.\",\r\n\t\"profileNAMsg\": \"* Not Applicable implies either the taxpayer type is not registered or Cancelled or Composition.\",\r\n\t\"ERR_NOT_REG\" : \"Taxpayer type is not active for the selected period.\",\r\n    \"ERR_NO_DETAILS\" : \"No details found.\",\r\n    \"LBL_BNK_STATUS\" : \"Bank Account Status\",\r\n    \"LBL_ACCN_TYPE\" : \"Type of Account\",\r\n    \"LBL_ACTN\": \"Action\",\r\n    \"LBL_RVAL\": \"REVALIDATE\",\r\n    \"LBL_ACCN_NUM\" : \"Account Number\",\r\n    \"LBL_BNAME\" : \"Bank Name\",\r\n    \"LBL_BNK_ADDR\" : \"Bank Address\",\r\n    \"LBL_VERIFIED\" : \"Verified\",\r\n    \"LBL_SVG_ACC\": \"Savings Account\",\r\n    \"LBL_CRNT_ACC\": \"Current Account\",\r\n    \"LBL_CASH_CRE_ACC\": \"Cash Credit Account\",\r\n    \"LBL_OTHERS\": \"Others\",\r\n    \"TLT_TICKMARK\" : \"The bank account validation is successful. Refunds can be Filed using this account\",\r\n    \"TLT_CROSSMARK\" : \"The bank account validation failed. Refund can't be Filed using this bank account. Kindly remove the account or rectify with correct information\",\r\n    \"TLT_EXCLAMARK\" : \"The bank account information has some issues. However, refund can be Filed using this account\",\r\n    \"LBL_BANKDETAILS_ERR\" : \"Kindly Add Bank Account details by filling Non-Core Amendment to proceed ahead\",\r\n    \"LBL_EDIT_ERR\" : \"Dear Tax-Payer, the application cannot be viewed due to security reasons\",\r\n    \"LBL_DOWNLOAD_ERR\" : \"Error, the application cannot be downloaded\",\r\n     \"LBL_DATE_CANCL_ORDER\": \"Date of Cancellation\",\r\n     \"LBL_REGIS_CANCEL\": \"Reason For Cancellation\",\r\n    \"LBL_EINV_ENABLED\" : \"Whether e-Invoice is Enabled?\",\r\n    \"EINV_ENABLED_STS_PT1\" : \"The above enablement status is based on aggregate annual turnover computations based on GSTR-3B filing.\",\r\n    \"EINV_ENABLED_STS_PT2\" : \"The 'enablement' status on the portal doesn't mean that the GSTIN is supposed to do e-invoicing. If a taxpayer is exempt from e-invoicing or e-invoicing is not applicable to a taxpayer for any other reason, they need not be concerned about the enablement status and may please ignore the same.\",\r\n    \"EINV_ENABLED_STS_PT3\" : \"Please note that on fulfilment of prescribed conditions, the legal obligation to prepare invoice in terms of Rule 48(4) of CGST/SGST Rules, lies with concerned registered person.\",\r\n\t\"ADHR_MYPROFILETAB_ES\": \"Please authenticate your Aadhaar. In case Aadhaar is not available, you can upload e-KYC details with Aadhaar Enrollment ID.\",\r\n\t\"ADHR_SEND_VER_LINK_SCS_MSG_ES\": \"Aadhaar Authentication link are shared on the Email and Mobile Number registered with GST of the Unregistered Applicant.\",\r\n\t\"IMG_UPLD_POPUP\" : \"Dear Taxpayer, Please update your photograph in the Edit Profile Page. To proceed further, Click on the below button\",\r\n    \"ECOM_HAS_GST_POPUP\" : \"The GSTIN is already registered using the same PAN used for getting the Enrolment ID <> and in Active/Suspended status. You are requested to use the registered GSTIN to access the portal.\", \r\n    \"LBL_GO_TO_DBRD\": \"Go to Dashboard\",\r\n    \"TXT_GTA_CONFIRM\": \"If you are providing a Goods Transport Agencies (GTA) Services and wish to opt for payment of tax on forward charge mechanism, please click on ‘Proceed’ button or click on ‘Go to Dashboard’ button to redirect to the dashboard page.\",\r\n    \"MSG_GTA_CHECK\": \"Please select both checkboxes to file Annexure V\",\r\n    \"LBL_GO\": \"Go\",\r\n    \"LBL_GTA_TITLE\": \"Annexure V: Furnishing Declaration for Opting Forward Charge Payment by GTA\",\r\n    \"HEAD_VERIFICATION\": \"Verification\",\r\n    \"LBL_DEC_INF\":\"I hereby solemnly affirm and declare that the information given herein above is true and correct to the best of my knowledge and belief and nothing has been concealed therefrom.\",\r\n    \"LBL_NM_AUT\": \"Name of Authorized Signatory\",\r\n    \"GTA_SIGN_FILE_EVC\": \"Sign and File with EVC\",\r\n    \"MSG_SUBMITTED_SUCCESS\": \"Your form has been signed successfully through EVC\",\r\n\t\"HEAD_APP_SUB_SCCFL\": \"Form submitted successfully.\",\r\n    \"HEAD_ACK_FOR_GTA\": \"Acknowledgment for Form Annexure V\",\r\n    \"LBL_REF\": \"Reference Number (RN)\",    \r\n    \"LBL_TIME_OF_FILING\": \"Time of filing \",\r\n    \"LBL_GDS_N_SRVS_IDN_NO\": \"Goods and Services Tax Identification Number (GSTIN) \",\r\n    \"LBL_PAN_NO\": \"PAN No \",\r\n    \"LBL_TRD_NM\": \"Trade Name (if available) \",\r\n    \"LBL_CNTR_JURSDCTN\": \"Center Jurisdiction  \",\r\n    \"LBL_STATE_JURSDCTN\": \"State Jurisdiction  \",\r\n    \"HEAD_SYS_GEN_ACK\": \"It is a system generated acknowledgement and does not require any signature.\",\r\n    \"BTN_DWNLD_ANNEXURE\": \"Download Annexure V\",\r\n    \"TXT_MANUAL_UPLOAD_CONFIRM\":\"Taxpayers who Filed their declaration in the Financial Year 2023-24 manually, only required to upload their acknowledged copy of Annexure V.\",\r\n    \"ANNX5_MSG_GTA_CHECK\": \"Please select both checkboxes to file Annexure V\",\r\n    \"ANNX6_MSG_GTA_CHECK\": \"Please select all checkboxes to file Annexure VI\",\r\n    \"ANNX5_LBL_GTA_TITLE\": \"Annexure V: Furnishing Declaration for Opting Forward Charge Payment by GTA\",\r\n    \"ANNX6_LBL_GTA_TITLE\": \"Annexure VI Form\",\r\n    \"ANNX5_HEAD_ACK_FOR_GTA\": \"Acknowledgment for Form Annexure V\",\r\n    \"ANNX6_HEAD_ACK_FOR_GTA\": \"Acknowledgment for Form Annexure VI\",\r\n    \"HEAD_SCSS_MSG_GTA\": \"You have Filed the declaration successfully and the particulars of the Form Annexure V are given as under :\",\r\n    \"ANNX5_HEAD_SCSS_MSG_GTA\": \"You have Filed the declaration successfully and the particulars of the Form Annexure V are given as under :\",\r\n    \"ANNX6_HEAD_SCSS_MSG_GTA\": \"You have Filed the declaration successfully and the particulars of the Form Annexure VI are given as under :\",\r\n    \"ANNX5_BTN_DWNLD_ANNEXURE\": \"Download Annexure V\",\r\n    \"ANNX6_BTN_DWNLD_ANNEXURE\": \"Download Annexure VI\",\r\n    \"MSG_GTA_DECLARATION\": \"Declaration in Annexure V has already been Filed for the selected Financial Year. Click on ‘Download Annexure V’ button to download the declaration\",\r\n    \"ANNX5_MSG_GTA_DECLARATION\": \"Declaration in Annexure V has already been Filed for the selected Financial Year. Click on ‘Download Annexure V’ button to download the declaration\",\r\n    \"ANNX6_MSG_GTA_DECLARATION\": \"Declaration in Annexure VI has already been Filed for the selected Financial Year. Click on ‘Download Annexure VI’ button to download the declaration\",\r\n    \"MSG_GTA_FILED\": \"The information in the downloaded Annexure Form is provided as per information and declarations given by the taxpayer at the time of filling Annexure Form for the respective Financial Year.\",\r\n    \"ANNX5_MSG_GTA_FILED\": \"The information in the downloaded Annexure V is provided as per information and declarations given by the Taxpayer at the time of filing Annexure V for the respective year.\",\r\n    \"ANNX6_MSG_GTA_FILED\": \"The information in the downloaded Annexure VI is provided as per information and declarations given by the Taxpayer at the time of filing Annexure VI for the respective year.\",\r\n    \"LBL_GTA_NOTE\": \"Note: \",\r\n    \"ANNX6_LBL_GTA_FMCNT\":\"Form for exercising option by a Goods Transport Agency intending to revert under reverse charge mechanism to be Filed before the commencement of any financial year to be submitted before the jurisdictional GST Authority.\",\r\n    \"ANNX5_LBL_GTA_FMCNT\": \"Form for exercising the option by a Goods Transport Agency (GTA) for payment of GST on the GTA services supplied by him under forward charge\",\r\n    \"LBL_GTA_FMCNT\": \"Form for exercising the option by a Goods Transport Agency (GTA) for payment of GST on the GTA services supplied by him under forward charge\",\r\n    \"LBL_GTA_TO\": \"To \",\r\n    \"LBL_GTA_TO_AUTH\": \"The Jurisdiction Authority\",\r\n    \"LBL_PROD_TO_FILE\": \"Proceed to File\",\r\n    \"LBL_GTA_DECL1\": \"I understand that this option once exercised shall not be allowed to be changed within a period of one year from the date of exercising the option and will remain valid till the start of the financial year for which I exercise option to revert under reverse charge mechanism by filing Annexure VI on or before the due date.\",\r\n    \"LBL_SELECT_FY\": \"Select Financial Year\",\r\n    \"LBL_GSTN_GTA\": \"GSTIN\",\r\n\r\n    \"LBL_GTA_ANNEXURE_VI_TITLE\": \"Annexure VI: Furnishing Declaration for Opting Reverse Charge Payment by GTA\",\r\n    \"LBL_ADMIN_JURISD\": \"Administrative Jurisdiction\",\r\n    \"ELEC_CREDIT_REV_RECLAIM_STMT\" : \"Electronic Credit Reversal and Re-claimed Statement\",\r\n    \"ELEC_REV_CHRG_LIAB_ITC_STMNT\": \"RCM Liability/ITC Statement\",\r\n    \"RCM_LIAB\":\"RCM Liability/ITC Statement\",\r\n\t\"LBL_RESEND\" : \"Resend Link\",\r\n\t\"LBL_RESEND_LINK\" : \"Resend Authentication Link\",\r\n\t\"ADHR_RESEND_VER_LINK\": \"Aadhaar Authentication Link reshared on the Email and Mobile Number registered with GST of the selected Promoter/Partner and Primary Authorized Signatory.\",\r\n\t\"RESEND_VERIFICATION_MESG_NT\": \"Aadhaar Authentication Link reshared on the Email and Mobile Number registered with GST of the selected Promoter/Partner and Primary Authorized Signatory.\",\r\n\t\"RESEND_VEERIFICATION_MESG_TCS\": \"Aadhaar Authentication Link reshared on the Email and Mobile Number registered with GST of the Primary Authorized Signatory.\",\r\n\t\"RESEND_VERIFICATION_MESG_RF\": \"Aadhaar Authentication Link reshared on the Email and Mobile Number registered with GST of the Unregistered Applicant.\",\r\n    \"ECOM_THRESHOLD_LMT\"        : \"You have crossed the threshold limit of turnover and requested to take a new registration and get GSTIN number.\",\r\n    \"Resend_SMS_Email\": \"Resend SMS/Email\",\r\n    \"SME_WELCOME_MESSAGE\":\"Temporary Login credentials has been successfully sent to your registered email id and mobile number.\",\r\n    \"FIRST_TIME_LOGIN\":\"Please login using First Time Login link on website.\",\r\n     \"ERR_USER_ALREADY_CREATED\": \"Username already created for the user.\",\r\n\t\"ERR_SYSTEM_ERROR\": \"System error occurred!! Please try again after sometime\",\r\n    \"GTA_MENU\": \"GTA (Goods Transport Agencies)\",\r\n    \"GTA_MENU_ANX_V\": \"Opting Forward Charge Payment by GTA (Annexure V)\",\r\n    \"GTA_MENU_ANX_VI\": \"Opting to Revert Under Reverse Charge Payment by GTA (Annexure VI)\",\r\n    \"GTA_MENU_ANX_UPLOAD\": \"Upload Manually Filed Annexure V\",\r\n    \"GTA_ANX_VI_TITLE\": \"Annexure VI: Furnishing Declaration for Opting Reverse Charge Payment by GTA\",\r\n    \"GTA_ANX_VI_POPUP\": \"Option already exercised in Annexure V by you for the Financial Year <Filed Financial Year> onwards will be discontinued and your payment option would be changed from Forward Charge Mechanism to Reverse Charge Mechanism. Click on 'PROCEED' button to continue or click on 'GO TO DASHBOARD' button to continue the earlier Filed option and redirect to the dashboard.\",\r\n    \"LBL_GTA_DECL2\": \"I hereby declare that I want to revert to reverse charge mechanism for Financial Year \",\r\n    \"GTA_UPLOAD_DECL\": \"I declare that Annexure V has been manually Filed by me at the jurisdictional office and it has been duly acknowledged by the jurisdiction proper officer, the information furnished by me is true.\",\r\n    \"GTA_LBL_PAN_NO\": \"PAN\",\r\n    \"GTA_LBL_ACKDT\": \"Date of Acknowledgement\",\r\n    \"GTA_LBL_ACKBY\": \"Acknowledged By\",\r\n    \"GTA_LBL_ACKBY_PL\": \"(AC/CTO/STO/DCTO/ACTO/Suptd.)\",\r\n    \"GTA_LBL_REFNO\": \"Reference Number (If any)\",\r\n    \"GTA_TEXT_REFNO\": \"Reference Number\",\r\n    \"GTA_LBL_UPFILE\": \"Upload Annexure V\",\r\n    \"GTA_BTN_CONFIRM\": \"Confirm\",\r\n    \"GTA_REF_NO\" : \"XXXXXXXXXXXXXXXX\",\r\n    \"GTA_UP_POPUPNOTE\": \"Please upload clear and legible copy duly acknowledged in the jurisdictional office within given time as per Notification No. 05/2023- Central Tax (Rate).\",\r\n    \"GTA_UP_SAVENOTE\": \"The reference number is generated with reference to your manually uploaded document.\",\r\n    \"GTA_UP_FTYPE\": \"File with PDF format is only allowed.\",\r\n    \"GTA_UP_FSIZE\": \"Maximum file size for upload is 2MB.\",\r\n    \"ANNX6_ERROR\": \"You have not Filed Annexure V for any of the previous Financial Year to pay tax under Forward Charge Mechanism and you are currently placed under Reverse Charge Mechanism.\",\r\n    \"GTA_UP_CHECK\" : \"Kindly select the declaration checkbox\",\r\n    \"GTA_UP_INV_DATE\": \"Invalid Date of Acknowledgement\",\r\n    \"GTA_DECL_3_ANNX6\": \"I understand that this option once exercised shall not be allowed to be changed within a period of one year from the date of exercising the option and will remain valid till the end of the financial year for which it is exercised.\",\r\n    \"TXT_GTA_CONFIRM_VI\" : \"Option already exercised in Annexure V by you will be discontinued and your payment option would be changed from Forward Charge Mechanism to Reverse Charge Mechanism. Click on 'PROCEED' button to continue or click on 'GO TO DASHBOARD' button to continue the earlier Filed option and redirect to the dashboard.\",\r\n    \"ANNX6_RBN_GTA_TITLE\": \"Annexure VI - Furnishing Declaration intending to revert under Reverse Charge mechanism\",\r\n    \"GTA_LBL_REF_NO\": \"Reference No\",\r\n    \"W_RSB_REMARKS\": \"Task is pending with Officer to take action\",\r\n    \"W_SUB_REMARKS\": \"Details shared to taxpayer on email/SMS.Pending with jurisdictional tax authority for action\",\r\n    \"W_ARS_REMARKS\": \"Task is pending with Officer to take action\",\r\n    \"W_CLR_REMARKS\": \"Notice for denial of option to pay tax under composition scheme is issued to taxpayer and waiting for reply to SCN/personal hearing\",\r\n    \"W_RJT_REMARKS\": \"Tax Officer has rejected the reply to SCN. Order for rejection of reply to show cause notice is issued\",\r\n    \"W_APR_REMARKS\": \"Tax Officer has accepted the reply to SCN. Order for acceptance of reply to show cause notice is issued\",\r\n    \"W_RSB_STATUS\":\"Clarification filed - Pending for Order\",\r\n    \"W_SUB_STATUS\": \"Application for Cancellation filed and pending for Processing\",\r\n    \"W_ARS_STATUS\": \"Clarification Not Filed – Pending for Order\",\r\n    \"W_CLR_STATUS\": \"SCN Raised – Pending for clarification\",\r\n    \"W_RJT_STATUS\": \"Order Issued – Rejected\",\r\n    \"W_APR_STATUS\": \"Order Issued – Approved\",\r\n    \"LBL_TYPE_OF_SUPPLY\": \"Type of Supply\",\r\n    \"LBL_TYP_SUP_OMG\": \"Supply of Online Money Gaming\",\r\n    \"LBL_TYP_SUP_OIDAR\": \"Supply of Online Information and Database Access or Retrieval Services\",\r\n    \"LBL_TYP_SUP_OIDAR_OMG\": \"Supply of Online Money Gaming and Online Information and Database Access or Retrieval Services\",\r\n\t\"BT_SEARCH\" : \"Search\",\r\n    \"NLS_BAL\":\"Negative liability statement - Regular Taxpayers\",\r\n    \"LBL_TYPE_OF_TEMP_ID\":\"Type of Temporary ID\",\r\n    \"LBL_TEMPID_TEXT_PART1\":\"Temporary Registration under Rule 16(1)\",\r\n\t\"LBL_TEMPID_TEXT_PARTA\":\"Temporary Identification Number under Rule 16A to make payment\",\r\n    \"LBL_OPN_NOTICES_TBL_HDR_6\" : \"Only notices/intimations issued in last 60 days by Adjudicating Authority & Enforcement officers are currently included in the count and their list is displayed on the next screen. To view all notices or orders, please navigate to \\\"View Notices and Orders\\\" and/or \\\"View Additional Notices and Orders\\\".\",\r\n    \"LBL_MDL_NM\": \"Module Name\",\r\n    \"LBL_COUNT_OF_NOTICES\": \"Count of Notices / Intimations Issued\",\r\n    \"LBL_OPN_NOTICES_TOTAL\": \"Total\",\r\n    \"LBL_OPN_NOTICES_TBL_HDR_1\" : \"Ref ID (Notice ID)\",\r\n    \"LBL_OPN_NOTICES_TBL_HDR_4\" : \"Date of Issue\",\r\n    \"LBL_OPN_NOTICES_TBL_HDR_5\" : \"Last Responded Date\",\r\n    \"LBL_OPN_NOTICES_TBL_HDR_7\" : \"ARN / Case ID\",\r\n    \"LBL_OPN_NOTICES_TBL_HDR_8\" : \"#\",\r\n    \"LBL_PERIOD_OF_VALIDITY\" : \"Period of Validity for LoA/LoP\",\r\n    \"HEAD_BASIC_DET\": \"Basic Details\",\r\n\t\"LBL_TMP_EFFDATE\": \"Effective Date of Registration / Temporary ID\",\r\n\t\"HEAD_DTL_TEMPID_GRTD\":\"Details of the person in whose name Temporary ID is granted\",\r\n\t\"HEAD_TAXPYR_DTLS\":\"Temporary Registration Taxpayer Details\",\r\n    \"HEAD_REQ_CANCEL\":\"Request for Cancellation\",\r\n    \"HEAD_CNCL_UNAPPL\":\"Cancel Unregistered Applicant\",\r\n    \"LBL_TYPE_OF_ID\":\"Type of ID\",\r\n    \"LBL_GSTIN_TEMP\":\"GSTIN/UIN/Temporary ID\",\r\n    \"LBL_GSTIN_TEMP_STS\":\"GSTIN/UIN/Temporary ID Status\",\r\n    \"LBL_TEMP_STS\":\"Status of Temporary ID\",\r\n    \"ERR_REASON_FOR_CANCEL\":\"Reason for Cancellation is required\",\r\n    \"LBL_REASON_CANCEL_UNREG\": \"Reason for Cancellation (Max Characters allowed 1000)\",\r\n    \"LBL_REG_TEMP_ID\":\"Registration No. / Temporary ID\",\r\n    \"LBL_ADDR_OF_PERSON_NO_ASTRK\":\"Address of the Person\",\r\n    \"MSG_SPL_CHARS_ALLOWED\":\"These special characters -/&,.[]():;_ are allowed\",\r\n    \"LBL_DECL_AS_SPECIFIED_PREMISES\": \"Declared as Specified Premises\",\r\n\t\"DC_URL_NEW\": \"/downloadhb/download/new?docId=\",\r\n    \"INFO_TRACK_APPLICATION\":\"You may search the status of Application of Withdrawal from Registration under Rule 14A through Track Application Status appearing under Registration Menu.\",\r\n     \"LBL_EKYC_STS_DESC_OPT_IN_OUT\":\"The links for Aadhaar authentication has been sent on email ids of all Promotors/ Partners/ Authorized Signatories. Kindly do the e-KYC of respective individuals  within the expiry date (15 days from date of submission of Form GST REG-32) so that the process may be completed.\",\r\n    \"LBL_BIO_STS_DESC_OPT_IN_OUT\":\"You are requested to get your Biometric Authentication done for Promoter/Partner and Primary Authorized Signatory by visiting the designated GST Suvidha Kendra within the expiry date (15 days from date of submission of Form GST REG-32) so that the process may be completed.\",\r\n    \"LBL_BIO_DOCSTS_DESC_OPT_IN_OUT\":\"Your Biometric Verification is already completed. You are requested to get your document verification done for PAS only by visiting the designated GST Suvidha Kendra within the expiry date (15 days from date of submission of Form GST REG-32) so that the process may be completed.\",\r\n    \"LBL_BIO_ARNGEN_DESC_OPT_IN_OUT\":\"You have not completed the Aadhaar e-KYC Authentication or not visited the GST Suvidha Kendra within the expiry date (15 days from date of submission of Form GST REG-32) or you have visited the GST Suvidha Kendra but Biometric Authentication/Document Verification is failed or not completed.\"\r\n\r\n  }\r\n"},"headersSize":1085,"bodySize":-1085,"redirectURL":"","_transferSize":0},"cache":{},"timings":{"dns":-1,"connect":-1,"ssl":-1,"send":0,"wait":0.157,"receive":3.064},"serverIPAddress":"103.83.77.48","_serverPort":443,"_securityDetails":{"protocol":"TLS 1.2","subjectName":"services.gst.gov.in","issuer":"GlobalSign Extended Validation CA - SHA256 - G3","validFrom":1747043474,"validTo":1781344273}},{"pageref":"page@208d3e1db68ef3d6564c6188af16a787","startedDateTime":"2026-05-22T16:51:13.146Z","time":59.72,"request":{"method":"GET","url":"https://services.gst.gov.