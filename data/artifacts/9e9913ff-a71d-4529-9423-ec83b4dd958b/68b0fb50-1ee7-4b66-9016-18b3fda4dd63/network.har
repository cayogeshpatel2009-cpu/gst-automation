le=\" padding: 6px;\">Warning</b></i></h4></div><p class=\"textClr\"></p></div><div class=\"modal-footer\"><div class=\"btnAlign\"><a class=\"btn btn-primary\"  ng-click=\"callback()\" data-dismiss=\"modal\">Yes</a><a class=\"btn btn-primary\" data-dismiss=\"modal\" ng-click=\"cnconfirmFunction()\">No</a></div></div></div></div>',\n\t};\n});\nmyApp.directive('finalApprovedTurnover', function () {\n\treturn {\n\t\trestrict: \"E\",\n\t\tcontrollerAs: 'dir',\n\t\tscope: {\n\t\t\tdata: \"=\",\n\t\t\tcallback: \"&\",\n\t\t\tcancelcallback: \"&\",\n\t\t\tsendvfyreqbtnTitle: \"@\",\n\t\t\trmdbtnTitle: \"@\"\n\t\t},\n\t\ttemplate: '<style>.w-10 {width: 8%}.w-35 {width: 25%}.w-45 {width: 45%}.txtAlign {text-align: right}</style><div id=\"finturnoverSumtable\" class=\"modal fade fade-scale\" role=\"dialog\"><div class=\"modal-dialog modal-lg sweet\"><div class=\"modal-content pdfPopupScroll\"><div class=\"modal-header\"><button type=\"button\" class=\"close\" data-dismiss=\"modal\">×</button></div><div class=\"modal-body\"><div><div class=\"turnoverContainer\"><h4 class=\"tlt1\">Statement of Turnover for a Financial Year</h4><div class=\"tableContainer\"><div><table class=\"table table-striped table-bordered finClass\"><tr><td>Financial Year</td><td> {{data.fy}}</td></tr></table></div><div class=\"\"><table class=\"table table-striped table-bordered\"><tr><td class=\"w-10\">1.</td><td class=\"w-35\">GSTIN</td><td> {{data.gstin}}</td></tr><tr><td>2.(A)</td><td>Legal name</td><td colspan=\"14\"> {{data.legName || \"-\"}}</td></tr><tr><td>2.(B)</td><td>Trade name,if any</td><td colspan=\"14\"> {{data.tradeName || \"-\"}}</td></tr></table></div><div><h4 class=\"subHeadCls\"><span>3. </span>Turnover of the Financial Year for the GSTIN above</h4><div style=\"text-align: right;\">(Amount in ₹ in tables)</div><div class=\"table-responsive\"><table class=\"table table-striped table-bordered turnoverTable\"><tr><td class=\"w-10\">(i)</td><td class=\"w-35\">System computed Turnover</td><td style=\"text-align: right;\"> {{data.gstinSysTo.toPrecision() | currency: \" \" }}</td><td>As on Date : {{data.finalToDate}}</td></tr><tr><td>(ii)</td><td>Reported by Taxpayer</td><td style=\"text-align: right;\"> {{data.gstinuserTo.toPrecision() | currency: \" \"}}</td><td><div><p>ARN : {{data.arn || \"-\" }} </p><p>ARN Date : {{data.arnDate || \"-\" }} </p></div></td></tr><tr><td>(iii)</td><td>Updated by Tax-Officer</td><td style=\"text-align: right;\"> {{data.gstinOffUpdatedTo.toPrecision() | currency: \" \"}}</td><td><div><p>Reference Number : {{data.refNum || \"-\" }} </p><p>Reference Date : {{data.refDate || \"-\"}} </p></div></td></tr><tr><td>(iv)</td><td><div><p>Tax Officer Details</p></div></td><td colspan=\"2\"><div><p> Name : {{data.toName || \"-\"}} </p><p> Designation : {{data.toDegination || \"-\" }}</p><p> Jurisdiction : {{data.toJur || \"-\"}} </p></div></td></tr><tr><td>(v)</td><td>Final Turnover</td><td style=\"text-align: right;\">{{ (data.gstinFinalTo != null ) ? (data.gstinFinalTo.toPrecision() | currency: \" \") : \"-\"}}</td><td>As on Date : {{data.displayToDate}}</td></tr></table></div></div><div><h4 class=\"subHeadCls\"><span>4.</span>Aggregate Turnover(PAN Based)</h4><div class=\"table-responsive\"><table class=\"table table-striped table-bordered aggturnoverTable\"><tr><td class=\"w-10\">Sr.No</td><td class=\"w-45\">Description</td><td>Number/Amount</td></tr><tr style=\"text-align: center;\"><td>(1)</td><td>(2)</td><td>(3)</td></tr><tr><td>1.</td><td>No. of registrations on the same PAN across the country</td><td class=\"txtAlign\">{{data.noOfTp}}</td></tr><tr><td>2.</td><td>Out of (1) above, No. of Taxpayers who have filed all returns as on {{data.finalToDate}}</td><td class=\"txtAlign\">{{data.noOfFiledTp}}</td></tr><tr><td>3.</td><td>Out of (1) above, No. of registration(s) who have updated the Turnover as on {{data.finalToDate}}</td><td class=\"txtAlign\">{{data.noOfTpUpdatedTo}}</td></tr><tr><td>4.</td><td>System Computed Aggregate Turnover as on {{data.finalToDate}}</td><td class=\"txtAlign\">{{(data.aggSysTo != null) ? (data.aggSysTo.toPrecision() | currency : \" \") : \"-\"}}</td></tr><tr><td>5.</td><td>Aggregate Turnover based on Taxpayer’s inputs as on {{data.finalToDate}}</td><td class=\"txtAlign\">{{(data.aggUserTo != null) ? (data.aggUserTo.toPrecision() | currency : \" \") : \"-\"}}</td></tr><tr><td>6.</td><td>Aggregate Turnover based on Tax-officers review as on {{data.displayToDate}}</td><td class=\"txtAlign\">{{(data.aggOffTo != null) ? (data.aggOffTo.toPrecision() | currency : \" \") : \"-\"}}</td></tr><tr><td>7.</td><td>Final Aggregate Turnover {{data.displayToDate}}</td><td class=\"txtAlign\">{{(data.aggFinalTo != null) ? (data.aggFinalTo.toPrecision() | currency : \" \") : \"-\"}}</td></tr></table></div></div><div><div style=\"font-weight: bold;\"><span style=\"text-decoration: underline;\">Disclaimer:</span><span> This is a system generated pdf and it requires no signing.</span></div><br/><div style=\"font-weight: bold;\"><span style=\"text-decoration: underline;\">Note: Last updated on - {{data.displayToDate}}</span></div></div></div></div></div></div><div class=\"modal-footer\"><div class=\"row\"><a class=\"btn btn-primary\" ng-click=\"callback()\">Download</a></div></div></div></div></div>',\n\t};\n});\nmyApp.directive('previewTurnover', function () {\n\treturn {\n\t\trestrict: \"E\",\n\t\tcontrollerAs: 'dir',\n\t\tscope: {\n\t\t\tdata: \"=\",\n\t\t\tcallback: \"&\",\n\t\t\tcancelcallback: \"&\",\n\t\t\tsendvfyreqbtnTitle: \"@\",\n\t\t\trmdbtnTitle: \"@\"\n\t\t},\n\t\ttemplate: '<style>.w-10 {width: 10%}.w-35 {width: 35%}</style><div id=\"turnoverSumtable\" class=\"modal fade fade-scale\" role=\"dialog\"><div class=\"modal-dialog modal-lg sweet\"><div class=\"modal-content\"><div class=\"modal-header\"><button type=\"button\" class=\"close\" data-dismiss=\"modal\">×</button></div><div class=\"modal-body\"><div><div class=\"turnoverContainer\"><h4 class=\"tlt1\">Declaration of Turnover for a Financial Year</h4><div class=\"tableContainer\"><div><table class=\"table table-striped table-bordered finClass\"><tr><td>Financial Year</td><td> {{data.fy}}</td></tr></table></div><div class=\"\"><table class=\"table table-striped table-bordered\"><tr><td class=\"w-10\">1.</td><td class=\"w-35\">GSTIN</td><td> {{data.gstnId}}</td></tr><tr><td>2.(A)</td><td>Legal name</td><td colspan=\"14\"> {{data.legalName || \"-\" }}</td></tr><tr><td>2.(B)</td><td>Trade name,if any</td><td colspan=\"14\"> {{data.tradeName || \"-\"}}</td></tr><tr><td>2.(C)</td><td>ARN</td><td colspan=\"14\">-</td></tr><tr><td>2.(D)</td><td>ARN Date</td><td colspan=\"14\">-</td></tr></table></div><div><h4 class=\"subHeadCls\"><span>3. </span>Turnover of the Financial Year for the GSTIN above</h4><div style=\"text-align: right;\">(Amount in ₹ in tables)</div><div class=\"table-responsive\"><table class=\"table table-striped table-bordered turnoverTable\"><tr><td class=\"w-10\">(i)</td><td class=\"w-35\">System Computed Turnover</td><td style=\"text-align: right;\"> {{data.sysGstinTO.toPrecision() | currency: \" \"}}</td></tr><tr><td>(ii)</td><td>Reported by Taxpayer</td><td style=\"text-align: right;\"> {{data.userEntry.toPrecision() | currency: \" \"}}</td></tr></table></div></div></div></div></div></div><div class=\"modal-footer\"><div class=\"row\"><a class=\"btn btn-primary\" ng-click=\"callback()\">Download</a></div></div></div></div></div>',\n\t};\n});\nmyApp.directive('finalTurnover', function () {\n\treturn {\n\t\trestrict: \"E\",\n\t\tcontrollerAs: 'dir',\n\t\tscope: {\n\t\t\tdata: \"=\",\n\t\t\tcallback: \"&\",\n\t\t\tcancelcallback: \"&\",\n\t\t\tsendvfyreqbtnTitle: \"@\",\n\t\t\trmdbtnTitle: \"@\"\n\t\t},\n\t\ttemplate: '<style>.w-10 {width: 10%}.w-35 {width: 35%}</style><div id=\"finturnoverSumtable\" class=\"modal fade fade-scale\" role=\"dialog\"><div class=\"modal-dialog modal-lg sweet\"><div class=\"modal-content pdfPopupScroll\"><div class=\"modal-header\"><button type=\"button\" class=\"close\" data-dismiss=\"modal\">×</button></div><div class=\"modal-body\"><div><div class=\"turnoverContainer\"><h4 class=\"tlt1\">Declaration of Turnover for a Financial Year</h4><div class=\"tableContainer\"><div><table class=\"table table-striped table-bordered finClass\"><tr><td>Financial Year</td><td> {{data.fy}}</td></tr></table></div><div class=\"\"><table class=\"table table-striped table-bordered\"><tr><td class=\"w-10\">1.</td><td class=\"w-35\">GSTIN</td><td> {{data.gstnId}}</td></tr><tr><td>2.(A)</td><td>Legal name</td><td colspan=\"14\"> {{data.legalName || \"-\" }}</td></tr><tr><td>2.(B)</td><td>Trade name,if any</td><td colspan=\"14\"> {{data.tradeName || \"-\" }}</td></tr><tr><td>2.(C)</td><td>ARN</td><td colspan=\"14\"> {{data.arnNo || \"-\"  }}</td></tr><tr><td>2.(D)</td><td>ARN Date</td><td colspan=\"14\"> {{data.arnDate || \"-\" }}</td></tr></table></div><div><h4 class=\"subHeadCls\"><span>3. </span>Turnover of the Financial Year for the GSTIN above</h4><div style=\"text-align: right;\">(Amount in ₹ in tables)</div><div class=\"table-responsive\"><table class=\"table table-striped table-bordered turnoverTable\"><tr><td class=\"w-10\">(i)</td><td class=\"w-35\">System computed Turnover</td><td style=\"text-align: right;\"> {{(data.sysGstinTO.toPrecision() | currency: \" \") || \"-\" }}</td></tr><tr><td>(ii)</td><td>Reported by Taxpayer</td><td style=\"text-align: right;\"> {{(data.gstinTOEnterByUser.toPrecision() | currency: \" \") || \"-\" }}</td></tr></table></div></div><div><h4 class=\"subHeadCls\"><span>4. </span>Verification</h4><span>I hereby solemnly affirm and declare that the information given herein above is true and correct to the best of my knowledge and belief and nothing has been concealed therefrom.</span></div><div class=\"row\" style=\"margin-top: 30px;\"><div class=\"col-sm-6 col-xs-12 \"><p>Date :<strong>{{data.arnDate}}</strong></p></div><div class=\"col-sm-6 col-xs-12 text-right\"><span><strong>Name of Authorized Signatory </strong></span><p>{{data.auth_name}}</p><span><strong>Designation / Status </strong></span><p>{{data.auth_dg}}</p></div> <div style=\"font-weight: bold;\"><span style=\" text-decoration: underline;\">Note:</span> <span>To see the latest updated system computed GSTIN turnover and AATO on the PAN,Dashboard screen can be referred for the same.</span></div></div></div></div></div></div><div class=\"modal-footer\"><div class=\"row\"><a class=\"btn btn-primary\" ng-click=\"callback()\">Download</a></div></div></div></div></div>',\n\t};\n});\n\nmyApp.directive('viewFirstSubmit', function () {\n\treturn {\n\t\trestrict: \"E\",\n\t\tcontrollerAs: 'dir',\n\t\tscope: {\n\t\t\tdata: \"=\",\n\t\t\tcallback: \"&\",\n\t\t\tcancelcallback: \"&\",\n\t\t\tsendvfyreqbtnTitle: \"@\",\n\t\t\trmdbtnTitle: \"@\"\n\t\t},\n\t\ttemplate: '<style>.w-10 {width: 10%}.w-35 {width: 35%}</style><div id=\"finturnoverSumtable\" class=\"modal fade fade-scale\" role=\"dialog\"><div class=\"modal-dialog modal-lg sweet\"><div class=\"modal-content pdfPopupScroll\"><div class=\"modal-header\"><button type=\"button\" class=\"close\" data-dismiss=\"modal\">×</button></div><div class=\"modal-body\"><div><div class=\"turnoverContainer\"><h4 class=\"tlt1\">View First Submitted Declaration </h4><div class=\"tableContainer\"><div><table class=\"table table-striped table-bordered finClass\"><tr><td>Financial Year</td><td> {{data.fy}}</td></tr></table></div><div class=\"\"><table class=\"table table-striped table-bordered\"><tr><td class=\"w-10\">1.</td><td class=\"w-35\">GSTIN</td><td> {{data.gstnId}}</td></tr><tr><td>2.(A)</td><td>Legal name</td><td colspan=\"14\"> {{data.legalName || \"-\" }}</td></tr><tr><td>2.(B)</td><td>Trade name,if any</td><td colspan=\"14\"> {{data.tradeName || \"-\" }}</td></tr><tr><td>2.(C)</td><td>ARN</td><td colspan=\"14\"> {{data.arnNo || \"-\" }}</td></tr><tr><td>2.(D)</td><td>ARN Date</td><td colspan=\"14\"> {{data.arnDate || \"-\" }}</td></tr></table></div><div><h4 class=\"subHeadCls\"><span>3. </span>Turnover of the Financial Year for the GSTIN above</h4><div style=\"text-align: right;\">(Amount in ₹ in tables)</div><div class=\"table-responsive\"><table class=\"table table-striped table-bordered turnoverTable\"><tr><td class=\"w-10\">(i)</td><td class=\"w-35\">System computed Turnover</td><td style=\"text-align: right;\"> {{data.sysGstinTO.toPrecision() | currency: \" \"}}</td></tr><tr><td>(ii)</td><td>Reported by Taxpayer</td><td style=\"text-align: right;\"> {{data.gstinTOEnterByUser.toPrecision() | currency: \" \"}}</td></tr></table></div></div><div><h4 class=\"subHeadCls\"><span>4. </span>Verification</h4><span>I hereby solemnly affirm and declare that the information given herein above is true and correct to the best of my knowledge and belief and nothing has been concealed therefrom.</span></div><div class=\"row\" style=\"margin-top: 30px;\"><div class=\"col-sm-6 col-xs-12 \"><p>Date :<strong>{{data.arnDate}}</strong></p></div><div class=\"col-sm-6 col-xs-12 text-right\"><span><strong>Name of Authorized Signatory </strong></span><p>{{data.authName}}</p><span><strong>Designation / Status </strong></span><p>{{data.auth_dg}}</p></div> <div style=\"font-weight: bold;\"><span style=\" text-decoration: underline;\">Note:</span> <span>To see the latest updated system computed GSTIN turnover and AATO on the PAN,Dashboard screen can be referred for the same.</span></div></div></div></div></div></div></div></div></div>',\n\t};\n});\n\nmyApp.directive('financialYrTable', function () {\n\treturn {\n\t\trestrict: \"E\",\n\t\tcontrollerAs: 'dir',\n\t\tscope: {\n\t\t\tdata: \"=\",\n\t\t\tcallback: \"&\",\n\t\t\tcancelcallback: \"&\",\n\t\t\tsendvfyreqbtnTitle: \"@\",\n\t\t\trmdbtnTitle: \"@\"\n\t\t},\n\t\ttemplate: '<style>#finYrtable table{table-layout: fixed;}</style><div id=\"finYrtable\" class=\"modal fade fade-scale\" role=\"dialog\"><div class=\"modal-dialog\"><div class=\"modal-content\"><div class=\"modal-header\"><h4><b>PAN Based Change History</b><button type=\"button\" class=\"close\" data-dismiss=\"modal\">×</button></h4></div><div class=\"modal-body\"><div class=\"table12\"><div class=\"\"><div ng-if=\"!data\">No Records found</div><div class=\"tableRs\" ng-if=\"data\">(Amount in ₹)</div><table ng-if=\"data\" class=\"table inv table-bordered exp table-striped ng-table\"><thead class=\"hhd\"><tr class=\"tableTrHei\"><th class=\"headerWidth2\"><label>GSTIN </label></th><th class=\"headerWidth2\"><label>ARN </label></th><th class=\"headerWidth2\" style=\"width: 19%;\"><label>System Calculated Turnover </label></th><th class=\"headerWidth2\" style=\"width: 19%;\"><label>Turnover reported by Taxpayer </label></th><th class=\"headerWidth2\"><label>Date of changes made by Taxpayer </label></th><th class=\"headerWidth2\"><label>Turnover updated by Tax officer</label></th></tr></thead><tbody><tr class=\"trow tableTrHei\" data-ng-repeat=\"res in data\"><td><label> {{res.gstnId ? res.gstnId : \"Annual Aggregate Turnover Value of all GSTINs\"}}</label></td><td><label> {{res.referenceID}}</label></td><td class=\"rightCls\"><label> {{res.sysCalTurnOver.toPrecision() | currency: \" \"}}</label></td><td class=\"rightCls\"><label> {{res.turnOverChanges.toPrecision() | currency: \" \"}}</label></td><td><label> {{res.insertTime}}</label></td><td class=\"rightCls\"><label> {{res.updateByTaxOff.toPrecision() | currency: \" \"}}</label></td></tr></tbody></table></div></div></div></div></div></div>',\n\t};\n});\n\n//CR-18078 Rectification directives\nmyApp.directive('reasonRectficationTable', function () {\n\treturn {\n\t\trestrict: \"E\",\n\t\tcontrollerAs: 'dir',\n\t\tscope: {\n\t\t\taccidentalslip: \"@\",\n\t\t\tliablitydemand: \"@\",\n\t\t\totherreason: \"@\"\n\t\t},\n\t\ttemplate: '<style>#reasonRectTable::-webkit-scrollbar {display: none;} #reasonRectTable {overflow-y: scroll}</style><div class=\"modal fade\" id=\"reasonRectTable\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"exampleModalCenterTitle\" aria-hidden=\"true\"><div class=\"modal-dialog modal-lg\" role=\"document\"><div class=\"modal-content\"><div class=\"modal-header\"><h4 class=\"modal-title text-center\" style=\"color:#0b1e59\" id=\"exampleModalCenterTitle\">REASON</h4></div><div class=\"modal-body\"><style>#modal_table_id tr:nth-child(even) {background-color: #d2dee7;} #some_table_id:nth-child(even) { background-color: #d2dee7; } #some_table_id:nth-child(odd) { background-color: #f1f1f1; } #nested:nth-child(even) { background-color: #d2dee7; } #nested:nth-child(odd) { background-color: #f1f1f1; } #reasonRectTable table,#reasonRectTable th,#reasonRectTable td { border: 1px solid white; padding: 5px; } #reasonRectTable thead { color: #fff; } #reasonRectTable tr td:nth-child(3) { text-align: center } #reasonRectTable table>thead>tr>th { text-align: left !important } #reasonRectTable textarea { width: 100%; height: 100px; } </style><table class=\"table table-striped\"><thead class=\"navbar-default\"><tr><th scope=\"col\" style=\"width: 45%;\">Reason for Rectification</th><th scope=\"col\">Specified reason</th></tr></thead><tbody id=\"some_table_id\"><tr ng-if=\"accidentalslip !== \\'undefined\\'\"><td>Correction of clerical or arithmetical error arising from accidental slip or omission (other than correction of liablity)</td><td><textarea id=\"accidentalslip\" data-ng-value=\"accidentalslip\" maxlength=\"500\" disabled>{{accidentalslip}}</textarea></td></tr><tr ng-if=\"liablitydemand !== \\'undefined\\'\"><td>Correction of liablity/demand(arising due to clerical or arithmetical error)</td><td><textarea id=\"liablitydemand\" data-ng-value=\"liablitydemand\" maxlength=\"500\" disabled>{{liablitydemand}}</textarea></td></tr><tr ng-if=\"otherreason !== \\'undefined\\'\"><td>Other Reason (Please Specify)</td><td><textarea id=\"otherreason\" data-ng-value=\"otherreason\" maxlength=\"100\" disabled>{{otherreason}}</textarea></td></tr></tbody></table></div><div class=\"modal-footer\"><button type=\"button\" class=\"btn btn-primary\" data-dismiss=\"modal\">Close</button></div></div></div></div>',\n\t};\n});\n\n\n//CR#18285 added new popup for core business activity\nmyApp.directive('coreactivityTable',function(){\n\t\treturn {\n\t\trestrict: \"E\",\n\t\tcontrollerAs: 'dir',\n\t\tscope: {\n\t\t\tdata: \"=\",\n\t\t\tcallback: \"&\",\n\t\t\tsubmitTitle: \"@\",\n\t\t\t\n\t\t},\n\t\t\t\n\t\ttemplate:'<style>#coreTable::-webkit-scrollbar {display: none;}#coreTable {overflow-y:scroll}</style><div class=\"modal fade\" id=\"coreTable\" tabindex=\"-1\" role=\"dialog\" aria-labelledby=\"exampleModalCenterTitle\" aria-hidden=\"true\"><div class=\"modal-dialog modal-lg\" role=\"document\"><div class=\"modal-content\" ><div class=\"modal-header\"><h4 class=\"modal-title text-center\" style=\"color:#0b1e59\" id=\"exampleModalCenterTitle\">CORE BUSINESS SELECTION</h4></div><div class=\"modal-body\"><style>#modal_table_id tr:nth-child(even) { background-color:#d2dee7;}#some_table_id:nth-child(even)  { background-color:#d2dee7;}#some_table_id:nth-child(odd)  { background-color:#f1f1f1;} #nested:nth-child(even)  { background-color:#d2dee7;}#nested:nth-child(odd)  { background-color:#f1f1f1;}  table, th, td {border: 1px solid white;padding: 5px; }thead{color:#fff}tr td:nth-child(3){text-align:center}table>thead>tr>th{text-align:left !important}</style><table class=\"table table-striped\"><thead  class=\"navbar-default\"><tr><th scope=\"col\">S.No</th><th scope=\"col\">Please Identity your Core business as&nbsp;<a data-toggle=\"modal\" data-target=\"#myModal1\"><i class=\"fa fa-info-circle fa-2x\" style=\"color:black\"></i></a></th><th scope=\"col\">Only one selection is allowed</th></tr></thead><tbody id=\"some_table_id\" data-ng-repeat=\"pare in data.data\"><tr><td>{{$index + 1}}</td><td>{{pare.n}}</td><td><input type=\"radio\" name=\"core\" data-ng-model=\"data.coreData\" data-ng-click=\"coreselectionData(pare.c)\" id=\"{{pare.c}}\" value=\"{{pare.c}}\"><label for=\"{{pare.c}}\"></label></td></tr><tr  data-ng-if=\"data.coreData==pare.c&&pare.data.length>0\" data-ng-repeat=\"sub in pare.data\" id=\"nested\"><td>{{getLetter($index)}}</td><td>{{sub.n}}</td><td><input type=\"radio\" name=\"core1\" data-ng-model=\"data.subvalue\" data-ng-click=\"coresubselectionData(sub.c)\"  id=\"{{sub.c}}\" value=\"{{sub.c}}\"><label for=\"{{sub.c}}\"></label></td></tr></tbody></table><div class=\"row\"><div class=\"col-xs-12\"><p style=\"text-decoration: underline;\"><b>NOTES:</b></p></div></div><div class=\"row\"><div class=\"col-xs-12\" style=\"font-size:12px\"><p>1. You can select only one core business activity.</p><p>2. In case all activities are applicable to you, kindly select your core business activity.</p><p>3. Others will include Work Contract and Other Miscellaneous items.</p><p>4. In order to understand the definitions of Manufacturer / Trader / Service Provider, you can click on “Information Button”.</p><p>5. Further if you want to change it in future you can do it by navigating MY PROFILE&gt;CORE BUSINESS ACTIVITY STATUS.</p></div></div></div><div class=\"modal-footer\"><p class=\"err pull-left\" data-ng-if=\"data.validation\">Kindly select one core business activity</p><p class=\"err pull-left\" data-ng-if=\"data.validationTrader\">Kindly select one out of the Trader</p><button type=\"button\" class=\"btn btn-primary\" ng-click=\"selectedvalue(data.coreData,data.subvalue)\">Submit</button></div></div>  </div></div><div class=\"modal\" tabindex=\"-1\" role=\"dialog\" id=\"myModal1\"><div class=\"modal-dialog modal-lg\" role=\"document\"><div class=\"modal-content\" ><div class=\"modal-header\"><h4 class=\"modal-title\" style=\"color:#0b1e59\">Meaning of Manufacturer,Trader and Service Provider</h4></div><div class=\"modal-body\" style=\"padding:0px\"><div class=\"row\"><div class=\"col-xs-12\"><table class=\"table table-striped\"><tbody id=\"modal_table_id\"><tr><td><strong>MANUFACTURER</strong></td> <td><p>A manufacturer is a registered person produces new products from raw materials and components using tools, equipment’s and machines and then sells them to the consumers, wholesalers, distributors, retailers or to the other manufacturers. A manufacturer may sell some more brought out items or may provide some ancillary services with his manufactured goods, but he would continue to be classified as manufacturer because it is the Primary Business Activity.</p></td></tr><tr><td><strong>TRADER</strong></td> <td><p>A trader is a registered person who engages in the buying and selling of goods. Traders have been further classified as - </p><p>• Wholesaler or Distributor</p><p>• Retailer </p><p>Retailer includes a registered person selling goods through e-commerce operators.</p></td></tr><tr><td><strong>SERVICE PROVIDER AND OTHERS</strong></td><td><p>A service provider is a registered person who provides service to a recipient of service and is neither a manufacturer nor a trader.</p><p>e.g. Banking service, IT service, works-contract service, agents, intermediaries, GTAs etc.</p></td></tr></tbody></table></div></div></div><div class=\"modal-footer\"><button type=\"button\" class=\"btn btn-secondary\" data-dismiss=\"modal\">Close</button></div></div></div></div>',\nlink: function (scope, element, attrs){\n\t \t \n scope.getLetter=function(index){\n return String.fromCharCode(97+index);\n }\nscope.coreselectionData=function(coreSelected){\n\tscope.data.subvalue=null;\nscope.data.validation=false;\nscope.data.validationTrader=false;\n\n }\n scope.coresubselectionData=function(subSelected){\n\t if(scope.data.subvalue){\n\t\tscope.data.validationTrader=false; \n\t\tscope.data.validation=false;\n\n\t }\n }\nscope.selectedvalue=function(pareValue,subValue){\nif(pareValue==undefined&&subValue==undefined){\nscope.data.validation=true;\nscope.data.validationTrader=false;\n \t}\n \telse if(pareValue&&subValue==null){\n\t\tangular.forEach(scope.data.data,function(key,value){\nif(key.c==pareValue&&key.data)\n{\n\tscope.data.validation=false;\n\t \t\tscope.data.validationTrader=true;\n\t\t\t}\n\telse if(key.c==pareValue&&key.data==undefined){\n\t\t\t scope.callback({pareValue:pareValue,subValue:subValue});\n\n\t}\n\t})\n\t}\n else{\n\t  \t\tscope.data.validationTrader=false;\nscope.data.validation=false;\n\t scope.callback({pareValue:pareValue,subValue:subValue});\n\t }\n } \n }\n\t};\n\t\n});\n\n\nmyApp.directive('assignZero', function () {\n\treturn {\n\t\trestrict: 'A',\n\t\trequire: 'ngModel',\n\t\tlink: function (scope, elem, attrs, ngModelCtrl) {\n\t\t\telem.on('blur', function () {\n\t\t\t\tif (!elem.val()) {\n\t\t\t\t\telem.val('0');\n\t\t\t\t\tngModelCtrl.$setViewValue('0');\n\t\t\t\t}\n\t\t\t});\n\t\t}\n\t};\n});\n\nif (!String.prototype.repeat) {\n\tString.prototype.repeat = function (count) {\n\t\tif (this === null) {\n\t\t\tthrow new TypeError('can\\'t convert ' + this + ' to object');\n\t\t}\n\t\tvar rpt = '',\n\t\t\tstr = \"\" + this;\n\t\tcount = +count;\n\t\tif (count !== count) {\n\t\t\tcount = 0;\n\t\t}\n\t\tif (count < 0) {\n\t\t\tthrow new RangeError('repeat count must be non-negative');\n\t\t}\n\t\tif (count === Infinity) {\n\t\t\tthrow new RangeError('repeat count must be less than infinity');\n\t\t}\n\t\tcount = Math.floor(count);\n\t\tif (str.length === 0 || count === 0) {\n\t\t\treturn '';\n\t\t}\n\t\t// Ensuring count is a 31-bit integer allows us to heavily optimize the\n\t\t// main part. But anyway, most current (August 2014) browsers can't handle\n\t\t// strings 1 << 28 chars or longer, so:\n\t\tif (str.length * count >= 1 << 28) {\n\t\t\tthrow new RangeError('repeat count must not overflow maximum string size');\n\t\t}\n\n\t\tfor (;;) {\n\t\t\tif ((count & 1) === 1) {\n\t\t\t\trpt += str;\n\t\t\t}\n\t\t\tcount >>>= 1;\n\t\t\tif (count === 0) {\n\t\t\t\tbreak;\n\t\t\t}\n\t\t\tstr += str;\n\t\t}\n\t\t// Could we try:\n\t\t// return Array(count + 1).join(this);\n\t\treturn rpt;\n\t};\n}\n\n\nmyApp.factory('utilFunctions', [\"$q\", \"$log\", \"cache\", \"$rootScope\", \"$filter\", function ($q, $log, cache, $rootScope, $filter) {\n\treturn {\n\t\tinitCache: function () {\n\t\t\t/*var cversion = cache.get('version');\n\t\t\tif (cversion.length > 0) {\n\t\t\t\tif (cversion !== version) {\n\t\t\t\t\tcache.clearAll();\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tcache.set(\"version\", version, 10000000000);\n\t\t\t}*/\n\t\t\tcache.removeExpired();\n\t\t},\n\t\tinitLanguage: function (module) {\n\t\t\tvar default_lang, l;\n\t\t\tif (navigator.cookieEnabled) {\n\t\t\t\tif (cache.get(module + ($().getCookie(\"Lang\") || 'en')).length === 0) {\n\t\t\t\t\t$rootScope.$emit(\"setDefaultLanguage\");\n\t\t\t\t} else {\n\t\t\t\t\treturn cache.get(module + ($().getCookie(\"Lang\") || 'en'));\n\t\t\t\t}\n\t\t\t} else {\n\t\t\t\tdefault_lang = $rootScope.lang || \"en\";\n\t\t\t\tif ($rootScope.langStore && $rootScope.langStore[module + default_lang]) {\n\t\t\t\t\treturn $rootScope.langStore[module + default_lang] || [];\n\t\t\t\t}\n\t\t\t}\n\t\t},\n\t\tcreateDialogue: function (config) {\n\t\t\t$(\"confirm-dialogue,ceiling-dialogue,error-dialogue,success-dialogue,cnclout-dialogue,adhr-table,coreactivity-table,adhr-refund-table,financial-yr-table,turnovr-warn-popup,preview-turnover,final-turnover,view-first-submit,final-approved-turnover\").remove();\n\t\t\t$(\".modal-backdrop\").remove();\n\t\t\t$(\"body\").css(\"padding-right\", \"0\").removeClass(\"modal-open\");\n\t\t\tswitch (config.type) {\n\t\t\tcase 'Warning':\n\t\t\t\treturn (\"<confirm-dialogue data-title='\" + config.title + \"' data-message='\" + config.message + \"' data-callback=\\\"\" + config.callback + \"()\\\" data-ok-title='\" + config.ok_btn_title + \"' data-cancel-title='\" + config.cancel_btn_title + \"' data-cancelcallback=\\\"\" + config.cancelcallback + \"()\\\"></confirm-dialogue>\");\n        case 'WarningWithNoCancelBtn':\n          return (\"<ceiling-dialogue data-title='\" + config.title + \"' data-message='\" + config.message + \"' data-callback=\\\"\" + config.callback + \"()\\\" data-ok-title='\" + config.ok_btn_title + \"'></ceiling-dialogue>\");\n        case 'Logout':\n\t\t\t\treturn (\"<cnclout-dialogue data-title='\" + config.title + \"' data-message='\" + config.message + \"' data-callback=\\\"\" + config.callback + \"()\\\" data-ok-title='\" + config.ok_btn_title +\"'></cnclout-dialogue>\");\t\n\t\t\tcase 'Error':\n\t\t\t\treturn (\"<error-dialogue data-title='\" + config.title + \"' data-message='\" + config.message + \"' data-cancel-title='\" + config.cancel_btn_title + \"'></error-dialogue>\");\n\t\t\tcase 'Success':\n\t\t\t\treturn (\"<success-dialogue data-title='\" + config.title + \"' data-message='\" + config.message + \"'></success-dialogue>\");\n\t\t\tcase 'fileamendment':\n\t\t\t\t\treturn (\"<bank-dialogue data-title='\"+config.title+\"' data-message='\" + config.message + \"' data-submsg = '\"+config.submsg+\"' data-callback=\\\"\" + config.callback + \"()\\\" data-ok-title='\" + config.ok_btn_title + \"' data-viewskipbtn ='\" + config.viewskipbtn + \"'></bank-dialogue>\");\n\t\t\tcase 'Adhrtable':\n\t\t\t\treturn (\"<adhr-table  data-data ='\" + JSON.stringify(config.data) + \"'data-callback=\\\"\" + config.callback + \"()\\\" data-sendvfyreqbtn-title='\" + config.sendvfyreqbtnTitle + \"' data-rmdbtn-title='\" + config.rmdbtnTitle + \"' data-adhrheadingmsg='\" + config.adhrheadingmsg + \"' data-rmdbtnviewvalue='\" + config.rmdbtnviewvalue + \"'data-getadhrsts=\\\"\" + config.getadhrsts + \"()\\\" data-cancelcallback=\\\"\" + config.cancelcallback + \"()\\\"></adhr-table>\");\n\t\t\tcase 'coreactivitytable':\n\t\t\t\treturn (\"<coreactivity-table  data-data ='\" + JSON.stringify(config.data) + \"' data-callback=\\\"\" + config.callback + \"()\\\"  data-submit-title='\" + config.submitTitle +\"'></coreactivity-table>\");\n\t\t\tcase 'AdhrRefundtable':\n\t\t\t\treturn (\"<adhr-refund-table data-data ='\" + JSON.stringify(config.data) + \"'data-callback=\\\"\" + config.callback + \"()\\\" data-refund-text='\" + config.refundText + \"' data-sendvfyreqbtn-title='\" + config.sendvfyreqbtnTitle + \"' data-rmdbtn-title='\" + config.rmdbtnTitle + \"'data-getadhrsts=\\\"\" + config.getadhrsts + \"()\\\" data-cancelcallback=\\\"\" + config.cancelcallback + \"()\\\"></adhr-refund-table>\");\n\t\t\tcase 'compWithDraw': /* CR#18614 code changes */ \n\t\t\t\treturn (\"<comp-dialogue data-message='\" + config.message + \"' data-callback=\\\"\" + config.callback + \"()\\\"></comp-dialogue>\");\n\t\t\t//CR#19321 -AATO\n\t\t\tcase 'financialYrTable':\n\t\t\t\treturn (\"<financial-yr-table  data-data ='\" + JSON.stringify(config.data) + \"' data-callback=\\\"\" + config.callback + \"()\\\"  data-submit-title='\" + config.ok_btn_title +\"'></financial-yr-table>\");\n\t\t\tcase 'turnovrWarnPopup':\n\t\t\t\treturn (\"<turnovr-warn-popup  data-data ='\" + JSON.stringify(config.data) + \"' data-callback=\\\"\" + config.callback + \"()\\\"  data-submit-title='\" + config.ok_btn_title +\"'></turnovr-warn-popup>\");\n\t\t\tcase 'previewTurnover':\n\t\t\t\treturn (\"<preview-turnover data-data ='\" + JSON.stringify(config.data) + \"' data-callback=\\\"\" + config.callback + \"()\\\"  data-submit-title='\" + config.ok_btn_title +\"'></preview-turnover>\");\n\t\t\tcase 'finalTurnover':\n\t\t\t\treturn (\"<final-turnover data-data ='\" + JSON.stringify(config.data) + \"' data-callback=\\\"\" + config.callback + \"()\\\"  data-submit-title='\" + config.ok_btn_title +\"'></final-turnover>\");\n\t\t\tcase 'viewFirstSubmit':\n\t\t\t\treturn (\"<view-first-submit data-data ='\" + JSON.stringify(config.data) + \"' data-callback=\\\"\" + config.callback + \"()\\\"  data-submit-title='\" + config.ok_btn_title +\"'></view-first-submit>\");\n\t\t\tcase 'finalApprovedTurnover':\n\t\t\t\treturn (\"<final-approved-turnover data-data ='\" + JSON.stringify(config.data) + \"' data-callback=\\\"\" + config.callback + \"()\\\"  data-submit-title='\" + config.ok_btn_title +\"'></final-approved-turnover>\");\n\t\t\tcase 'caNumpop':\n\t\t\t\treturn (\"<ca-numpop  data-data ='\" + JSON.stringify(config.data) + \"'data-callback=\\\"\" + config.callback + \"()\\\" data-sendvfyreqbtn-title='\" + config.sendvfyreqbtnTitle + \"' data-rmdbtn-title='\" + config.rmdbtnTitle + \"' data-adhrheadingmsg='\" + config.adhrheadingmsg + \"'data-getadhrsts=\\\"\" + config.getadhrsts + \"()\\\" data-cancelcallback=\\\"\" + config.cancelcallback + \"()\\\"></ca-numpop>\");\n\t\t\tcase 'anxVpop':\n\t\t\t\treturn (\"<anx-vpop  data-data ='\" + JSON.stringify(config.data) + \"'data-callback=\\\"\" + config.callback + \"()\\\" data-sendvfyreqbtn-title='\" + config.sendvfyreqbtnTitle + \"' data-rmdbtn-title='\" + config.rmdbtnTitle + \"' data-anxvheadingmsg1='\" + config.anxvheadingmsg1 +  \"' data-anxvheadingmsg2='\" + config.anxvheadingmsg2 + \"' data-cancelcallback=\\\"\" + config.cancelcallback + \"()\\\"></anx-vpop>\");\t\t\t\t\n\t\t\tcase 'reasonRectficationTable':\n\t\t\t\t\treturn (\"<reason-rectfication-table data-accidentalslip ='\" + config.accidentalslip + \"' data-liablitydemand ='\" + config.liablitydemand + \"' data-otherreason ='\" + config.otherreason + \"'></reason-rectfication-table>\");\n\t\t\tcase 'enableComppop':\n\t\t\t\t\treturn (\"<enable-comppop  data-data ='\" + JSON.stringify(config.data) + \"'data-callback=\\\"\" + config.callback + \"()\\\" data-sendvfyreqbtn-title='\" + config.sendvfyreqbtnTitle + \"' data-rmdbtn-title='\" + config.rmdbtnTitle + \"' data-adhrheadingmsg='\" + config.adhrheadingmsg + \"'data-getadhrsts=\\\"\" + config.getadhrsts + \"()\\\" data-cancelcallback=\\\"\" + config.cancelcallback + \"()\\\"></ca-numpop>\");\n\t\t\tcase 'revokeAuth':\n\t\t\t\t\treturn (\"<revoke-auth-dialogue data-title='\" + config.title + \"' data-message='\" + config.message + \"' data-callback=\\\"\" + config.callback + \"()\\\" data-ok-title='\" + config.ok_btn_title + \"' data-cancel-title='\"  +config.cancel_btn_title + \"' data-input-model=\\\"\" + (config.inputModel || 'revokeAuthValue') + \"\\\"></revoke-auth-dialogue>\");\n\t\t\t}\n\n\t\t},\n\t\t_destroyDialogue: function () {\n\t\t\tvar x = $(\"confirm-dialogue,error-dialogue,success-dialogue,cnclout-dialogue,ceiling-dialogue,revoke-auth-dialogue\").find(\".modal\");\n\t\t\tif (x.length > 0) {\n\t\t\t\t$('#myModal').on('hidden', function () {\n\t\t\t\t\tx.parent().remove();\n\t\t\t\t\t$(\".modal-backdrop\").remove();\n\t\t\t\t});\n\t\t\t\tx.modal('hide');\n\t\t\t}\n\t\t},\n\t\tcreateAlert: function (config) {\n\t\t\treturn (\"<alert-message data-title='\" + config.title + \"' data-type='\" + config.type + \"' data-message='\" + config.message + \"' ></alert-message>\");\n\t\t},\n\t\tcreateDeleteDialogue: function (config) {\n\t\t\treturn (\"<delete-dialogue data-warning-title='\" + config.warning.title + \"' data-success-title='\" + config.success.title +\n\t\t\t\t\"' data-error-title='\" + config.error.title + \"'data-warning-message='\" + config.warning.message +\n\t\t\t\t\"data-success-message='\" + config.success.message + \"' data-error-message='\" + config.error.message + \"'\" +\n\t\t\t\t\"' data-success-callback=\\\"\" + config.callback + \"()\\\" data-error-callback=\\\"\" + config.callback + \"()\\\" \" +\n\t\t\t\t\"data-warning-callback=\\\"\" + config.callback + \"()\\\" data-warning-ok-title='\" + config.warning.ok_btn_title +\n\t\t\t\t\"' data-warning-cancel-title='\" + config.warning.cancel_btn_title + \"'></delete-dialogue>\");\n\t\t},\n\t\tmaskString: function (str, type, length) {\n\t\t\tif (str === undefined) {\n\t\t\t\treturn false;\n\t\t\t}\n\t\t\tif (!length) {\n\t\t\t\tlength = str.length;\n\t\t\t}\n\t\t\tif (str && str !== undefined && str.length >= length) {\n\t\t\t\tvar strlength = str.length,\n\t\t\t\t\tmasklength = length,\n\t\t\t\t\tunmasklength = strlength - length,\n\t\t\t\t\treturnStr;\n\t\t\t\tif (type === 'prepend') {\n\t\t\t\t\treturnStr = (str.replace(RegExp('^([^~,]{' + masklength + '})([^~,]{' + unmasklength + '})$'),\n\t\t\t\t\t\t