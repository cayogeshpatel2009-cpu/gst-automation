DealerCtrl\", nonmigratedDealerCtrl);\r\nmyApp.controller(\"migratedDealerCtrl\", migratedDealerCtrl);\r\nmyApp.controller(\"oidarCtrl\", oidarCtrl);\r\nmyApp.controller(\"uinCtrl\", uinCtrl);\r\n\r\nnonmigratedDealerCtrl.$inject = ['$scope', 'cache', '$rootScope', 'shareData', '$location', 'ajax', '$route', 'version', '$window', '$timeout', '$templateCache', '$log', 'utilFunctions', 'validations', '$compile'];\r\n\r\n\r\nfunction nonmigratedDealerCtrl($scope, cache, $rootScope, shareData, $location, ajax, $route, version, $window, $timeout, $templateCache, $log, utilFunctions, validations, $compile) {\r\n\t/* init controller */\r\n\tutilFunctions.initCache();\r\n\t$scope.servers = $().getServers();\r\n\t$scope.trans = utilFunctions.initLanguage('services');\r\n\t$rootScope.$on(\"LangChanged\", function(event, mass) {\r\n\t\t$scope.trans = utilFunctions.initLanguage('services');\r\n\t});\r\n\t$scope.$on('$viewContentLoaded', function() {\r\n\t\t$window.scrollTo(0, 0);\r\n\t\tangular.element(document.querySelector('[autofocus]')).focus();\r\n\t});\r\n\t/*init completed*/\r\n\t$scope.UserDetails = true;\r\n\t$scope.alertMsgLogin = true;\r\n\t$scope.validations = validations;\r\n\t$scope.oneClick = false;\r\n\t$scope.migratehide= true;\r\n \t$scope.errors = {};\r\n\t\r\n\t\r\n    \r\n    /* services code */\r\n    $scope.setPristine = function(form, ele, prop) {\r\n        $scope[form][ele].$setValidity(prop, true);\r\n    }\r\n    \r\n    \r\n   var patterns = {};\r\n    patterns.username = /^([a-zA-Z0-9\\_\\-\\.]){8,15}$/;\r\n    patterns.uppercase = /[A-Z]/;\r\n    patterns.lowercase = /[a-z]/;\r\n    patterns.number = /[0-9]/;\r\n    patterns.symbol = /[\\@\\!\\#\\%\\^\\$\\&\\`\\*\\-\\_\\+]+/;\r\n    patterns.pwd = /(?=.*[a-z])(?=.*[A-Z])(?=.*[0-9])(?=.*^[a-zA-Z0-9\\@\\!\\#\\%\\^\\$\\&\\`\\*\\-\\_\\+]*$).{8,15}/;\r\n    $(\".password-helper\").keyup(function() {\r\n        var val = $(this).val();\r\n        if (val.length > 7) {\r\n            $(this).parent().find(\".minlength\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".minlength\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".minlength\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".minlength\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.uppercase.test(val)) {\r\n            $(this).parent().find(\".upperChar\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".upperChar\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".upperChar\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".upperChar\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.lowercase.test(val)) {\r\n            $(this).parent().find(\".lowerChar\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".lowerChar\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".lowerChar\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".lowerChar\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.number.test(val)) {\r\n            $(this).parent().find(\".numberic\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".numberic\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".numberic\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".numberic\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.symbol.test(val)) {\r\n            $(this).parent().find(\".symbol\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".symbol\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".symbol\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".symbol\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.pwd.test(val)) {\r\n            $(this).parent().find(\".validpwd\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".validpwd\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".validpwd\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".validpwd\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n    });\r\n    \r\n    \r\n   \r\n//$scope.securityQ = false;    \r\n    \r\n    \r\n    //non-migrate createuser cred submit\r\n $scope.securityTab = function() {\r\n$scope.errors[\"createuser\"] = false;\r\n        if ($scope.userDet.gstUser.$valid && $scope.userDet.userCred.$valid && $scope.userDet.retype.$valid) {\r\n            if ($scope.cu.uPassword === $scope.cu.repassword) {\r\n                var userDetails = {\r\n                    NewUsername: $scope.cu.user,\r\n                    Password: $scope.cu.uPassword\r\n\r\n                }\r\n                var userNameDetails = JSON.stringify(userDetails);\r\n\r\n                ajax.post(\"/services/auth/check/username\", userNameDetails).then(function(response) {\r\n\r\n                    //$log.debug(response);\r\n\r\n\r\n                    if (response.message === \"true\") {\r\n                        $scope.oneClick = false;\r\n                       // $scope.securityQ = true;\r\n                        $scope.UserDetails = true;\r\n                        $('#sec').removeClass('not-active');\r\n                        $('#sec').addClass('on-page');\r\n                        $('#newc').show();\r\n                        /* $('#newc1').show();\r\n                        $('#newc1').removeClass('on-page'); */\r\n                        $('.z3').addClass('step-on');\r\n                       /*  $('.z3').addClass('step-done');\r\n                        $('.z4').addClass('step-on'); */\r\n                      \r\n                        $scope.alertMsgLogin = true;\r\n\t\t\t\t\t\t$scope.cusubmit();\r\n\r\n\r\n\r\n                    }\r\n                    \r\n                    else {\r\n                    if (response && response.errorCode) {\r\n                        \r\n                       \r\n                        delete $scope.cu.uPassword;\r\n                        delete $scope.cu.repassword;\r\n                        $(\"#pwd1\").focus();\r\n\r\n                        switch (response.errorCode) {\r\n                          \r\n                               \r\n                            case \"SWEB_9010\":\r\n                                //\"Username should be of 8 to 15 characters (where the minimum length is 8 characters and maximum length is 15 characters)\" + \"which should start with an alphabet, can be contain alphabets, numbers and special characters (dot [.] or underscore  [_] or hyphen [-])\";\r\n                               \r\n                              \r\n                            case \"SWEB_9011\":\r\n                                //\"Password should be of 8 to 15 characters (where the minimum length is 8 characters and maximum length is 15 characters) \" + \"which should comprise of at least one number, special character \" + \"and letters( at least one upper and lower case)\";\r\n                              \r\n                                \r\n                            case \"SWEB_9030\":\r\n                                //The username entered matches the pattern of PAN. Kindly choose a different username\"\r\n                               \r\n                            case \"SWEB_9021\":\r\n                                //Session expired. Kindly Login again.\";\r\n                              \r\n                                \r\n                            case \"SWEB_9009\":\r\n                                //Username already exists. Kindly choose another username.\";\r\n                               \r\n                            case \"SWEB_8000\":\r\n                            case \"false\":\r\n                            case false:\r\n                               \r\n                                //System error\t\r\n                                \r\n                                $scope.errors[\"createuser\"] = true;\r\n                                $scope.userDet.$setPristine();\r\n\r\n                                $scope.errors[\"createuser_desc\"] = $scope.trans[\"ERR_\" + response.errorCode];\r\n                                break;\r\n                        }\r\n                    } else {\r\n                        $scope.errors[\"createuser\"] = true;\r\n                        $scope.errors[\"createuser_desc\"] = $scope.trans[\"ERR_SWEB_8000\"];\r\n                    }\r\n                    if ($scope.errors[\"createuser\"] && $scope.errors[\"createuser_desc\"] != \"\") {\r\n                        var alert_dlg = utilFunctions.createAlert({\r\n                            \"title\": \"\",\r\n                            \"type\": \"danger\",\r\n                            \"message\": $scope.errors[\"createuser_desc\"]\r\n                        });\r\n                        $('[name=errContainer]').empty().append($compile(alert_dlg)($scope));\r\n                    }\r\n                }\r\n\r\n\r\n                }, function(response) {\r\n                    $log.debug(response);\r\n                })\r\n\r\n            }\r\n        } else {\r\n            $scope.alertMsgLogin = true;\r\n        }\r\n\r\n    };\r\n    \r\n   // console.log($scope.ques);\r\n     var security;\r\n  $scope.cusubmit = function() {\r\n\r\n        if ($scope.userDet.$valid ) {\r\n\r\n\r\n            $scope.oneClick = false;\r\n\r\n            \r\n            var userDetails = {\r\n                NewUsername: $scope.cu.user,\r\n                Password: $scope.cu.uPassword,\r\n\t\t\t\temail: $scope.cu.email,\r\n                mobileNo: $scope.cu.Phone\r\n\r\n            };\r\n           \r\n\r\n\r\n            var userDetails1 = JSON.stringify(userDetails);\r\n   \r\n\r\n            ajax.post(\"/services/auth/create/username\", userDetails1, function () {\r\n                    $().blockPage(true);\r\n                }, function () {\r\n                    $().blockPage(false);\r\n                \r\n                }).then(function(response) {\r\n               \r\n                if (response.url === \"/auth/logout\" && response.successCode===\"SWEB_9015\") {\r\n                    $scope.alertMsgLogin = true;\r\n                    $window.location.href = \"login?usrcr=1\";\r\n\r\n                }\r\n                else if (response.errorCode === \"428\") {\r\n                    $scope.alertMsgLogin = true;\r\n                    $window.location.href = \"/services/error/dataerror\";\r\n\r\n\r\n\r\n                }\r\n                else if (response.errorCode === \"SWEB_9021\") {\r\n                    if ($scope.userDet.$setPristine) {\r\n                        $scope.userDet.$setPristine();\r\n                        $scope.oneClick = false;\r\n                        $scope.alertMsgLogin = false;\r\n                        $scope.login = false;\r\n                        $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];;\r\n                        $window.scrollTo(0, 0);\r\n                    }\r\n                }\r\n                else if (response.message === null) {\r\n                    \r\n                    if ($scope.userDet.$setPristine) {\r\n                        $scope.userDet.$setPristine();\r\n                        $scope.oneClick = false;\r\n                        $scope.alertMsgLogin = false;\r\n                        $scope.login = false;\r\n                        $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];;\r\n                        $window.scrollTo(0, 0);\r\n                    }\r\n                } \r\n                if (response.errorCode === \"SWEB_9009\") {\r\n                    if ($scope.userDet.$setPristine) {\r\n                        $scope.userDet.$setPristine();\r\n\r\n                        $scope.oneClick = false;\r\n                        $scope.alertMsgLogin = false;\r\n                        $scope.login = false;\r\n                        $('#otp').hide();\r\n                        $('#otp1').show();\r\n                        $('.z2').removeClass(\"step-on\");\r\n                        $('.z2').addClass(\"step-done\");\r\n                        $('#newc').show();\r\n                       /*  $('#newc1').hide();\r\n                        $('.z3').removeClass(\"step-done\"); */\r\n                        $('.z3').addClass(\"step-on\");\r\n                        /* $('#newc').addClass('on-page');\r\n                        $('#newc').removeClass('not-active'); */\r\n\r\n                        $scope.focus($('#uname'));\r\n                        $scope.cu.uPassword = null;\r\n                        $scope.cu.repassword = null;\r\n                        //$scope.securityQ = false;\r\n                        $scope.UserDetails = true;\r\n                        $scope.GenOtp = false;\r\n                        $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n\r\n                        $window.scrollTo(0, 0);\r\n\r\n                    }\r\n                } else if (response.errorCode === \"SWEB_8000\") {\r\n                    if ($scope.userDet.$setPristine) {\r\n                        $scope.userDet.$setPristine();\r\n                        $scope.oneClick = false;\r\n                        $scope.alertMsgLogin = false;\r\n                        $scope.login = false;\r\n                        $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        $window.scrollTo(0, 0);\r\n                    }\r\n                } else if(response.errorCode && response.successCode==!(\"SWEB_9015\")) {\r\n                        if ($scope.userDet.$setPristine) {\r\n                            $scope.userDet.$setPristine();\r\n                            $scope.cu.uPassword = null;\r\n                            $scope.alertMsgLogin = false;\r\n                            $scope.login = false;\r\n                            $scope.errorMsg1 = $scope.trans[\"ERR_SWEB_8000\"];\r\n                            $window.scrollTo(0, 0);\r\n                        }\r\n                    }\r\n \r\n\r\n            }, function(response) {\r\n\t\t\t\t$scope.alertMsgLogin = true;\r\n            })\r\n\r\n\r\n        } else {\r\n            $scope.alertMsgLogin = true;\r\n        }\r\n    }  \r\n   \r\n}\r\n\r\n\r\n\r\nmigratedDealerCtrl.$inject = ['$scope', 'cache', '$rootScope', 'shareData', '$location', 'ajax', '$route', 'version', '$window', '$timeout', '$templateCache', '$log', 'utilFunctions', 'validations', '$compile'];\r\n\r\nfunction migratedDealerCtrl($scope, cache, $rootScope, shareData, $location, ajax, $route, version, $window, $timeout, $templateCache, $log, utilFunctions, validations, $compile) {\r\n\t\r\n\t/* init controller */\r\n\tutilFunctions.initCache();\r\n\t$scope.servers = $().getServers();\r\n\t$scope.trans = utilFunctions.initLanguage('services');\r\n\t$rootScope.$on(\"LangChanged\", function(event, mass) {\r\n\t\t$scope.trans = utilFunctions.initLanguage('services');\r\n\t});\r\n\t$scope.$on('$viewContentLoaded', function() {\r\n\t\t$window.scrollTo(0, 0);\r\n\t\tangular.element(document.querySelector('[autofocus]')).focus();\r\n\t});\r\n\t/*init completed*/\r\n\t\r\n   var patterns = {}; \r\n    $scope.validations = validations;\r\n    $scope.emailCk = true;\r\n    $scope.alertMsgLogin = true;\r\n    $scope.oneClick = false;\r\n    $scope.migratehide = true;\r\n    $scope.errors = {};\r\n   \r\n    patterns.username = $scope.validations.formats.pwdtooltip_user;\r\n    patterns.uppercase = $scope.validations.formats.pwdtooltip_uppercase;\r\n    patterns.lowercase = $scope.validations.formats.pwdtooltip_lowercase;\r\n    patterns.number = $scope.validations.formats.pwdtooltip_num;\r\n    patterns.symbol = $scope.validations.formats.pwdtooltip_symbol;\r\n    patterns.pwd = $scope.validations.formats.pwdtooltip_pwd;\r\n    $(\".password-helper\").keyup(function() {\r\n        var val = $(this).val();\r\n        if (val.length > 7) {\r\n            $(this).parent().find(\".minlength\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".minlength\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".minlength\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".minlength\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.uppercase.test(val)) {\r\n            $(this).parent().find(\".upperChar\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".upperChar\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".upperChar\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".upperChar\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.lowercase.test(val)) {\r\n            $(this).parent().find(\".lowerChar\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".lowerChar\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".lowerChar\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".lowerChar\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.number.test(val)) {\r\n            $(this).parent().find(\".numberic\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".numberic\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".numberic\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".numberic\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.symbol.test(val)) {\r\n            $(this).parent().find(\".symbol\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".symbol\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".symbol\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".symbol\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n        if (patterns.pwd.test(val)) {\r\n            $(this).parent().find(\".validpwd\").removeClass(\"fa-times\").addClass(\"fa-check\");\r\n            $(this).parent().find(\".validpwd\").parent().removeClass(\"text-danger\").addClass(\"text-success\");\r\n        } else {\r\n            $(this).parent().find(\".validpwd\").addClass(\"fa-times\").removeClass(\"fa-check\");\r\n            $(this).parent().find(\".validpwd\").parent().addClass(\"text-danger\").removeClass(\"text-success\");\r\n        }\r\n    });\r\n    \r\n   \r\n    \r\n    /* services code */\r\n    $scope.setPristine = function(form, ele, prop) {\r\n        $scope[form][ele].$setValidity(prop, true);\r\n    }\r\n\r\n    //createusername generate OTP\r\n     $scope.genOtp = function() {\r\n\r\n\r\n        if ($scope.emailck.userEmail.$valid && $scope.emailck.userMobile.$valid) {\r\n\r\n            var emailmobile = {\r\n\r\n                email: $scope.cu.email,\r\n                mobileNo: $scope.cu.Phone\r\n            }\r\n\r\n            ajax.post(\"/services/request/otp/migrateddealer\", emailmobile).then(function(response) {\r\n                $log.debug(response);\r\n                if (response.errorCode === \"SWEB_9004\") {\r\n                    $scope.alertMsgLogin = false;\r\n                    $scope.oneClick = false;\r\n\r\n                    $scope.errorMsg1 = \"Please enter a valid email address\";\r\n                } else if (response.errorCode === \"SWEB_9005\") {\r\n                    $scope.alertMsgLogin = false;\r\n                    $scope.oneClick = false;\r\n                    $scope.errorMsg1 = \"Please enter a valid mobile number.\";\r\n                } else if (response.message === \"true\") {\r\n                    $scope.GenOtp = true;\r\n\r\n                    $scope.emailCk = false;\r\n\r\n                    $scope.otperror = false;\r\n                } else if (response.message === \"false\") {\r\n                    $scope.alertMsgLogin = false;\r\n                    $scope.oneClick = false;\r\n                    $scope.errorMsg1 = \"OTP is not generated. Kindly click on Continue to regenerate OTP\";\r\n                } else if (response.errorCode === \"SWEB_9021\") {\r\n                    $scope.alertMsgLogin = false;\r\n                    $scope.oneClick = false;\r\n                    $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                } else if (response.errorCode === \"SWEB_8000\") {\r\n                    $scope.alertMsgLogin = false;\r\n                    $scope.oneClick = false;\r\n                    $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                }\r\n\r\n\r\n            }, function(response) {\r\n                $log.debug(response);\r\n            })\r\n\r\n        } else {\r\n            $scope.alertMsgLogin = true;\r\n            $('#email').focus();\r\n\r\n        }\r\n\r\n    }\r\n     \r\n     \r\n     //createusername validateOTP\r\n     $scope.proceed = function() {\r\n\r\n        if ($scope.OtpCk.$valid) {\r\n            $scope.oneClick = true;\r\n\r\n            var otps = {\r\n                email: $scope.cu.email,\r\n                mobileNo: $scope.cu.Phone,\r\n                emailOtp: $scope.cu.mailotp,\r\n                smsOtp: $scope.cu.smsotp\r\n            }\r\n\r\n            ajax.post(\"/services/validate/migrateddealer/otp\", otps).then(function(response) {\r\n\r\n                $log.debug(response);\r\n                if (response.message == \"Y\") {\r\n                    $scope.oneClick = false;\r\n                    $('#otp').hide();\r\n                    $('#otp1').show();\r\n                    $('.z2').removeClass(\"step-on\");\r\n                    $('.z2').addClass(\"step-done\");\r\n                    $scope.alertMsgLogin = true;\r\n                    $('.z3').addClass(\"step-on\");\r\n                    $('#newc').addClass('on-page');\r\n                    $('#newc').removeClass('not-active');\r\n                    $scope.UserDetails = true;\r\n                    $scope.GenOtp = false;\r\n                } else if (response.message == null && response.errorCode == \"SWEB_9003\") {\r\n                    if ($scope.OtpCk.$setPristine) {\r\n                        $scope.OtpCk.$setPristine();\r\n\r\n                        $scope.oneClick = false;\r\n                        $scope.cu.smsotp = null;\r\n                        $scope.cu.mailotp = null;\r\n                        $scope.alertMsgLogin = false;\r\n                        $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        //$scope.otperror = true;\r\n                    }\r\n\r\n                } else if (response.message == null && response.errorCode == \"SWEB_8000\") {\r\n                    if ($scope.OtpCk.$setPristine) {\r\n                        $scope.OtpCk.$setPristine();\r\n\r\n                        $scope.oneClick = false;\r\n                        $scope.cu.smsotp = null;\r\n                        $scope.cu.mailotp = null;\r\n                        $scope.alertMsgLogin = false;\r\n                        $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        $scope.otperror = false;\r\n                    }\r\n\r\n                } else if (response.message == null && response.errorCode == \"SWEB_9021\") {\r\n                    if ($scope.OtpCk.$setPristine) {\r\n                        $scope.OtpCk.$setPristine();\r\n\r\n                        $scope.oneClick = false;\r\n                        $scope.cu.smsotp = null;\r\n                        $scope.cu.mailotp = null;\r\n                        $scope.alertMsgLogin = false;\r\n                        $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                        $scope.otperror = false;\r\n                    }\r\n\r\n                }\r\n            }, function(response) {\r\n                $log.debug(response);\r\n            });\r\n        } else {\r\n            $scope.alertMsgLogin = true;\r\n        }\r\n\r\n    }\r\n     \r\n     //createusername resendOTP\r\n      $scope.resend = function() {\r\n\r\n        $scope.cu.mailotp = null;\r\n        $scope.cu.smsotp = null;\r\n        $scope.genOtp();\r\n        $scope.alertMsgLogin = true;\r\n    };\r\n    \r\n    //createusername savenewcred\r\n    $scope.securityTab = function() {\r\n\r\n        if ($scope.userDet.gstUser.$valid && $scope.userDet.userCred.$valid && $scope.userDet.retype.$valid) {\r\n            if ($scope.cu.uPassword === $scope.cu.repassword) {\r\n\r\n\r\n                var userDetails = {\r\n                    NewUsername: $scope.cu.user,\r\n                    Password: $scope.cu.uPassword\r\n\r\n                }\r\n                var userNameDetails = JSON.stringify(userDetails);\r\n\r\n                ajax.post(\"/services/auth/check/username\", userNameDetails).then(function(response) {\r\n\r\n                    $log.debug(response);\r\n\r\n\r\n                    if (response.message === \"true\") {\r\n             \t\t\t//$scope.securityQ = true;\r\n                        $('#sec').removeClass('not-active');\r\n                        $('#sec').addClass('on-page');\r\n                        $('#newc').show();\r\n                        $('.z3').addClass('step-on');\r\n                        $('#otp').hide();\r\n                        $('#otp1').show();\r\n                        $scope.alertMsgLogin = true;\r\n\t\t\t\t\t\t$scope.cusubmit();\r\n\r\n\r\n\r\n                    } else if (response.errorCode === \"SWEB_9008\") {\r\n                        if ($scope.userDet.$setPristine) {\r\n                            $scope.userDet.$setPristine();\r\n                            $scope.cu.uPassword = null;\r\n                            $scope.cu.repassword = null;\r\n                            $scope.alertMsgLogin = false;\r\n                            $scope.login = false;\r\n\r\n\r\n                            $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                            $window.scrollTo(0, 0);\r\n                        }\r\n                    } else if (response.errorCode === \"SWEB_9010\") {\r\n                        if ($scope.userDet.$setPristine) {\r\n                            $scope.userDet.$setPristine();\r\n                            $scope.cu.uPassword = null;\r\n                            $scope.cu.repassword = null;\r\n                            $scope.a