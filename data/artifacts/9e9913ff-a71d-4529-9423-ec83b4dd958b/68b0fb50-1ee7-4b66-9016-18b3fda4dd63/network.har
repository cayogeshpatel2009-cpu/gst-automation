\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/locategstp\"\r\n                                        data-ng-class=\"{'disabledanchor' :udata.disableMenu}\">Locate GST Practitioner\r\n                                        (GSTP)</a>\r\n                                </li>\r\n                                <li ng-show=\"udata && (udata.role == 'login' ||udata.utype=='O')\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/locategstp\"\r\n                                        data-ng-class=\"{'disabledanchor' :udata.disableMenu}\">Locate GST Practitioner\r\n                                        (GSTP)</a>\r\n                                </li>\r\n                                <li ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin') && (udata.utype== 'TP' || udata.utype=='NR'||udata.utype== 'TD'||udata.utype== 'TS'||udata.utype== 'O' || udata.utype== 'TPCAEX'||udata.utype== 'NREX' || udata.utype=='AR' || udata.utype=='UN') \"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/engdisenggstp\"\r\n                                        data-ng-class=\"{'disabledanchor' :udata.disableMenu}\">Engage / Disengage GST\r\n                                        Practitioner (GSTP)</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.regType=='TP' || udata.regType=='NT' || udata.regType=='CA') && udata.utype!='NREX'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/itc02/pendingactions\"\r\n                                        data-ng-class=\"{'disabledanchor' :udata.disableMenu}\">ITC02-Pending for\r\n                                        action</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && udata.utype != 'ES' && (udata.role == 'login' || udata.role == 'panLogin' || udata.utype=='O')\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/notices\"\r\n                                        data-ng-class=\"{'disabledanchor' :udata.disableMenu}\">View Additional\r\n                                        Notices/Orders</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' || udata.utype=='UN' || udata.utype=='O')\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/litserv/auth/api/case/hrng/get\"\r\n                                        data-ng-class=\"{'disabledanchor' :udata.disableMenu}\">Cause List</a>\r\n                                </li>\r\n                                <li ng-hide=\"udata && (udata.role == 'login' || udata.role == 'panLogin' || udata.utype == 'AR')\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                             