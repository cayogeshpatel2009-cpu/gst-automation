                  data-ng-if=\"udata.utype !== 'CO' && udata.utype!='TD' && udata.utype !== 'TS' && udata.utype !== 'O' && udata.utype !== 'UN' &&  udata.utype !='TPCAEX' && udata.utype !='NREX'\">\r\n                                        <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/transition/trans1\"\r\n                                            target=\"_self\">Transition Forms</a>\r\n                                    </li>\r\n                                    <li\r\n                                        data-ng-hide=\"udata.utype=='UN' || udata.utype=='TD' || udata.utype == 'O' || udata.utype =='TPCAEX' || udata.utype =='NREX' \">\r\n                                        <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/itcform/links\">ITC\r\n                                            Forms</a>\r\n                                    </li>\r\n                                    <li data-ng-show=\"udata.regType=='CA' && udata.appStatus == 'E'\">\r\n                                        <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/finalreturn\">Final\r\n                                            Return</a>\r\n                                    </li>\r\n                                    <li\r\n                                        data-ng-if=\"udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CO'  || udata.regType == 'TP')\">\r\n                                        <a target=\"_self\"\r\n                                            data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/annualreturn\">Annual\r\n                                            Return</a>\r\n                                    </li>\r\n                                    <li\r\n                                        data-ng-if=\"(udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP')) || (udata.utype == 'TPCAEX' && udata.regType == 'CA') || (udata.utype == 'O')\">\r\n                                        <a target=\"_self\"\r\n                                            data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/comptds\">TDS and\r\n                                            TCS credit received </a>\r\n                                    </li>\r\n                                    <!--Comparison report CR 17153 - adding the link to landing page changes begin-->\r\n                                    <li\r\n                                        data-ng-if=\"udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP')\">\r\n                                        <a data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/comparison\">Tax\r\n                                            liabilities and ITC comparison</a>\r\n                                    </li>\r\n                                    <!--Comparison report CR 17153 - adding the link to landing page changes end-->\r\n                                    <!--Optin for Quarterly Return link CR- 18145-->\r\n                                    <li\r\n                                        data-ng-if=\"udata.regType=='NT' || udata.regType=='TP'  || udata.regType =='CO'\">\r\n                                        <a data-ng-click=\"manageProfile()\">Opt-in for Quarterly Return</a>\r\n                                    </li>\r\n                                    <!--Optin for Quarterly Return link CR- 18145 End-->\r\n                                    <!-- CR-23810 Liability Mismatch Starts -->\r\n                                    <li\r\n                                        data-ng-if=\"udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP' || udata.sezFlag\">\r\n                                        <a target=\"_self\"\r\n                                            data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/returnComp\">Return\r\n                                            Compliance</a>\r\n                                    </li>\r\n\r\n                                    <!-- CR 25787 IMS Dashboard-->\r\n                                    <li\r\n                                        data-ng-if=\"udata && udata.role == 'login' && (udata.utype == 'TP'|| udata.utype == 'TPCAEX') && imsLinkEnable && (udata.regType == 'NT' ||  udata.regType=='CA'|| udata.regType == 'CO' || udata.regType=='TP' || udata.sezFlag)\">\r\n                                        <a target=\"_self\"\r\n                                            data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/imsweb/auth/imsDashboard\">Invoice\r\n                                            Management System (IMS) Dashboard</a>\r\n                                    </li>\r\n                                    <!-- CR 25787 IMS Dashboard-->\r\n\r\n                                    <!-- CR-23810 Liability Mismatch End -->\r\n                                    <!-- DO NOT REMOVE THIS CODE CR 25786 Credit Limit Check for High Risk Taxpayer Starts -->\r\n                                    <!-- <li\r\n                                data-ng-if=\"udata && udata.role == 'login' && udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'CA' || udata.regType == 'CO' || udata.regType=='TP' || udata.sezFlag)\">\r\n                                    <a target=\"_self\" data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns/auth/increasingcreditlimit/alreadyraisedreq\">Application for increasing credit limit</a>\r\n                                </li> -->\r\n                                    <!-- DO NOT REMOVE THIS CODE CR 25786 Credit Limit Check for High Risk Taxpayer Ends  -->\r\n                                    <!-- CR26009 Changes -->\r\n\r\n                                    <!-- CR 26286 Application for Unbarring Returns starts -->\r\n                                    <li data-ng-if=\"udata && udata.role == 'login'\">\r\n                                        <a target=\"_self\"\r\n                                            data-ng-href=\"{{servers.GST_RETURNS_R1_URL}}/returns2/auth/unbarringreturns/alreadyraisedreq\">Application\r\n                                            for Unbarring Returns</a>\r\n                                    </li>\r\n                                    <!-- CR 26286 Application for Unbarring Returns ends  -->\r\n                                    <li data-toggle=\"tooltip\"\r\n                                        title=\"Only manufacturer of pan masala/tobacco products allowed to file.\"\r\n                                        data-ng-if=\"udata && udata.role == 'login' && udata.isManufacturer == 'Y' && (udata.appStatus == 'C' || udata.appStatus == 'A') && udata.utype == 'TP' && (udata.regType == 'NT' || udata.regType == 'TP')\">\r\n                                        <a target=\"_self\"\r\n                                            data-ng-href=\"{{servers.GST_SRM_R1_URL}}/srmweb/auth/srmsearch\">SRM Forms\r\n                                            (Pan Masala/Tobacco)</a>\r\n                                    </li>\r\n                                </ul>\r\n                            </div>\r\n                        </li>\r\n                        <li class=\"has-sub\" data-ng-hide=\"udata.utype == 'RF' || udata.utype == 'ES'\"\r\n                            data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\" data-placement=\"top\">\r\n                            <a data-ng-show=\"(udata && udata.role == 'panLogin')\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/quicklinks/payments/trn\"\r\n                                data-ng-class=\"{'disabledanchor' : udata.disableMenu, 'dropdown-toggle' : !udata.disableMenu}\">Payments</a>\r\n                            <a data-ng-show=\"!udata\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/quicklinks/payments\"\r\n                                data-ng-class=\"{'disabledanchor' : udata.disableMenu, 'dropdown-toggle' : !udata.disableMenu}\">Payments</a>\r\n                            <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/quicklinks/payments\"\r\n                                data-ng-class=\"{'disabledanchor' : udata.disableMenu, 'dropdown-toggle' : !udata.disableMenu}\">Payments</a>\r\n                            <div data-ng-class=\"{'disabledisplay' : udata.disableMenu && enableServices}\">\r\n                                <ul class=\"isubmenu pay\"\r\n                                    data-ng-class=\"{'post': udata && udata.role == 'login'  && udata.utype!='O' && udata.utype!='UN' && udata.utype!='AR', 'ar': udata && udata.role == 'login' && udata.utype == 'AR', 'pan': udata && udata.role == 'panLogin' && udata.utype!='UN', 'oidr': udata && udata.utype=='O', 'uinu': udata && udata.utype=='UN' && udata.role == 'login','uinu pre': udata && udata.utype=='UN' &&  udata.role == 'panLogin'}\">\r\n                                    <li>\r\n                                        <a data-ng-show=\"!udata\"\r\n                                            data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/\">Create Challan</a>\r\n                                        <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                            data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/\">Create\r\n                                            Challan</a>\r\n                                        <a data-ng-show=\"(udata && udata.role == 'panLogin')\"\r\n                                            data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/challanhistory\">Challan\r\n                                            History</a>\r\n                                    </li>\r\n                                    <li data-ng-show=\"udata && udata.role == 'login' && udata.utype !='NREX'\">\r\n                                        <a data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/savedchallan\">Saved\r\n                                            Challans</a>\r\n                                    </li>\r\n                                    <li>\r\n                                        <a data-ng-show=\"udata && udata.role == 'login' && udata.utype !='NREX'\"\r\n                                            data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/challanhistory\">Challan\r\n                                            History</a>\r\n                                        <a data-ng-show=\"!udata \"\r\n                                            data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/trackpayment\">Track\r\n                                            Payment Status</a>\r\n\r\n                                    </li>\r\n                                    <li\r\n                                        data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' ) && udata.utype!='TPCAEX' && udata.utype!='NREX' && udata.utype != 'AR'\">\r\n                                        <a\r\n                                            data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/litserv/auth/deferred/instalmentpayment\">Application\r\n                                            for Deferred Payment/Payment in Instalments</a>\r\n                                    </li>\r\n                                    <li\r\n                                        data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' ) && udata.utype!='TPCAEX' && udata.utype!='NREX' && udata.utype != 'AR'\">\r\n                                        <a\r\n                                            data-ng-href=\"{{servers.GST_PAYMENTS_R1_URL}}/payment/auth/ledger/instalmentcalendar\">Instalment\r\n                                            Calendar</a>\r\n                                    </li>\r\n                                    <li>\r\n                                        <a data-ng-show=\"!udata\"\r\n                                            data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/grievance\">Grievance\r\n                                            against Payment(GST PMT-07)</a>\r\n                                        <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                            data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/grievance\">Grievance\r\n                                            against Payment(GST PMT-07)</a>\r\n                                    </li>\r\n\r\n                                </ul>\r\n                            </div>\r\n\r\n                        </li>\r\n\r\n                        <li class=\"has-sub\" data-ng-class=\"{'disabled' :udata.disableMenu && !enableServices}\">\r\n                            <a data-ng-show=\"!udata\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/quicklinks/userservices\"\r\n                                data-ng-class=\"{'disabledanchor' : udata.disableMenu, 'dropdown-toggle' : !udata.disableMenu}\">User\r\n                                Services</a>\r\n                            <div data-ng-if=\"enableServices\">\r\n                                <a data-ng-show=\"udata && (udata.role == 'login'||udata.role == 'panLogin')\"\r\n                                    data-ng-class=\"{'disabledanchor' : udata.disableMenu && !enableServices, 'dropdown-toggle' : !udata.disableMenu && !enableServices}\"\r\n                                    style='display: block;text-decoration: none;'>User Services</a>\r\n                            </div>\r\n                            <div data-ng-if=\"!enableServices\">\r\n                                <a data-ng-show=\"udata && (udata.role == 'login'||udata.role == 'panLogin')\"\r\n                                    target=\"_self\"\r\n                                    data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/quicklinks/userservices\"\r\n                                    data-ng-class=\"{'disabledanchor' : udata.disableMenu && !enableServices, 'dropdown-toggle' : !udata.disableMenu && !enableServices}\"\r\n                                    style='display: block;text-decoration: none;'>User Services</a>\r\n                            </div>\r\n                            <ul class=\"isubmenu services\"\r\n                                data-ng-class=\"{'services': !udata,'oth': udata && udata.role == 'login' && udata.utype != 'UN','isubmenu pay post': udata && udata.role == 'login' && udata.utype == 'O','isubmenu ar': udata && udata.role == 'login' && udata.utype == 'AR','isubmenu us uinu': udata  && udata.utype == 'UN' && udata.role == 'login','isubmenu us uinu pre': udata  && udata.utype == 'UN' && udata.role == 'panLogin', 'isubmenu us rf': udata  && udata.utype == 'RF','isubmenu us es': udata && udata.role == 'login' && udata.utype == 'ES'}\">\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' || udata.utype=='UN' || udata.utype=='O') && udata.utype!='ES'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu && !enableServices}\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/savedapp\"\r\n                                        data-ng-class=\"{'disabledanchor' : udata.disableMenu && !enableServices}\">My\r\n                                        Saved Applications</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' ) && udata.utype!='ES'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/litserv/auth/drc03register\"\r\n                                        data-ng-class=\"{'disabledanchor' : udata.disableMenu}\">DRC-03 Register</a>\r\n                                </li>\r\n\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' || udata.utype=='O')&& udata.utype!='ES' && udata.utype != 'AR'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu && !enableServices}\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services2/auth/getlistofnotices\"\r\n                                        data-ng-class=\"{'disabledanchor' : udata.disableMenu && !enableServices}\">Notices\r\n                                        / Intimations Issued</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' ) && udata.utype!='ES'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/litserv/auth/case/search\"\r\n                                        data-ng-class=\"{'disabledanchor' : udata.disableMenu}\">My Applications</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.utype=='UN' || udata.utype=='O') && udata.utype != 'AR' && udata.utype != 'ES'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/certs\"\r\n                                        data-ng-class=\"{'disabledanchor' :udata.disableMenu}\">View/Download\r\n                                        Certificates</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' || udata.utype=='UN' || udata.utype=='O') && udata.utype != 'AR' && udata.utype != 'ES'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu && !enableServices}\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/notices\"\r\n                                        data-ng-class=\"{'disabledanchor' : udata.disableMenu && !enableServices}\">View\r\n                                        Notices and Orders</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && (udata.role == 'login' || udata.role == 'panLogin' || udata.utype=='UN' || udata.utype=='O') && udata.utype != 'AR'  && udata.utype!='ES'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                                    <a data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/submissions\"\r\n                                        data-ng-class=\"{'disabledanchor' :udata.disableMenu}\">View My Submissions</a>\r\n                                </li>\r\n                                <li data-ng-show=\"udata && udata.role == 'panLogin' && udata.utype!='TR'\"\r\n                                    data-ng-class=\"{'disabled' :udata.disableMenu}\" data-toggle=\"tooltip\"\r\n                                    data-placement=\"top\">\r\n                               