.captchaObj.refresh();\r\n\t\t\t\t\t\t\t$scope.alertMsgLogin = false;\r\n                            $scope.errorMsg1 = \"Enter valid letters shown in the image below\";\r\n                        }\r\n\t\t\t\t}\r\n            }, function (response) {\r\n\r\n            });\r\n        } else {\r\n            $scope.alertMsgLogin = true;\r\n            $('#fo-email').focus();\r\n        }\r\n    };\r\n\r\n    //resendOTP\r\n    $scope.resendOtp = function (a) {\r\n        $scope.errorMsg2={};\r\n         $scope.errorMsg2[\"login_error\"] = false;\r\n        if ($scope.forgotpass_2.cap.$valid) {\r\n        \t$scope.oneClick3 = false;\r\n            $scope.oneClick = false;\r\n            var details = {\r\n\r\n            type: a,\r\n            captcha: $scope.data.captcha\r\n            \t\r\n            };\r\n\r\n        //var otpDetails = JSON.stringify(details);\r\n       // $scope.alertMsgLogin = true;\r\n\r\n\r\n        ajax.post(\"/services/resendotp\", details, function () {\r\n            $().blockPage(true);\r\n        }, function () {\r\n            $().blockPage(false);\r\n        }).then(function (response) {\r\n\r\n            if (response.errorCode === \"SWEB_9021\") {\r\n                if ($scope.forgotpass_2.$setPristine) {\r\n                    $scope.forgotpass_2.$setPristine();\r\n                    $scope.alertMsgLogin = false;\r\n                    $scope.data.captcha = null;\r\n                    $scope.oneClick3 = false;\r\n                    $scope.captchaObj.refresh();\r\n                    $scope.errorMsg1 = $scope.trans[\"ERR_\" + response.errorCode];\r\n                }\r\n            } else if (response.errorCode === \"SWEB_8000\") {\r\n                if ($scope.forgotpass_2.$setPristine) {\r\n                     $scope.forgotpass_2.$setPristine();\r\n                     $scope.alertMsgLogin = false;\r\n                     $scope.data.captcha = null;\r\n                     $scope.oneClick3 = false;\r\n                     $s