R10'||scope.formType=='GSTR9'||scope.formType=='GSTR9A'||scope.formType=='GSTR7'||scope.formType=='GSTR8'||scope.formType=='CMP08' || scope.formType == 'GSTR6' ||scope.formType=='GSTR5' || scope.formType == 'EINV-EXMPT' ||scope.formType == 'Returns'|| scope.formType=='UnblockGstin') {\n\t\t\t\t\t\t if(!scope.mobileno || scope.mobileno == '' || scope.mobileno == undefined){\n\t                         scope.setErr(\"One-Time Password (OTP) has been sent to your registered email ID \"+scope.emailsend+\" registered at the GST portal\", 'success');\n\t                        \n\t                    }\n\t                    else{\n\t                    \tscope.setErr(\"One-Time Password (OTP) has been sent to your registered email ID \"+scope.emailsend+\" and mobile no. \"+scope.mobile+\". OTP is Valid Till \"+scope.validityOtp+\" \", 'success');\n\t                    }\n\t\t\t\t\t} else {\n\t\t\t\t\t\t$('.resenfun').hide();\n\t\t\t\t\t\t//CR#28913-B Code changes starts\n\t\t\t\t\t\tif (isUnRegApplCancel) {\n\t\t\t\t\t\t\tscope.setErr(\"OTP has been sent to your Email and Mobile number registered at the GST portal\", 'success');\n\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tif (!scope.mobileno || scope.mobileno == '' || scope.mobileno == undefined) {\t\t\t\t\t\t\t\n\t\t                        scope.setErr(\"OTP has been sent to your Email registered at the GST portal\", 'success');\n\t\t\t\t\t\t\t} else {\n\t\t\t\t\t\t\tscope.setErr(\"OTP has been sent to your Email and Mobile number registered at the GST portal\", 'success');\n\t\t                    }\n\t\t\t\t\t\t}\n\t\t\t\t\t\t//CR#28913-B Code changes ends\t\t\t\t\t\t\n\t\t\t\t\t}\n                   \n                   \t\t\t\n                    scope.msg = resp.message;\n                } else if (resp.stscd === \"SWEB_9000\") {\n                \tscope.captchaError = true;\n                    scope.captchaValue = null;\n                    scope.reset();\n\t\t\t\t} else if (resp.stscd === \"0\") {\n                    scope.reset();\n                    scope.setErr(\"OTP could not be generated please try again.\", 'error'); \n\t\t\t\t} else {\n\t\t\t\t\tscope.setErr(\"OTP could not be generated please try again.\", 'error');\n\t\t\t\t}\t\n\t\t\t}, function (err) {\n\t\t\t\tscope.setErr(\"Unable to generate OTP. Please try again.\", 'error');\n\t\t\t});\n\t\t};\n\t}\n\treturn {\n\t\trestrict: 'A',\n\t\tscope: {\n\t\t\t\"signUrl\": \"@\",\n\t\t\t\"otpUrl\": \"@\",\n\t\t\t\"rPayload\": \"@\",\n\t\t\t\"callBack\": \"&\",\n\t\t\t\"submitCk\": \"&\",\n\t\t\t\"formType\": \"@\",\n\t\t\t\"tranId\": \"@\",\n\t\t\t\"username\": \"@\",\n\t\t\t\"email\": \"@\",\n            \"mobileno\": \"@\",\n            \"stCode\": \"@\",\n            \"uuid\": \"@\",\n            \"captchaValue\": \"=\",\n            \"captchaError\": \"=\",\n            \"refreshCaptcha\": \"&\",\n\t\t\t\"formvalue\":\"@\"\n\t\t},\n\t\tcompile: function (tElement) {\n\t\t\treturn link;\n\t\t},\n\t\ttemplate: function (ele, attrs, scope) {\n\t\t\treturn \"<button type='button' title='{{btnValue}}' class='btn btn-primary' data-ng-click='submit()'>{{btnValue}}</button><div id='otpPrompt' class='modal fade text-left' role='dialog'><div class='modal-dialog'><div class='modal-content'><div class='modal-header'><h4 class='modal-title'>Validate One Time Password (OTP)</h4></div><div class='modal-body'><div class='alert alert-{{errtype}} rowtp-mar' data-ng-if='err'><p data-ng-bind='err'></p></div><label class='reg'>Enter One Time Password (OTP)</label><form novalidate><input type='password' name='otp' id='otpinput' class='form-control upper-input' data-capitalize='' data-ng-model='otp' maxlength='6' autofocus></form></div><div class='modal-footer'><button type='button' class='btn btn-default' data-ng-click='reset()'>Cancel</button><button type='button' data-ng-click='submitEVC()' class='btn btn-primary'>Verify</button> <button type='button' class='btn btn-primary resenfun' data-ng-disabled='resendDisable' data-ng-click='count