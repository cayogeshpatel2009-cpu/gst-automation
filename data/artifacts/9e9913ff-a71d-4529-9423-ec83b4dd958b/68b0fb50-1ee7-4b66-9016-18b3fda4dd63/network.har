g-href=\"{{servers.GST_SERVICES_R1_URL}}/services/auth/dashboard\">Dashboard</a>\r\n                    <a data-ng-show=\"udata && udata.role == 'panLogin'\"\r\n                        data-ng-href=\"{{servers.GST_REGISTRATION_R1_URL}}/registration/auth/dashboard\">Dashboard</a>\r\n                    <a class=\"nav_home\" data-ng-show=\"!udata || udata.role == undefined\"\r\n                        data-ng-href=\"{{servers.GST_CONTENT_R1_URL}}/\">Home</a>\r\n                </li>\r\n                <!-- CR#22679 Enabling changes -->\r\n                <li class=\"dropdown drpdwn menuList\"\r\n                    data-ng-class=\"{'active': servers.NAV_COMPONENT == 'services', 'disabled' :udata.disableMenu && !enableServices}\">\r\n                    <a data-ng-href=\"#\"\r\n                        data-ng-class=\"{'disabledanchor' : udata.disableMenu && !enableServices, 'dropdown-toggle' : !udata.disableMenu && !enableServices}\"\r\n                        data-toggle=\"dropdown\" role=\"button\" aria-expanded=\"false\">Services <span\r\n                            class=\"caret\"></span></a>\r\n                    <ul class=\"dropdown-menu smenu\" role=\"menu\">\r\n                        <li class=\"has-sub\" data-ng-hide=\"(udata.utype=='RF'  || udata.utype=='ES')\"\r\n                            data-ng-class=\"{'disabled' :udata.disableMenu && !enableServices}\">\r\n                            <a data-ng-show=\"!udata || (udata && udata.role == 'panLogin')\"\r\n                                data-ng-href=\"{{servers.GST_SERVICES_R1_URL}}/services/quicklinks/registration\"\r\n                                data-ng-class=\"{'disabledanchor' :udata.disableMenu, 'dropdown-toggle' : !udata.disableMenu}\">Registration</a>\r\n                            <div data-ng-if=\"enableServices\">\r\n                                <a data-ng-show=\"udata && udata.role == 'login'\"\r\n                                    data-ng-class=\"{'disabledanchor' : udata.disableMenu 